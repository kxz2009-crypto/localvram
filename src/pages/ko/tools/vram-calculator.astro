---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../../data/root-alternates";

const pagePath = "/ko/tools/vram-calculator/";
const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "VRAM Calculator KO",
  url: "https://localvram.com/ko/tools/vram-calculator/",
  inLanguage: "ko"
};
---

<BaseLayout
  title="LocalVRAM KO | VRAM Calculator"
  description="한국어 CTA 전환 진입 페이지."
  locale="ko"
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={structuredData}
>
  <main class="container">
    <section class="card">
      <h1>VRAM Calculator (KO)</h1>
      <p>한국어 퍼널 라우팅을 위한 CTA 전환 페이지입니다.</p>
      <div class="cta-row">
        <a class="btn" href="/ko/guides/local-llm-cost-vs-cloud/">주제 페이지로 돌아가기</a>
        <a class="btn" href="/ko/models/qwen35-35b-q4/">모델 페이지로 돌아가기</a>
      </div>
    </section>
  </main>
</BaseLayout>
