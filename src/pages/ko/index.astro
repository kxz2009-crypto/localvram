---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../data/root-alternates";

const pagePath = "/ko/";
const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "LocalVRAM Korean",
  url: "https://localvram.com/ko/",
  inLanguage: "ko",
  description: "LocalVRAM 다국어 SEO 확장을 위한 한국어 라우트."
};
---

<BaseLayout
  title="LocalVRAM | Korean"
  description="LocalVRAM 다국어 SEO 확장을 위한 한국어 라우트."
  locale="ko"
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={structuredData}
>
  <main class="container">
    <header class="simple-header">
      <img src="/branding/logo.svg" alt="LocalVRAM" />
      <a class="btn" href="/en/">English</a>
    </header>
    <section class="hero">
      <img class="verified-pill" src="/branding/ollama-verified-pill.svg" alt="Ollama Verified" />
      <h1>한국어 라우트가 활성화되었습니다</h1>
      <p>
        한국어 SEO와 운영은 영어 및 중국어 사이트와 분리되어 운영됩니다.
      </p>
      <div class="cta-row">
        <a class="btn btn-primary" href="/ko/tools/vram-calculator/">핵심 도구 열기</a>
        <a class="btn" href="/ko/guides/local-llm-cost-vs-cloud/">주제 페이지</a>
        <a class="btn" href="/ko/models/qwen35-35b-q4/">모델 페이지</a>
        <a class="btn" href="/ko/guides/ollama-vs-vllm-vram/">런타임 비교 가이드</a>
        <a class="btn" href="/en/status/data-freshness/">데이터 최신성</a>
        <a class="btn" href="/ko/tools/roi-calculator/">ROI Calculator</a>
        <a class="btn" href="/ko/tools/quantization-blind-test/">Quantization Blind Test</a>
        <a class="btn" href="/ko/benchmarks/changelog/">Benchmark Changelog</a>
        <a class="btn" href="/ko/status/data-freshness/">Data Freshness</a>
        <a class="btn" href="/ko/benchmarks/">Benchmark Hub</a>
        <a class="btn" href="/ko/status/pipeline-status/">Pipeline Status</a>
        <a class="btn" href="/ko/models/">Model Catalog</a>
        <a class="btn" href="/ko/hardware/">Hardware Tiers</a>
        <a class="btn" href="/ko/status/">Status Hub</a>
        <a class="btn" href="/ko/status/conversion-funnel/">Conversion Funnel</a>
        <a class="btn" href="/ko/errors/">Error KB</a>
      </div>
    </section>
  </main>
</BaseLayout>





