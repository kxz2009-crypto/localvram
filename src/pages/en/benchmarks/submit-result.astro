---
import BaseLayout from "../../../layouts/BaseLayout.astro";

const pagePath = "/en/benchmarks/submit-result/";
const pageTitle = "Submit Your Test Result | LocalVRAM";
const pageDescription = "Contribute your hardware benchmark data to LocalVRAM with a standardized precheck flow.";
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: "Submit Your Test Result",
    description: pageDescription,
    url: `https://localvram.com${pagePath}`,
    inLanguage: "en",
  },
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    name: "Submit a LocalVRAM benchmark result",
    description: pageDescription,
    step: [
      {
        "@type": "HowToStep",
        name: "Prepare hardware details",
        text: "Record model ID, hardware profile, Ollama version, backend, prompt shape, throughput, and runtime notes.",
      },
      {
        "@type": "HowToStep",
        name: "Run the precheck",
        text: "Score the submission with the LocalVRAM precheck command before opening a review issue.",
      },
      {
        "@type": "HowToStep",
        name: "Open a GitHub issue",
        text: "Attach the data package, logs, and screenshots for manual validation.",
      },
    ],
  },
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  locale="en"
  canonicalPath={pagePath}
  structuredData={structuredData}
>
  <main class="container">
    <h1>Submit Your Test Result</h1>
    <p>Community submissions are accepted after automated precheck and manual validation.</p>

    <section class="card">
      <h2>Required submission fields</h2>
      <ul>
        <li>Model ID (example: <code>llama-70b-q4</code>)</li>
        <li>Hardware profile (GPU, CPU, RAM, OS)</li>
        <li>Ollama version and backend (CUDA/ROCm/Metal)</li>
        <li>Prompt shape and context length</li>
        <li>Measured token throughput and runtime notes</li>
      </ul>
    </section>

    <section class="card terminal-card">
      <h2>Precheck command</h2>
      <pre><code>python scripts/score-user-submission.py --model-id llama-70b-q4 --hardware "RTX 4090 24GB + WSL2" --score 0.91 --submitter-id github:your-id --issue-url "https://github.com/kxz2009-crypto/localvram/issues/123"</code></pre>
    </section>

    <section class="card">
      <h2>Submission channel</h2>
      <p>
        Open a GitHub issue with your data package and include benchmark logs/screenshots.
      </p>
      <a class="btn btn-primary" href="https://github.com/kxz2009-crypto/localvram/issues/new">
        Open GitHub issue
      </a>
      <a class="btn" href="/en/status/submission-review/" style="margin-left: 8px;">
        View review queue
      </a>
    </section>
  </main>
</BaseLayout>
