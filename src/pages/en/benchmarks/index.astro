---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import clusterBenchmarks from "../../../data/cluster-benchmarks.json";

type ClusterNode = {
  endpoint?: string;
  status?: string;
  avg_tokens_per_s?: number;
  avg_latency_ms?: number;
  error?: string;
};

type ClusterTest = {
  topology?: string;
  model_id?: string;
  verified_date?: string;
  id?: string;
  metrics?: {
    tokens_per_s?: number;
    avg_node_latency_ms?: number;
  };
  nodes?: ClusterNode[];
};

const clusterTests = Array.isArray(clusterBenchmarks.tests) ? clusterBenchmarks.tests : [];
const latestCluster = (clusterTests[0] || null) as ClusterTest | null;
const latestNodes = latestCluster && Array.isArray(latestCluster.nodes) ? latestCluster.nodes : [];
const clusterUpdatedAt = clusterBenchmarks.updated_at || "";
const trendPoints = clusterTests
  .slice(0, 12)
  .reverse()
  .map((item: ClusterTest) => {
    const date = (item.verified_date || "").trim();
    const fallback = (item.id || "").replace(/^cluster_/, "").slice(0, 8);
    const labelDate = date || fallback || "unknown";
    return {
      label: `${labelDate} · ${item.model_id || "unknown"}`,
      tokensPerSecond: typeof item.metrics?.tokens_per_s === "number" ? item.metrics.tokens_per_s : null,
      latencyMs: typeof item.metrics?.avg_node_latency_ms === "number" ? item.metrics.avg_node_latency_ms : null,
    };
  });
---

<BaseLayout
  title="Benchmarks | LocalVRAM"
  description="Benchmark update timeline and community result submission for LocalVRAM."
  locale="en"
>
  <main class="container">
    <h1>Benchmarks</h1>
    <p>Track what changed, when it changed, and submit verified runs from your own hardware.</p>

    <section class="card-grid">
      <article class="card">
        <h2>Benchmark Changelog</h2>
        <p>Every update with date, environment, and result deltas.</p>
        <a class="btn btn-primary" href="/en/benchmarks/changelog/">Open changelog</a>
      </article>
      <article class="card">
        <h2>Submit Your Test Result</h2>
        <p>Community-backed data pipeline with precheck and manual review.</p>
        <a class="btn btn-primary" href="/en/benchmarks/submit-result/">Open submit guide</a>
      </article>
      <article class="card">
        <h2>Cluster Runbook</h2>
        <p>Network checklist and topology guidance for local multi-node Ollama setup.</p>
        <a class="btn btn-primary" href="/en/guides/ollama-local-cluster-network/">Open guide</a>
      </article>
    </section>

    <section class="card" style="margin-top: 16px;">
      <h2>Latest Cluster Snapshot</h2>
      {latestCluster ? (
        <>
          <p>
            Updated {clusterUpdatedAt ? clusterUpdatedAt.slice(0, 10) : "unknown"} · Topology {latestCluster.topology}
            {" "}· Model {latestCluster.model_id} · Aggregate {latestCluster.metrics?.tokens_per_s ?? "N/A"} tok/s
          </p>
          <div style="overflow-x: auto; margin-top: 12px;">
            <table class="table">
              <thead>
                <tr>
                  <th>Endpoint</th>
                  <th>Status</th>
                  <th>Avg tok/s</th>
                  <th>Avg latency</th>
                  <th>Error</th>
                </tr>
              </thead>
              <tbody>
                {latestNodes.map((node: ClusterNode) => (
                  <tr>
                    <td>{node.endpoint || "unknown"}</td>
                    <td>{node.status || "unknown"}</td>
                    <td>{typeof node.avg_tokens_per_s === "number" ? node.avg_tokens_per_s.toFixed(2) : "N/A"}</td>
                    <td>{typeof node.avg_latency_ms === "number" ? `${node.avg_latency_ms.toFixed(1)} ms` : "N/A"}</td>
                    <td>{node.error || "-"}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </>
      ) : (
        <p>No cluster benchmark data yet. Configure `LV_CLUSTER_ENDPOINTS` to start publishing snapshots.</p>
      )}
    </section>

    <section class="card" style="margin-top: 16px;">
      <h2>Cluster Performance Trend</h2>
      <p>Recent cluster runs with aggregate tokens/s and average node latency.</p>
      <canvas id="cluster-trend-chart" aria-label="Cluster benchmark trend chart" style="height: 280px;"></canvas>
    </section>
  </main>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js" defer></script>
  <script define:vars={{ trendPoints }}>
    const mountClusterTrend = () => {
      const canvas = document.getElementById("cluster-trend-chart");
      if (!canvas || !window.Chart) return;
      const labels = trendPoints.map((p) => p.label);
      const tps = trendPoints.map((p) => p.tokensPerSecond);
      const latency = trendPoints.map((p) => p.latencyMs);
      if (!labels.length) return;
      new window.Chart(canvas, {
        type: "line",
        data: {
          labels,
          datasets: [
            {
              label: "Aggregate tok/s",
              data: tps,
              borderColor: "#0ea5e9",
              backgroundColor: "rgba(14,165,233,0.15)",
              yAxisID: "y",
              tension: 0.25,
            },
            {
              label: "Avg node latency (ms)",
              data: latency,
              borderColor: "#fb923c",
              backgroundColor: "rgba(251,146,60,0.12)",
              yAxisID: "y1",
              tension: 0.25,
            },
          ],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          scales: {
            y: {
              title: { display: true, text: "tok/s" },
              ticks: { color: "#94a3b8" },
              grid: { color: "rgba(148,163,184,0.15)" },
            },
            y1: {
              position: "right",
              title: { display: true, text: "ms" },
              ticks: { color: "#94a3b8" },
              grid: { drawOnChartArea: false },
            },
            x: {
              ticks: { color: "#94a3b8", maxRotation: 20, minRotation: 20 },
              grid: { color: "rgba(148,163,184,0.08)" },
            },
          },
          plugins: {
            legend: { labels: { color: "#cbd5e1" } },
          },
        },
      });
    };
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", mountClusterTrend, { once: true });
    } else {
      mountClusterTrend();
    }
  </script>
</BaseLayout>
