---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import changelog from "../../../data/benchmark-changelog.json";
import benchmarkResults from "../../../data/benchmark-results.json";

const benchmarkMap = benchmarkResults.models || {};
const measuredCount = Object.values(benchmarkMap).filter((item) => item?.status === "ok").length;
const latestMeasuredAt = benchmarkResults.updated_at || changelog.updated_at || "";
const pagePath = "/en/benchmarks/changelog/";
const pageUrl = `https://localvram.com${pagePath}`;
const datasetSchema = {
  "@context": "https://schema.org",
  "@type": "Dataset",
  name: "LocalVRAM Benchmark Changelog",
  description: "Date-stamped benchmark updates with environment details and measurable result deltas.",
  url: pageUrl,
  inLanguage: "en",
  dateModified: latestMeasuredAt || changelog.updated_at,
  creator: {
    "@type": "Organization",
    name: "LocalVRAM"
  }
};
---

<BaseLayout
  title="Benchmark Changelog | LocalVRAM"
  description="Date-stamped benchmark updates with environment details and measurable result changes."
  locale="en"
  canonicalPath={pagePath}
  structuredData={datasetSchema}
>
  <main class="container">
    <h1>Benchmark Changelog</h1>
    <p>
      Last updated: {new Date(changelog.updated_at).toISOString().slice(0, 10)}.
      This page is updated whenever benchmark baselines change.
    </p>
    <p>
      Real measured tags in production map: <strong>{measuredCount}</strong>.
      Latest measurement sync: <strong>{latestMeasuredAt || "N/A"}</strong>.
    </p>

    <section class="post-list">
      {changelog.items.map((entry) => (
        <article class="post-card">
          <h2>{entry.date} - {entry.title}</h2>
          <p>{entry.environment}</p>
          <ul>
            {entry.changes.map((change) => (
              <li>{change}</li>
            ))}
          </ul>
        </article>
      ))}
    </section>
  </main>
</BaseLayout>
