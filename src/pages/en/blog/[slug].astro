---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import catalog from "../../../data/model-catalog.json";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => data.lang === "en");
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const postPath = `/en/blog/${post.slug}/`;
const postUrl = `https://localvram.com${postPath}`;
const publishedIso = post.data.pubDate.toISOString();
const modifiedIso = (post.data.updatedDate || post.data.pubDate).toISOString();
const normalizeToken = (value: unknown) =>
  String(value || "")
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");
const primaryHaystack = [
  post.slug,
  post.data.title,
  post.data.description,
  ...(post.data.tags || [])
].join(" ").toLowerCase();
const bodyHaystack = String(post.body || "").toLowerCase();
const normalizedPrimaryHaystack = normalizeToken(primaryHaystack);
const normalizedBodyHaystack = normalizeToken(bodyHaystack);
const quantScore = (quantization: string) => {
  const quant = String(quantization || "").toUpperCase();
  if (quant === "Q4") return 8;
  if (quant === "Q5") return 6;
  if (quant === "Q8") return 4;
  if (quant === "FP16") return 1;
  return 0;
};
const modelScore = (item: (typeof catalog.items)[number]) => {
  const tag = String(item.ollama_tag || "").toLowerCase();
  const tagSlug = normalizeToken(tag);
  const idSlug = normalizeToken(item.id);
  const librarySlug = normalizeToken(item.library_id);
  const familySlug = normalizeToken(item.family);
  let score = 0;
  if (tag && primaryHaystack.includes(tag)) score += 180;
  if (tagSlug && normalizedPrimaryHaystack.includes(tagSlug)) score += 160;
  if (idSlug && normalizedPrimaryHaystack.includes(idSlug)) score += 140;
  if (librarySlug && normalizedPrimaryHaystack.includes(librarySlug)) score += 70;
  if (familySlug && normalizedPrimaryHaystack.includes(familySlug)) score += 30;
  if (tag && bodyHaystack.includes(tag)) score += 35;
  if (tagSlug && normalizedBodyHaystack.includes(tagSlug)) score += 30;
  if (idSlug && normalizedBodyHaystack.includes(idSlug)) score += 25;
  if (librarySlug && normalizedBodyHaystack.includes(librarySlug)) score += 15;
  if (familySlug && normalizedBodyHaystack.includes(familySlug)) score += 8;
  if (!score) return 0;
  score += quantScore(item.quantization);
  if (item.data_status === "measured") score += 8;
  if (item.is_top20_curated) score += 6;
  return score;
};
const relatedModelCandidates = new Map<
  string,
  { item: (typeof catalog.items)[number]; score: number }
>();
for (const item of catalog.items) {
  const score = modelScore(item);
  if (!score) continue;
  const key = String(item.ollama_tag || item.library_id || item.id);
  const existing = relatedModelCandidates.get(key);
  if (!existing || score > existing.score) {
    relatedModelCandidates.set(key, { item, score });
  }
}
const relatedModels = Array.from(relatedModelCandidates.values())
  .sort((a, b) => b.score - a.score || String(a.item.name).localeCompare(String(b.item.name)))
  .slice(0, 5)
  .map(({ item }) => ({
    id: item.id,
    name: item.name,
    tag: item.ollama_tag,
    status: item.data_status === "measured" ? "measured" : "estimated",
    quantization: item.quantization,
    vramMin: item.vram_min_gb,
    vramOptimal: item.vram_optimal_gb
  }));
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.description,
  datePublished: publishedIso,
  dateModified: modifiedIso,
  inLanguage: "en",
  author: {
    "@type": "Organization",
    name: "LocalVRAM"
  },
  publisher: {
    "@type": "Organization",
    name: "LocalVRAM",
    logo: {
      "@type": "ImageObject",
      url: "https://localvram.com/branding/logo.svg"
    }
  },
  mainEntityOfPage: postUrl,
  url: postUrl,
  keywords: post.data.tags,
  about: relatedModels.slice(0, 3).map((model) => ({
    "@type": "SoftwareApplication",
    name: model.name,
    url: `https://localvram.com/en/models/${model.id}/`,
    applicationCategory: "AI model"
  }))
};
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: "https://localvram.com/en/"
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Blog",
      item: "https://localvram.com/en/blog/"
    },
    {
      "@type": "ListItem",
      position: 3,
      name: post.data.title,
      item: postUrl
    }
  ]
};
const relatedModelsSchema = relatedModels.length
  ? {
      "@context": "https://schema.org",
      "@type": "ItemList",
      name: `${post.data.title} related model pages`,
      itemListElement: relatedModels.map((model, index) => ({
        "@type": "ListItem",
        position: index + 1,
        name: model.name,
        url: `https://localvram.com/en/models/${model.id}/`
      }))
    }
  : null;
const structuredData = relatedModelsSchema
  ? [articleSchema, breadcrumbSchema, relatedModelsSchema]
  : [articleSchema, breadcrumbSchema];
---

<BaseLayout
  title={`${post.data.title} | LocalVRAM`}
  description={post.data.description}
  locale="en"
  canonicalPath={postPath}
  ogType="article"
  publishedTime={publishedIso}
  modifiedTime={modifiedIso}
  structuredData={structuredData}
>
  <main class="container">
    <article class="post-page">
      <header class="post-header">
        <h1>{post.data.title}</h1>
        <p>{post.data.description}</p>
        <div class="meta-row">
          <span>Published: {post.data.pubDate.toISOString().slice(0, 10)}</span>
          {post.data.updatedDate && (
            <span>Updated: {post.data.updatedDate.toISOString().slice(0, 10)}</span>
          )}
          <span>Intent: {post.data.intent}</span>
        </div>
      </header>

      <section class="prose">
        <Content />
      </section>

      {relatedModels.length > 0 && (
        <section class="card">
          <h2>Related model pages</h2>
          <p>Model profiles referenced by this article, with VRAM fit and measured or estimated status.</p>
          <ul class="link-list">
            {relatedModels.map((model) => (
              <li>
                <a href={`/en/models/${model.id}/`}>{model.name}</a>
                <span>
                  {model.tag} · {model.quantization} · {model.vramMin}-{model.vramOptimal}GB VRAM · {model.status}
                </span>
              </li>
            ))}
          </ul>
        </section>
      )}

      <section class="cta-row">
        <a class="btn" href="/en/tools/vram-calculator/">Check model fit</a>
        <a class="btn" href="/en/errors/">Open Error KB</a>
        <a class="btn btn-primary" href="/en/status/data-freshness/">View latest verified data</a>
      </section>
    </article>
  </main>
</BaseLayout>
