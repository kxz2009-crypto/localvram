---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import tiers from "../../../data/hardware-tiers.json";

const pagePath = "/en/hardware/";
const pageTitle = "Hardware Tiers | LocalVRAM";
const pageDescription = "Pick Ollama models by available VRAM tier.";
const hardwareItems = [
  ...tiers.tiers.map((tier) => ({
    name: `${tier.vram_gb}GB VRAM`,
    url: `https://localvram.com/en/hardware/${tier.vram_gb}gb-vram-models/`,
  })),
  {
    name: "Apple Silicon",
    url: "https://localvram.com/en/hardware/apple-silicon-llm-guide/",
  },
  {
    name: "Verified on RTX 3090",
    url: "https://localvram.com/en/hardware/verified-3090/",
  },
];
const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Hardware Tiers",
  description: pageDescription,
  url: `https://localvram.com${pagePath}`,
  inLanguage: "en",
  mainEntity: {
    "@type": "ItemList",
    numberOfItems: hardwareItems.length,
    itemListElement: hardwareItems.map((item, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: item.name,
      url: item.url,
    })),
  },
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  locale="en"
  canonicalPath={pagePath}
  structuredData={structuredData}
>
  <main class="container">
    <h1>Hardware VRAM Tiers</h1>
    <section class="card-grid">
      {tiers.tiers.map((tier) => (
        <article class="card">
          <h2>{tier.vram_gb}GB VRAM</h2>
          <p>{tier.summary}</p>
          <a class="btn btn-primary" href={`/en/hardware/${tier.vram_gb}gb-vram-models/`}>
            View recommended models
          </a>
        </article>
      ))}
      <article class="card">
        <h2>Apple Silicon</h2>
        <p>Unified memory planning guide for local LLM inference on M-series devices.</p>
        <a class="btn btn-primary" href="/en/hardware/apple-silicon-llm-guide/">
          Open Apple Silicon guide
        </a>
      </article>
      <article class="card">
        <h2>Verified on RTX 3090</h2>
        <p>Measured model tags and sustained-load benchmark snapshots on 3090.</p>
        <a class="btn btn-primary" href="/en/hardware/verified-3090/">
          Open verification page
        </a>
      </article>
    </section>
  </main>
</BaseLayout>
