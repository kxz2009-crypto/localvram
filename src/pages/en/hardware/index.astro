---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import tiers from "../../../data/hardware-tiers.json";
---

<BaseLayout
  title="Hardware Tiers | LocalVRAM"
  description="Pick Ollama models by available VRAM tier."
  locale="en"
  canonicalPath="/en/hardware/"
>
  <main class="container">
    <h1>Hardware VRAM Tiers</h1>
    <section class="card-grid">
      {tiers.tiers.map((tier) => (
        <article class="card">
          <h2>{tier.vram_gb}GB VRAM</h2>
          <p>{tier.summary}</p>
          <a class="btn btn-primary" href={`/en/hardware/${tier.vram_gb}gb-vram-models/`}>
            View recommended models
          </a>
        </article>
      ))}
      <article class="card">
        <h2>Apple Silicon</h2>
        <p>Unified memory planning guide for local LLM inference on M-series devices.</p>
        <a class="btn btn-primary" href="/en/hardware/apple-silicon-llm-guide/">
          Open Apple Silicon guide
        </a>
      </article>
    </section>
  </main>
</BaseLayout>
