---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import errorData from "../../../data/errors.json";
import affiliateLinks from "../../../data/affiliate-links.json";
import { ROOT_ALTERNATES } from "../../../data/root-alternates";

export function getStaticPaths() {
  return errorData.errors.map((item) => ({
    params: { slug: item.id },
    props: { item }
  }));
}

const { item } = Astro.props;
const pagePath = `/en/errors/${item.id}/`;
const pageUrl = `https://localvram.com${pagePath}`;
const localizedErrorIds = new Set(["cuda-out-of-memory"]);
const errorAlternates = localizedErrorIds.has(String(item.id || "")) ? ROOT_ALTERNATES : [];

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: `Fix ${item.title}`,
  inLanguage: "en",
  url: pageUrl,
  about: {
    "@type": "SoftwareSourceCode",
    text: item.raw_stack_trace
  },
  step: item.fixes.map((fix) => ({
    "@type": "HowToStep",
    name: fix.label,
    text: fix.command
  }))
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: `What causes ${item.title}?`,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.causes.join(" ")
      }
    },
    {
      "@type": "Question",
      name: "What is the fastest way to fix this error?",
      acceptedAnswer: {
        "@type": "Answer",
        text: `Use the copy-fix commands listed in this page and verify with the provided terminal workflow for ${item.title}.`
      }
    }
  ]
};

const techArticleSchema = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  headline: `${item.title} fix guide`,
  description: item.symptom,
  inLanguage: "en",
  url: pageUrl,
  author: {
    "@type": "Organization",
    name: "LocalVRAM"
  },
  about: item.title
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: "https://localvram.com/en/"
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Error KB",
      item: "https://localvram.com/en/errors/"
    },
    {
      "@type": "ListItem",
      position: 3,
      name: item.title,
      item: pageUrl
    }
  ]
};
---

<BaseLayout
  title={`${item.title} | LocalVRAM`}
  description={item.symptom}
  locale="en"
  canonicalPath={pagePath}
  alternates={errorAlternates}
  ogType="article"
  structuredData={[howToSchema, faqSchema, techArticleSchema, breadcrumbSchema]}
>
  <main class="container">
    <h1>{item.title}</h1>
    <p>{item.symptom}</p>

    <section class="card terminal-card">
      <h2>Raw Stack Trace</h2>
      <pre><code>{item.raw_stack_trace}</code></pre>
    </section>

    <section class="card-grid">
      <article class="card">
        <h2>Common causes</h2>
        <ul>
          {item.causes.map((cause) => <li>{cause}</li>)}
        </ul>
      </article>
      <article class="card">
        <h2>Copy-fix commands</h2>
        <ul>
          {item.fixes.map((fix) => (
            <li>
              <strong>{fix.label}</strong>
              <code>{fix.command}</code>
            </li>
          ))}
        </ul>
      </article>
    </section>

    <section class="cta-row">
      <a class="btn" href="/en/tools/vram-calculator/">Use smaller model</a>
      <a class="btn" href="/en/tools/quantization-blind-test/">Switch quantization</a>
      <a class="btn btn-primary" href={affiliateLinks.runpod}>Use Cloud 48GB</a>
    </section>
  </main>
</BaseLayout>
