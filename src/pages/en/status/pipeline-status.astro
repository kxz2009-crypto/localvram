---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import pipelineStatus from "../../../data/pipeline-status.json";
import pipelineSlo from "../../../data/pipeline-slo.json";

type WorkflowRow = {
  workflow_key?: string;
  workflow_name?: string;
  run_id?: string;
  run_url?: string;
  status?: string;
  conclusion?: string;
  event?: string;
  head_sha?: string;
  failure_class?: string;
  failure_detail?: string;
  updated_at?: string;
};

type SloWindow = {
  total_runs?: number;
  success_runs?: number;
  failure_runs?: number;
  success_rate?: number;
  target_success_rate?: number;
  slo_met?: boolean;
  top_failure_class?: string;
};

type SloWorkflow = {
  workflow_key?: string;
  workflow_name?: string;
  current_success_streak?: number;
  last_success_at?: string;
  last_failure_at?: string;
  windows?: Record<string, SloWindow>;
};

type FailureRecommendation = {
  workflow_key?: string;
  workflow_name?: string;
  failure_class?: string;
  count?: number;
  action?: string;
};

const workflowsMap = (pipelineStatus.workflows || {}) as Record<string, WorkflowRow>;
const preferredOrder = ["weekly_benchmark", "daily_content", "publish_benchmark_artifact"];
const orderedKeys = [
  ...preferredOrder.filter((key) => key in workflowsMap || key in ((pipelineSlo.workflows || {}) as Record<string, SloWorkflow>)),
  ...Object.keys(workflowsMap).filter((key) => !preferredOrder.includes(key)),
];
const workflowRows: WorkflowRow[] = [
  ...orderedKeys
    .map((key) => workflowsMap[key])
    .filter((row): row is WorkflowRow => Boolean(row)),
];

const historyRows = Array.isArray(pipelineStatus.history) ? (pipelineStatus.history as WorkflowRow[]).slice(0, 12) : [];
const sloWorkflows = (pipelineSlo.workflows || {}) as Record<string, SloWorkflow>;
const weeklyReport = (pipelineSlo.weekly_report || {}) as Record<string, any>;
const weeklyLines = Array.isArray(weeklyReport.summary_lines) ? weeklyReport.summary_lines : [];
const failureRecommendations = (pipelineSlo.failure_recommendations || {}) as Record<string, any>;
const globalTopFailures = Array.isArray(failureRecommendations.global_top_failures)
  ? (failureRecommendations.global_top_failures as FailureRecommendation[])
  : [];
const workflowTopFailures = Array.isArray(failureRecommendations.workflows_28d)
  ? (failureRecommendations.workflows_28d as FailureRecommendation[])
  : [];

const sloRows: Array<{
  workflowName: string;
  w7: SloWindow;
  w28: SloWindow;
  streak: number;
  lastSuccess: string;
  lastFailure: string;
}> = orderedKeys.map((key) => {
  const row = sloWorkflows[key] || {};
  const windows = (row.windows || {}) as Record<string, SloWindow>;
  return {
    workflowName: row.workflow_name || key,
    w7: windows["7"] || {},
    w28: windows["28"] || {},
    streak: Number(row.current_success_streak || 0),
    lastSuccess: String(row.last_success_at || ""),
    lastFailure: String(row.last_failure_at || ""),
  };
});
---

<BaseLayout
  title="Pipeline Status | LocalVRAM"
  description="Latest Weekly, Daily Content, and Publish workflow status snapshots."
  locale="en"
>
  <main class="container">
    <h1>Pipeline Status</h1>
    <p>Latest workflow snapshots for benchmark collection, daily content, and publish pipeline.</p>

    <div class="card-grid">
      <article class="card">
        <h2>Pipeline SLO (28d)</h2>
        <p>{pipelineSlo.pipeline_slo_met ? "Met" : "Not met"}</p>
      </article>
      <article class="card">
        <h2>Target Success Rate</h2>
        <p>{pipelineSlo.target_success_rate ?? 95}%</p>
      </article>
      <article class="card">
        <h2>Reference Time</h2>
        <p>{pipelineSlo.reference_time || "-"}</p>
      </article>
      <article class="card">
        <h2>Weekly Report Window</h2>
        <p>{weeklyReport.window_start || "-"} -> {weeklyReport.window_end || "-"}</p>
      </article>
    </div>

    <div class="card-grid">
      {workflowRows.map((row) => (
        <article class="card">
          <h2>{row.workflow_name || row.workflow_key || "Workflow"}</h2>
          <p>Status: {row.status || "unknown"} / {row.conclusion || "unknown"}</p>
          <p>Updated: {row.updated_at || "unknown"}</p>
          <p>Event: {row.event || "unknown"}</p>
          <p>Failure Class: {row.failure_class || "none"}</p>
          <p>{row.failure_detail || "-"}</p>
          {row.run_url ? (
            <a class="btn" href={row.run_url} target="_blank" rel="noopener noreferrer">Open Run</a>
          ) : null}
        </article>
      ))}
    </div>

    <section class="card" style="margin-top: 16px;">
      <h2>Workflow SLO Metrics</h2>
      <table class="table">
        <thead>
          <tr>
            <th>Workflow</th>
            <th>7d Success</th>
            <th>28d Success</th>
            <th>28d Target</th>
            <th>Current Success Streak</th>
            <th>Top Failure (28d)</th>
          </tr>
        </thead>
        <tbody>
          {sloRows.map((row) => (
            <tr>
              <td>{row.workflowName}</td>
              <td>{row.w7.success_runs ?? 0}/{row.w7.total_runs ?? 0} ({row.w7.success_rate ?? 0}%)</td>
              <td>{row.w28.success_runs ?? 0}/{row.w28.total_runs ?? 0} ({row.w28.success_rate ?? 0}%)</td>
              <td>{row.w28.target_success_rate ?? pipelineSlo.target_success_rate ?? 95}% ({row.w28.slo_met ? "met" : "miss"})</td>
              <td>{row.streak}</td>
              <td>{row.w28.top_failure_class || "none"}</td>
            </tr>
          ))}
        </tbody>
      </table>
      <p>Last success/failure timestamps are available in raw data: <code>src/data/pipeline-slo.json</code>.</p>
    </section>

    <section class="card" style="margin-top: 16px;">
      <h2>Weekly Ops Summary</h2>
      {weeklyLines.length === 0 ? (
        <p>No weekly summary lines yet.</p>
      ) : (
        <ul>
          {weeklyLines.map((line) => <li>{line}</li>)}
        </ul>
      )}
    </section>

    <section class="card" style="margin-top: 16px;">
      <h2>Top Failure Classes (28d)</h2>
      <table class="table">
        <thead>
          <tr>
            <th>Failure Class</th>
            <th>Count</th>
            <th>Recommended Action</th>
          </tr>
        </thead>
        <tbody>
          {globalTopFailures.length === 0 ? (
            <tr>
              <td colSpan={3}>No failed runs in the selected window.</td>
            </tr>
          ) : (
            globalTopFailures.map((row) => (
              <tr>
                <td>{row.failure_class || "unknown_failure"}</td>
                <td>{row.count ?? 0}</td>
                <td>{row.action || "-"}</td>
              </tr>
            ))
          )}
        </tbody>
      </table>
    </section>

    <section class="card" style="margin-top: 16px;">
      <h2>Workflow Failure Actions (28d)</h2>
      <table class="table">
        <thead>
          <tr>
            <th>Workflow</th>
            <th>Failure Class</th>
            <th>Count</th>
            <th>Recommended Action</th>
          </tr>
        </thead>
        <tbody>
          {workflowTopFailures.length === 0 ? (
            <tr>
              <td colSpan={4}>No workflow-level recommendations yet.</td>
            </tr>
          ) : (
            workflowTopFailures.map((row) => (
              <tr>
                <td>{row.workflow_name || row.workflow_key || "-"}</td>
                <td>{row.failure_class || "unknown_failure"}</td>
                <td>{row.count ?? 0}</td>
                <td>{row.action || "-"}</td>
              </tr>
            ))
          )}
        </tbody>
      </table>
    </section>

    <section class="card" style="margin-top: 16px;">
      <h2>Recent Pipeline History</h2>
      <table class="table">
        <thead>
          <tr>
            <th>Workflow</th>
            <th>Status</th>
            <th>Conclusion</th>
            <th>Updated</th>
            <th>Run</th>
          </tr>
        </thead>
        <tbody>
          {historyRows.length === 0 ? (
            <tr>
              <td colSpan={5}>No history yet.</td>
            </tr>
          ) : (
            historyRows.map((row) => (
              <tr>
                <td>{row.workflow_name || row.workflow_key || "unknown"}</td>
                <td>{row.status || "unknown"}</td>
                <td>{row.conclusion || "unknown"}</td>
                <td>{row.updated_at || "unknown"}</td>
                <td>
                  {row.run_url ? (
                    <a href={row.run_url} target="_blank" rel="noopener noreferrer">#{row.run_id || "-"}</a>
                  ) : (
                    <span>-</span>
                  )}
                </td>
              </tr>
            ))
          )}
        </tbody>
      </table>
    </section>
  </main>
</BaseLayout>
