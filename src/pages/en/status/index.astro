---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import status from "../../../data/status.json";
import contentPublish from "../../../data/content-publish-log.json";
import conversionFunnel from "../../../data/conversion-funnel.json";
import pipelineStatus from "../../../data/pipeline-status.json";
import pipelineSlo from "../../../data/pipeline-slo.json";
import newModelWatchlist from "../../../data/new-model-watchlist.json";
import modelCatalog from "../../../data/model-catalog.json";
import searchConsole from "../../../data/search-console-keywords.json";
import { existsSync, readFileSync } from "node:fs";
import { join } from "node:path";

type WorkflowRow = {
  workflow_key?: string;
  workflow_name?: string;
  status?: string;
  conclusion?: string;
  updated_at?: string;
  failure_class?: string;
  failure_detail?: string;
  run_url?: string;
};

type LocaleKpiRow = {
  date: string;
  locale: string;
  indexed_urls: number;
  discovered_urls: number;
  index_rate_pct: number;
  impressions: number;
  clicks: number;
  ctr_pct: number;
  avg_position: number;
  next_action: string;
};

type SloWindow = {
  total_runs?: number;
  success_runs?: number;
  failure_runs?: number;
  success_rate?: number;
  target_success_rate?: number;
  slo_met?: boolean;
  top_failure_class?: string;
  top_failure_action?: string;
};

type SloWorkflow = {
  workflow_key?: string;
  workflow_name?: string;
  current_success_streak?: number;
  windows?: Record<string, SloWindow>;
};

type FailureRecommendation = {
  workflow_key?: string;
  workflow_name?: string;
  failure_class?: string;
  count?: number;
  action?: string;
};

function parseCsvLine(line: string): string[] {
  const cells: string[] = [];
  let current = "";
  let inQuotes = false;
  for (let index = 0; index < line.length; index += 1) {
    const char = line[index];
    if (char === '"') {
      if (inQuotes && line[index + 1] === '"') {
        current += '"';
        index += 1;
      } else {
        inQuotes = !inQuotes;
      }
      continue;
    }
    if (char === "," && !inQuotes) {
      cells.push(current);
      current = "";
      continue;
    }
    current += char;
  }
  cells.push(current);
  return cells;
}

function parseLocaleKpi(): LocaleKpiRow[] {
  const filePath = join(process.cwd(), "docs", "seo-ops", "locale-kpi-tracker.csv");
  if (!existsSync(filePath)) {
    return [];
  }
  const lines = readFileSync(filePath, "utf-8").trim().split(/\r?\n/).filter(Boolean);
  const headers = parseCsvLine(lines[0] || "");
  return lines.slice(1).map((line) => {
    const values = parseCsvLine(line);
    const row = Object.fromEntries(headers.map((header, index) => [header, values[index] || ""]));
    return {
      date: row.date || "",
      locale: row.locale || "",
      indexed_urls: Number(row.indexed_urls || 0),
      discovered_urls: Number(row.discovered_urls || 0),
      index_rate_pct: Number(row.index_rate_pct || 0),
      impressions: Number(row.impressions || 0),
      clicks: Number(row.clicks || 0),
      ctr_pct: Number(row.ctr_pct || 0),
      avg_position: Number(row.avg_position || 0),
      next_action: row.next_action || "",
    };
  });
}

function formatWindow(row: SloWindow): string {
  return `${row.success_runs ?? 0}/${row.total_runs ?? 0} (${row.success_rate ?? 0}%)`;
}

const workflows = (pipelineStatus.workflows || {}) as Record<string, WorkflowRow>;
const dailyWorkflow = workflows.daily_content || {};
const weeklyWorkflow = workflows.weekly_benchmark || {};
const publishArtifactWorkflow = workflows.publish_benchmark_artifact || {};
const sloWorkflows = (pipelineSlo.workflows || {}) as Record<string, SloWorkflow>;
const weeklyReport = (pipelineSlo.weekly_report || {}) as Record<string, any>;
const weeklyLines = Array.isArray(weeklyReport.summary_lines) ? weeklyReport.summary_lines : [];
const failureRecommendations = (pipelineSlo.failure_recommendations || {}) as Record<string, any>;
const topFailureRows = Array.isArray(failureRecommendations.global_top_failures)
  ? (failureRecommendations.global_top_failures as FailureRecommendation[])
  : [];
const lastRun = (contentPublish.last_run || {}) as Record<string, any>;
const lastPublished = Array.isArray(lastRun.published) ? lastRun.published[0] : null;
const funnel = (conversionFunnel.funnel || {}) as Record<string, any>;
const dataQuality = (conversionFunnel.data_quality || {}) as Record<string, any>;
const watchlistItems = Array.isArray(newModelWatchlist.items) ? newModelWatchlist.items : [];
const publishCount = Number(lastRun.published_count || 0);
const affiliateEventsInWindow = Number(dataQuality.affiliate_event_items_in_window || 0);
const affiliateFeedTotal = Number(dataQuality.affiliate_event_items_total || 0);
const affiliateStatus = affiliateEventsInWindow > 0
  ? "Live events in window"
  : affiliateFeedTotal > 0
    ? "Feed healthy; no recent redirects"
    : "No event feed";
const pipelineHealth = pipelineSlo.pipeline_slo_met ? "SLO met" : "SLO miss";
const dailyHealth = dailyWorkflow.conclusion === "success" ? "Healthy" : "Needs attention";
const benchmarkHealth = weeklyWorkflow.conclusion === "success" ? "Healthy" : "Needs attention";
const catalogVerifiedAt = String(modelCatalog.ollama_verified_at || modelCatalog.generated_at || "unknown");
const localeKpiRows = parseLocaleKpi();
const latestLocaleKpiDate = localeKpiRows[0]?.date || "unknown";
const topLocaleRows = [...localeKpiRows].sort((a, b) => b.impressions - a.impressions).slice(0, 5);
const lowestIndexRows = [...localeKpiRows].sort((a, b) => a.index_rate_pct - b.index_rate_pct).slice(0, 5);
const searchItems = Array.isArray(searchConsole.items) ? searchConsole.items : [];
const topSearchRows = [...searchItems]
  .sort((a: any, b: any) => Number(b.impressions || 0) - Number(a.impressions || 0))
  .slice(0, 6);
const searchConsoleWindow = (searchConsole.window || {}) as Record<string, any>;
const searchConsoleSummary = `${searchItems.length} rows; ${searchConsoleWindow.start_date || "unknown"} to ${searchConsoleWindow.end_date || "unknown"}`;
const topFailure = topFailureRows[0] || {};
const pipelineHealthDetail = topFailure.failure_class
  ? `${topFailure.failure_class}: ${topFailure.count ?? 0} run(s) in 28d.`
  : "No failed runs in the selected window.";
const workflowSloRows = ["daily_content", "weekly_benchmark", "publish_benchmark_artifact"].map((key) => {
  const row = sloWorkflows[key] || {};
  const windows = (row.windows || {}) as Record<string, SloWindow>;
  return {
    workflowName: row.workflow_name || workflows[key]?.workflow_name || key,
    w7: windows["7"] || {},
    w28: windows["28"] || {},
    streak: Number(row.current_success_streak || 0),
  };
});

const statusCards = [
  {
    label: "Daily content",
    value: dailyHealth,
    detail: `Last publish ${contentPublish.updated_at || "unknown"}; published ${publishCount} post(s).`,
    href: "/en/status/content-publish/",
  },
  {
    label: "Benchmark data",
    value: benchmarkHealth,
    detail: `Last hardware sync ${status.last_hardware_sync || "unknown"}.`,
    href: "/en/status/data-freshness/",
  },
  {
    label: "Pipeline SLO",
    value: pipelineHealth,
    detail: `${pipelineHealthDetail} Reference ${pipelineSlo.reference_time || pipelineStatus.updated_at || "unknown"}.`,
    href: "/en/status/pipeline-status/",
  },
  {
    label: "Affiliate events",
    value: affiliateStatus,
    detail: `${affiliateEventsInWindow} redirect event(s) in the ${conversionFunnel.window_days || 30}d window; ${affiliateFeedTotal} total captured.`,
    href: "/en/status/conversion-funnel/",
  },
  {
    label: "Model catalog",
    value: `${modelCatalog.count || 0} models`,
    detail: `Ollama catalog verified ${catalogVerifiedAt}.`,
    href: "/en/models/",
  },
  {
    label: "New model radar",
    value: `${watchlistItems.length} item(s)`,
    detail: `Updated ${newModelWatchlist.updated_at || "unknown"}.`,
    href: "/en/status/new-model-radar/",
  },
  {
    label: "Search Console",
    value: searchConsole.source || "unknown",
    detail: `Updated ${searchConsole.updated_at || "unknown"}; ${searchConsoleSummary}.`,
    href: "#search-console",
  },
];

const workflowRows = [
  ["Daily Content", dailyWorkflow],
  ["Weekly Benchmark", weeklyWorkflow],
  ["Publish Benchmark Artifact", publishArtifactWorkflow],
] as Array<[string, WorkflowRow]>;
---

<BaseLayout
  title="Operations Health | LocalVRAM"
  description="A single-page health overview for LocalVRAM content, benchmark, model, and affiliate data pipelines."
  locale="en"
  canonicalPath="/en/status/"
>
  <main class="container">
    <section class="hero">
      <h1>Operations Health</h1>
      <p>Current health for LocalVRAM publishing, benchmark freshness, model inventory, and conversion telemetry.</p>
      <div class="cta-row">
        <a class="btn btn-primary" href="/en/status/pipeline-status/">Pipeline Status</a>
        <a class="btn" href="/en/status/data-freshness/">Data Freshness</a>
        <a class="btn" href="/en/status/conversion-funnel/">Conversion Funnel</a>
      </div>
    </section>

    <div class="card-grid">
      {statusCards.map((card) => (
        <article class="card">
          <h2>{card.label}</h2>
          <p><strong>{card.value}</strong></p>
          <p>{card.detail}</p>
          <a class="btn" href={card.href}>Open</a>
        </article>
      ))}
    </div>

    <section class="card" style="margin-top: 16px;">
      <h2>Latest Publication</h2>
      {lastPublished ? (
        <>
          <p>{lastPublished.title || lastPublished.slug}</p>
          <p>Queue date: {lastRun.queue_date || "unknown"} | Source: {lastPublished.source_draft || "unknown"}</p>
          <a class="btn" href={`/en/blog/${lastPublished.slug}/`}>Open Post</a>
        </>
      ) : (
        <p>No published post recorded in the latest run.</p>
      )}
    </section>

    <section class="card" style="margin-top: 16px;">
      <h2>Workflow Snapshot</h2>
      <table class="table">
        <thead>
          <tr>
            <th>Workflow</th>
            <th>Conclusion</th>
            <th>Updated</th>
            <th>Failure Class</th>
            <th>Run</th>
          </tr>
        </thead>
        <tbody>
          {workflowRows.map(([label, row]) => (
            <tr>
              <td>{row.workflow_name || label}</td>
              <td>{row.conclusion || "unknown"}</td>
              <td>{row.updated_at || "unknown"}</td>
              <td>{row.failure_class || "none"}</td>
              <td>
                {row.run_url ? (
                  <a href={row.run_url} target="_blank" rel="noopener noreferrer">Open</a>
                ) : (
                  "-"
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    <section class="card" style="margin-top: 16px;">
      <h2>Pipeline SLO Summary</h2>
      <p>Overall: {pipelineSlo.pipeline_slo_met ? "Met" : "Not met"} | Target: {pipelineSlo.target_success_rate ?? 95}% | Window: {weeklyReport.window_start || "unknown"} to {weeklyReport.window_end || "unknown"}</p>
      <table class="table">
        <thead>
          <tr>
            <th>Workflow</th>
            <th>7d Success</th>
            <th>28d Success</th>
            <th>Current Streak</th>
            <th>Top Failure</th>
          </tr>
        </thead>
        <tbody>
          {workflowSloRows.map((row) => (
            <tr>
              <td>{row.workflowName}</td>
              <td>{formatWindow(row.w7)}</td>
              <td>{formatWindow(row.w28)}</td>
              <td>{row.streak}</td>
              <td>{row.w28.top_failure_class || "none"}</td>
            </tr>
          ))}
        </tbody>
      </table>
      {topFailureRows.length > 0 ? (
        <p>Recommended action: {topFailureRows[0].action || "Review the latest failed workflow run."}</p>
      ) : (
        <p>No workflow-level remediation is needed in the current SLO window.</p>
      )}
      {weeklyLines.length > 0 ? (
        <ul>
          {weeklyLines.map((line) => <li>{line}</li>)}
        </ul>
      ) : null}
    </section>

    <section class="card" style="margin-top: 16px;">
      <h2>Conversion Telemetry</h2>
      <p>Organic clicks: {funnel.organic_search_clicks || 0} | Decision clicks: {funnel.decision_page_clicks || 0} | Redirect events: {funnel.affiliate_redirect_clicks || 0}</p>
      <p>Affiliate event feed total: {dataQuality.affiliate_event_items_total || 0}; in current window: {dataQuality.affiliate_event_items_in_window || 0}.</p>
    </section>

    <section id="search-console" class="card" style="margin-top: 16px;">
      <h2>Search Console Snapshot</h2>
      <p>Source: {searchConsole.source || "unknown"} | Updated: {searchConsole.updated_at || "unknown"} | Window: {searchConsoleWindow.start_date || "unknown"} to {searchConsoleWindow.end_date || "unknown"}</p>
      <table class="table">
        <thead>
          <tr>
            <th>Locale</th>
            <th>Query</th>
            <th>Landing</th>
            <th>Impressions</th>
            <th>Clicks</th>
            <th>Avg. Position</th>
          </tr>
        </thead>
        <tbody>
          {topSearchRows.map((row: any) => (
            <tr>
              <td>{row.locale || "-"}</td>
              <td>{row.query || row.keyword || "-"}</td>
              <td>{row.landing || "-"}</td>
              <td>{row.impressions || 0}</td>
              <td>{row.clicks || 0}</td>
              <td>{row.position || 0}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    <section class="card" style="margin-top: 16px;">
      <h2>Locale KPI</h2>
      <p>Latest checkpoint: {latestLocaleKpiDate}. Top locales by impressions are listed first; low index-rate locales show where inspection work is most urgent.</p>
      <table class="table">
        <thead>
          <tr>
            <th>Locale</th>
            <th>Indexed / Discovered</th>
            <th>Index Rate</th>
            <th>Impressions</th>
            <th>Clicks</th>
            <th>Next Action</th>
          </tr>
        </thead>
        <tbody>
          {topLocaleRows.map((row) => (
            <tr>
              <td>{row.locale}</td>
              <td>{row.indexed_urls} / {row.discovered_urls}</td>
              <td>{row.index_rate_pct}%</td>
              <td>{row.impressions}</td>
              <td>{row.clicks}</td>
              <td>{row.next_action}</td>
            </tr>
          ))}
        </tbody>
      </table>
      <h3>Lowest Index Rate</h3>
      <table class="table">
        <thead>
          <tr>
            <th>Locale</th>
            <th>Index Rate</th>
            <th>Indexed</th>
            <th>Discovered</th>
            <th>Avg. Position</th>
          </tr>
        </thead>
        <tbody>
          {lowestIndexRows.map((row) => (
            <tr>
              <td>{row.locale}</td>
              <td>{row.index_rate_pct}%</td>
              <td>{row.indexed_urls}</td>
              <td>{row.discovered_urls}</td>
              <td>{row.avg_position}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>
  </main>
</BaseLayout>
