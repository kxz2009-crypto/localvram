---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import catalog from "../../../data/model-catalog.json";
import links from "../../../data/affiliate-links.json";
import benchmarkResults from "../../../data/benchmark-results.json";
import { ROOT_ALTERNATES } from "../../../data/root-alternates";

export function getStaticPaths() {
  return catalog.items.map((item) => ({
    params: { id: item.id },
    props: { item }
  }));
}

const { item } = Astro.props;
const isCloudFirst = item.vram_optimal_gb > 24;
const monthlyCloud40h = Math.round(item.cloud_hourly_usd * 40 * 100) / 100;
const monthlyCloud120h = Math.round(item.cloud_hourly_usd * 120 * 100) / 100;
const benchmarkMap = benchmarkResults.models || {};
const realBenchmark = item.ollama_tag ? benchmarkMap[item.ollama_tag] : null;
const hasRealBenchmark =
  realBenchmark &&
  realBenchmark.status === "ok" &&
  typeof realBenchmark.tokens_per_second === "number";
const localMeasuredTokS = hasRealBenchmark ? realBenchmark.tokens_per_second : item.benchmarks.rtx3090_tok_s;
const cloudSpeedFactor =
  localMeasuredTokS > 0 ? Math.round((item.benchmarks.a100_tok_s / localMeasuredTokS) * 10) / 10 : 0;
const amazon3090PriceLabel = (import.meta.env.PUBLIC_AMAZON_PRICE_3090 || "Check latest deal").trim();
const runpodA100PriceLabel = (import.meta.env.PUBLIC_RUNPOD_A100_PRICE || "").trim();
const chartPayload = {
  labels: ["RTX 3090", "RTX 4090", "A100 80GB"],
  baseline: [item.benchmarks.rtx3090_tok_s, item.benchmarks.rtx4090_tok_s, item.benchmarks.a100_tok_s],
  measured3090: hasRealBenchmark ? realBenchmark.tokens_per_second : null,
  hasMeasured: hasRealBenchmark,
  modelName: item.name,
};
const relatedProfiles = catalog.items
  .filter((candidate) => candidate.id !== item.id && candidate.ollama_tag === item.ollama_tag)
  .sort((a, b) => {
    const priority: Record<string, number> = { Q4: 0, Q5: 1, Q8: 2, FP16: 3, CLOUD: 4 };
    return (
      (priority[String(a.quantization || "").toUpperCase()] ?? 9) -
      (priority[String(b.quantization || "").toUpperCase()] ?? 9)
    );
  })
  .slice(0, 4);
const modelPath = `/en/models/${item.id}/`;
const modelUrl = `https://localvram.com${modelPath}`;
const seoTitle =
  typeof item.seo_title === "string" && item.seo_title.trim()
    ? item.seo_title.trim()
    : `${item.name} on LocalVRAM`;
const seoDescription = `${item.name}: ${item.vram_min_gb}GB minimum VRAM, ${item.vram_optimal_gb}GB optimal. RTX 3090 ${
  hasRealBenchmark ? `${realBenchmark.tokens_per_second} tok/s measured` : `${item.benchmarks.rtx3090_tok_s} tok/s baseline`
}, RTX 4090 ${item.benchmarks.rtx4090_tok_s} tok/s, cloud ${item.benchmarks.a100_tok_s} tok/s.`;
const paramsB = Number(item.params_b || 0);
const systemRamTargetGb =
  item.vram_optimal_gb <= 12 ? 16 : item.vram_optimal_gb <= 24 ? 32 : item.vram_optimal_gb <= 48 ? 64 : 128;
const canRunOnRtx3090 = item.vram_min_gb <= 24;
const comfortableOnRtx3090 = item.vram_optimal_gb <= 24;
const localFitAnswer = comfortableOnRtx3090
  ? `Yes. ${item.name} fits comfortably on an RTX 3090 24GB target with ${item.vram_optimal_gb}GB optimal VRAM.`
  : canRunOnRtx3090
    ? `It may load on an RTX 3090 24GB because the minimum estimate is ${item.vram_min_gb}GB, but the safer target is ${item.vram_optimal_gb}GB. Expect tighter context or lower throughput.`
    : `Not as a comfortable local target. ${item.name} needs about ${item.vram_min_gb}GB minimum and ${item.vram_optimal_gb}GB optimal VRAM, so cloud or larger local GPUs are safer.`;
const dataStatusAnswer = hasRealBenchmark
  ? `${item.name} has a verified RTX 3090 result of ${realBenchmark.tokens_per_second} tokens/s from LocalVRAM benchmark data.`
  : `${item.name} currently uses estimated baseline anchors on this page. Verified benchmark data will replace the estimate after a local hardware run is available.`;
const faqItems = [
  {
    question: `How much VRAM does ${item.name} need?`,
    answer: `${item.name} needs about ${item.vram_min_gb}GB minimum VRAM and ${item.vram_optimal_gb}GB optimal VRAM for a safer local run target.`,
  },
  {
    question: `Can ${item.name} run on an RTX 3090 24GB?`,
    answer: localFitAnswer,
  },
  {
    question: `What is the Ollama command for ${item.name}?`,
    answer: item.ollama_command
      ? `Use ${item.ollama_command}. Check the Ollama tag ${item.ollama_tag || "listed on this page"} before running.`
      : `Use the Ollama tag ${item.ollama_tag || "listed on this page"} with your local Ollama installation.`,
  },
  {
    question: `What is the approximate Ollama model size for ${item.name}?`,
    answer: `${item.name} uses the ${item.ollama_tag || "listed"} Ollama tag. Treat the ${item.quantization} ${paramsB || item.size_class} profile as smaller than the runtime VRAM budget; use ${item.vram_min_gb}GB minimum VRAM and ${item.vram_optimal_gb}GB optimal VRAM as the safer sizing numbers.`,
  },
  {
    question: `How much system RAM does ${item.name} need in Ollama?`,
    answer: `Plan for at least ${systemRamTargetGb}GB system RAM alongside ${item.vram_min_gb}GB minimum VRAM and ${item.vram_optimal_gb}GB optimal VRAM. More RAM helps if layers spill to CPU or if you run multiple models.`,
  },
  {
    question: `Is ${item.name} benchmark data measured or estimated?`,
    answer: dataStatusAnswer,
  },
];
const modelSchema = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  headline: `${item.name} VRAM Requirement and Benchmark`,
  dateModified: item.updated_at,
  inLanguage: "en",
  url: modelUrl,
  mainEntityOfPage: modelUrl,
  author: {
    "@type": "Organization",
    name: "LocalVRAM"
  },
  about: {
    "@type": "SoftwareApplication",
    name: item.name,
    applicationCategory: "DeveloperApplication",
    operatingSystem: "Linux, Windows, macOS",
    softwareRequirements: `${item.vram_min_gb}GB minimum VRAM; ${item.vram_optimal_gb}GB optimal VRAM`,
  }
};
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((entry) => ({
    "@type": "Question",
    name: entry.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: entry.answer,
    },
  })),
};
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: "https://localvram.com/en/"
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Models",
      item: "https://localvram.com/en/models/"
    },
    {
      "@type": "ListItem",
      position: 3,
      name: item.name,
      item: modelUrl
    }
  ]
};
const relatedProfilesSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: `${item.name} related LocalVRAM model profiles`,
  itemListElement: relatedProfiles.map((profile, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: profile.name,
    url: `https://localvram.com/en/models/${profile.id}/`
  }))
};
const structuredData = relatedProfiles.length
  ? [modelSchema, faqSchema, breadcrumbSchema, relatedProfilesSchema]
  : [modelSchema, faqSchema, breadcrumbSchema];
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  locale="en"
  canonicalPath={modelPath}
  alternates={ROOT_ALTERNATES}
  ogType="article"
  modifiedTime={item.updated_at}
  structuredData={structuredData}
>
  <main class="container">
    <h1>{item.name}</h1>
    <p>{item.focus}. Caveat: {item.caveat}.</p>

    <section class="card">
      <h2>Hardware Snapshot</h2>
      <table class="table">
        <tbody>
          <tr>
            <th>Family</th>
            <td>{item.family}</td>
          </tr>
          <tr>
            <th>Scenario</th>
            <td>{item.scenario}</td>
          </tr>
          <tr>
            <th>License scope</th>
            <td>{item.license_scope}</td>
          </tr>
          <tr>
            <th>Quantization</th>
            <td>{item.quantization}</td>
          </tr>
          <tr>
            <th>VRAM minimum</th>
            <td>{item.vram_min_gb}GB</td>
          </tr>
          <tr>
            <th>VRAM optimal</th>
            <td>{item.vram_optimal_gb}GB</td>
          </tr>
          <tr>
            <th>Best local GPU</th>
            <td>{item.best_local_gpu}</td>
          </tr>
          <tr>
            <th>Cloud fallback</th>
            <td>{item.cloud_fallback}</td>
          </tr>
          <tr>
            <th>Updated</th>
            <td>{item.updated_at}</td>
          </tr>
          <tr>
            <th>Data status</th>
            <td>{hasRealBenchmark ? "Verified by Real Hardware" : "Estimated baseline (pending measurement)"}</td>
          </tr>
          <tr>
            <th>Ollama source</th>
            <td><a class="btn" href={item.ollama_source_url}>Library reference</a> (verified: {item.ollama_verified_at})</td>
          </tr>
          {item.ollama_tag && (
            <tr>
              <th>Ollama tag</th>
              <td><code>{item.ollama_tag}</code></td>
            </tr>
          )}
          {item.popularity && (
            <tr>
              <th>Popularity</th>
              <td>{item.popularity}</td>
            </tr>
          )}
          {item.category_label && (
            <tr>
              <th>Category</th>
              <td>{item.category_label}</td>
            </tr>
          )}
        </tbody>
      </table>
    </section>

    <section class="card">
      <h2>Benchmark Anchors</h2>
      <table class="table">
        <thead>
          <tr>
            <th>Hardware</th>
            <th>Expected tok/s</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>RTX 3090 24GB</td>
            <td>{item.benchmarks.rtx3090_tok_s}</td>
          </tr>
          <tr>
            <td>RTX 4090 24GB</td>
            <td>{item.benchmarks.rtx4090_tok_s}</td>
          </tr>
          <tr>
            <td>A100 80GB</td>
            <td>{item.benchmarks.a100_tok_s}</td>
          </tr>
        </tbody>
      </table>
    </section>

    <section class="card">
      <h2>Quick Answers</h2>
      <dl>
        {faqItems.map((entry) => (
          <div>
            <dt>{entry.question}</dt>
            <dd>{entry.answer}</dd>
          </div>
        ))}
      </dl>
    </section>

    <section class="card">
      <h2>Ollama Model Size and RAM Notes</h2>
      <table class="table">
        <tbody>
          <tr>
            <th>Ollama tag</th>
            <td><code>{item.ollama_tag || "not listed"}</code></td>
          </tr>
          <tr>
            <th>Run command</th>
            <td>
              {item.ollama_command ? (
                <code>{item.ollama_command}</code>
              ) : (
                "Use the listed Ollama tag with ollama run."
              )}
            </td>
          </tr>
          <tr>
            <th>Model size guidance</th>
            <td>{item.quantization} quantization, {paramsB || item.size_class} profile; size runtime by VRAM, not download size alone</td>
          </tr>
          <tr>
            <th>Runtime VRAM target</th>
            <td>{item.vram_min_gb}GB minimum, {item.vram_optimal_gb}GB optimal</td>
          </tr>
          <tr>
            <th>System RAM planning</th>
            <td>{systemRamTargetGb}GB or more when running this tag locally with Ollama</td>
          </tr>
        </tbody>
      </table>
      <p class="affiliate-note">
        Download size alone is not a safe runtime budget. Runtime memory also includes KV cache, context length, and GPU layer placement.
      </p>
    </section>

    <section class="card">
      <h2>Real Hardware Benchmark (RTX 3090)</h2>
      {hasRealBenchmark ? (
        <>
          <table class="table">
            <tbody>
              <tr>
                <th>Tokens/s</th>
                <td>{realBenchmark.tokens_per_second}</td>
              </tr>
              <tr>
                <th>Latency</th>
                <td>{realBenchmark.latency_ms} ms</td>
              </tr>
              <tr>
                <th>Prompt tokens</th>
                <td>{realBenchmark.prompt_tokens}</td>
              </tr>
              <tr>
                <th>Eval tokens</th>
                <td>{realBenchmark.eval_tokens}</td>
              </tr>
              <tr>
                <th>Test time</th>
                <td>{realBenchmark.test_time}</td>
              </tr>
              <tr>
                <th>GPU model</th>
                <td>{realBenchmark.gpu_model}</td>
              </tr>
            </tbody>
          </table>
          <p style="color: #19a55a; font-weight: 700;">
            <span title={realBenchmark.verified_tooltip || "Tested on local RTX 3090, 450W TDP, Ambient 25C"}>
              Verified by real hardware.
            </span>
          </p>
          {realBenchmark.gpu_snapshot && (
            <p><a class="btn" href={realBenchmark.gpu_snapshot}>View raw nvidia-smi snapshot</a></p>
          )}
        </>
      ) : (
        <p>Real benchmark data not available yet for this tag. Estimated anchors are shown above.</p>
      )}
    </section>

    <section class="card">
      <h2>Performance Curve</h2>
      <div class="chart-wrap">
        <canvas id="benchmark-chart" aria-label="Benchmark tokens per second comparison"></canvas>
      </div>
      <p class="affiliate-note">
        Reference anchors are baseline estimates. Measured RTX 3090 data is overlaid when available.
      </p>
    </section>

    <section class="card">
      <h2>Best Hardware for {item.name}</h2>
      <ul>
        <li>
          Local run:
          <a href={links.amazon_3090}> RTX 3090 (24GB)</a>
          ({amazon3090PriceLabel}) for around {localMeasuredTokS} tok/s on this profile.
        </li>
        <li>
          Cloud run:
          <a href={links.runpod}> RunPod {item.cloud_fallback}</a>
          {runpodA100PriceLabel ? ` (${runpodA100PriceLabel})` : ""}
          {cloudSpeedFactor > 0 ? `, about ${cloudSpeedFactor}x the local 3090 speed anchor.` : "."}
        </li>
        <li>
          Alternative cloud:
          <a href={links.vast}> Vast.ai options</a> for flexible spot pricing.
        </li>
      </ul>
    </section>

    <section class="card">
      <h2>Local vs Cloud Cost Hint</h2>
      <table class="table">
        <thead>
          <tr>
            <th>Mode</th>
            <th>40h / month</th>
            <th>120h / month</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Local power only (3090 baseline)</td>
            <td>${Math.round((item.local_monthly_power_usd / 3) * 100) / 100}</td>
            <td>${item.local_monthly_power_usd}</td>
          </tr>
          <tr>
            <td>{item.cloud_fallback}</td>
            <td>${monthlyCloud40h}</td>
            <td>${monthlyCloud120h}</td>
          </tr>
        </tbody>
      </table>
    </section>

    {relatedProfiles.length > 0 && (
      <section class="card">
        <h2>Related Model Profiles</h2>
        <ul>
          {relatedProfiles.map((profile) => (
            <li>
              <a href={`/en/models/${profile.id}/`}>{profile.name}</a>
              {" "}
              <span class="affiliate-note">
                {profile.vram_min_gb}GB min, {profile.vram_optimal_gb}GB optimal
              </span>
            </li>
          ))}
        </ul>
      </section>
    )}

    <section class="cta-row">
      {item.ollama_command && <span class="btn"><code>{item.ollama_command}</code></span>}
      <a class="btn" href={`/en/models/group/${item.scenario}/`}>More {item.scenario} models</a>
      <a class="btn" href={`/en/models/group/${item.size_class}/`}>More {item.size_class} models</a>
      <a class="btn" href="/en/benchmarks/changelog/">Benchmark changelog</a>
      <a class="btn" href="/en/benchmarks/submit-result/">Submit your test result</a>
      {isCloudFirst ? (
        <>
          <a class="btn btn-primary" href={links.runpod}>Run on RunPod</a>
          <a class="btn btn-primary" href={links.vast}>Try Vast.ai</a>
        </>
      ) : (
        <a class="btn btn-primary" href="/en/affiliate/hardware-upgrade/">Check local GPU upgrade</a>
      )}
    </section>

    <p class="affiliate-note">We may earn a commission if you click links on this page.</p>
    {!hasRealBenchmark && item.data_status !== "measured" && (
      <p class="affiliate-note">This page currently uses estimated benchmark baselines. Measured data will replace it after validation.</p>
    )}
  </main>
  <script is:inline src="/js/performance-chart.js?v=20260625"></script>
  <script define:vars={{ chartPayload }}>
    const mountChart = () => {
      const canvas = document.getElementById("benchmark-chart");
      if (!canvas || !window.LocalVRAMCharts) {
        window.addEventListener("localvram:charts-ready", mountChart, { once: true });
        return;
      }
      const datasets = [
        {
          label: `${chartPayload.modelName} baseline`,
          data: chartPayload.baseline,
          borderColor: "#3b82f6",
          backgroundColor: "rgba(59,130,246,0.15)",
          borderWidth: 2,
        },
      ];
      if (chartPayload.hasMeasured && chartPayload.measured3090 !== null) {
        datasets.push({
          label: "Measured RTX 3090",
          data: [chartPayload.measured3090, null, null],
          borderColor: "#10b981",
          backgroundColor: "rgba(16,185,129,0.2)",
          pointRadius: 5,
          borderWidth: 2,
        });
      }
      window.LocalVRAMCharts.renderLineChart(canvas, {
        labels: chartPayload.labels,
        datasets,
        yAxisLabel: "tokens/s",
      });
    };

    if (document.readyState === "complete") {
      mountChart();
    } else {
      window.addEventListener("load", mountChart, { once: true });
    }
  </script>
</BaseLayout>
