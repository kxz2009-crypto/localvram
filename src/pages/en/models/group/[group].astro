---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import catalog from "../../../../data/model-catalog.json";
import links from "../../../../data/affiliate-links.json";

export function getStaticPaths() {
  return catalog.group_definitions.map((group) => ({
    params: { group: group.id },
    props: { group }
  }));
}

const { group } = Astro.props;
const items = catalog.items
  .filter((item) => item.license_scope === group.id || item.size_class === group.id || item.scenario === group.id)
  .sort((a, b) => b.params_b - a.params_b || a.name.localeCompare(b.name));
const pagePath = `/en/models/group/${group.id}/`;
const pageTitle = `${group.label} | LocalVRAM`;
const pageDescription = `${group.label}: RAM and VRAM requirements, benchmark anchors, RTX 3090 fit, and local/cloud path.`;
const systemRamTarget = (optimalVram: number) =>
  optimalVram <= 12 ? 16 : optimalVram <= 24 ? 32 : optimalVram <= 48 ? 64 : 128;
const rtx3090Fit = (minVram: number, optimalVram: number) =>
  optimalVram <= 24 ? "Comfortable" : minVram <= 24 ? "Borderline" : "Cloud / larger GPU";
const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: group.label,
  description: pageDescription,
  url: `https://localvram.com${pagePath}`,
  inLanguage: "en",
  mainEntity: {
    "@type": "ItemList",
    numberOfItems: items.length,
    itemListElement: items.slice(0, 100).map((item, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: item.name,
      url: `https://localvram.com/en/models/${item.id}/`,
    })),
  },
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  locale="en"
  canonicalPath={pagePath}
  structuredData={structuredData}
>
  <main class="container">
    <h1>{group.label}</h1>
    <p>
      {items.length} profiles in this group. Use this hub page to compare practical VRAM floor, expected throughput,
      and best local-vs-cloud path.
    </p>
    <p>
      RAM planning is included because Ollama may spill layers to CPU when VRAM is tight, especially with long context.
    </p>

    <section class="card">
      <table class="table">
        <thead>
          <tr>
            <th>Model</th>
            <th>Data</th>
            <th>VRAM min</th>
            <th>VRAM optimal</th>
            <th>System RAM</th>
            <th>RTX 3090 fit</th>
            <th>Best local GPU</th>
            <th>Cloud fallback</th>
            <th>Detail</th>
          </tr>
        </thead>
        <tbody>
          {items.map((item) => (
            <tr>
              <td>{item.name}</td>
              <td>{item.data_status === "measured" ? "Measured" : "Estimated"}</td>
              <td>{item.vram_min_gb}GB</td>
              <td>{item.vram_optimal_gb}GB</td>
              <td>{systemRamTarget(item.vram_optimal_gb)}GB+</td>
              <td>{rtx3090Fit(item.vram_min_gb, item.vram_optimal_gb)}</td>
              <td>{item.best_local_gpu}</td>
              <td>{item.cloud_fallback}</td>
              <td>
                <a class="btn" href={`/en/models/${item.id}/`}>Open</a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    <section class="cta-row">
      <a class="btn" href="/en/models/">Back to all groups</a>
      <a class="btn" href="/en/tools/vram-calculator/">Use VRAM calculator</a>
      <a class="btn btn-primary" href={links.runpod}>Run large models on RunPod</a>
      <a class="btn btn-primary" href={links.vast}>Try Vast.ai fallback</a>
    </section>

    <p class="affiliate-note">We may earn a commission if you click links on this page.</p>
  </main>
</BaseLayout>
