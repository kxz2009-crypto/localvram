---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import catalog from "../../../data/model-catalog.json";

const pagePath = "/en/matrix/";
const allItems = Array.isArray(catalog.items) ? catalog.items : [];
const tiers = [8, 12, 16, 24, 48];
const scenarios = [
  { id: "chat", label: "Chat" },
  { id: "coding", label: "Coding" },
  { id: "multimodal", label: "Multimodal" },
  { id: "reasoning", label: "Reasoning" },
  { id: "embedding", label: "Embedding" }
];

function compatibleCount(scenarioId, vramTier) {
  return allItems.filter((item) => item.scenario === scenarioId && item.vram_min_gb <= vramTier).length;
}

const faqItems = [
  {
    question: "What does a compatible model count mean?",
    answer:
      "A compatible count means the catalog profile has a minimum VRAM requirement at or below that tier. It is a planning filter, not a guarantee of quality, latency, or context length."
  },
  {
    question: "Which VRAM tier should I start with?",
    answer:
      "Start with your physical GPU VRAM ceiling, then open model pages to compare quantization, measured status, and workload fit before choosing a runtime."
  },
  {
    question: "Why do some workloads have fewer compatible models?",
    answer:
      "Coding, reasoning, multimodal, and embedding workloads can have different model families and memory profiles, so the compatible count changes by scenario."
  }
];
const matrixSchema = {
  "@context": "https://schema.org",
  "@type": "Dataset",
  name: "LocalVRAM Compatibility Matrix",
  description: "Compatibility matrix by workload scenario and VRAM tier.",
  inLanguage: "en",
  url: `https://localvram.com${pagePath}`
};
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: "https://localvram.com/en/"
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Compatibility Matrix",
      item: `https://localvram.com${pagePath}`
    }
  ]
};
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer
    }
  }))
};
---

<BaseLayout
  title="Compatibility Matrix | LocalVRAM"
  description="Compatibility matrix of local LLM workloads by scenario and VRAM tier."
  locale="en"
  canonicalPath={pagePath}
  structuredData={[matrixSchema, breadcrumbSchema, faqSchema]}
>
  <main class="container">
    <h1>Compatibility Matrix</h1>
    <p>
      This matrix shows how many catalog profiles can run at each VRAM tier, split by workload scenario. Use it as a
      planning shortcut before checking individual model pages.
    </p>

    <section class="card">
      <table class="table">
        <thead>
          <tr>
            <th>Scenario</th>
            {tiers.map((tier) => <th>{tier}GB tier</th>)}
          </tr>
        </thead>
        <tbody>
          {scenarios.map((scenario) => (
            <tr>
              <td>{scenario.label}</td>
              {tiers.map((tier) => <td>{compatibleCount(scenario.id, tier)}</td>)}
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    <section class="card">
      <h2>How to use this matrix</h2>
      <ol>
        <li>Pick your actual VRAM ceiling first.</li>
        <li>Find the scenario row that matches your workload.</li>
        <li>Open model pages from that subset and compare measured signals.</li>
      </ol>
    </section>

    <section class="card">
      <h2>Compatibility FAQ</h2>
      <dl class="faq-list">
        {faqItems.map((item) => (
          <>
            <dt>{item.question}</dt>
            <dd>{item.answer}</dd>
          </>
        ))}
      </dl>
    </section>

    <section class="cta-row">
      <a class="btn btn-primary" href="/en/models/">Open model catalog</a>
      <a class="btn" href="/en/tools/vram-calculator/">Estimate with calculator</a>
      <a class="btn" href="/en/hardware/">Open hardware tiers</a>
    </section>
  </main>
</BaseLayout>
