---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import catalog from "../../../data/model-catalog.json";
import links from "../../../data/affiliate-links.json";
import benchmarkResults from "../../../data/benchmark-results.json";

const allModels = Array.isArray(catalog.items) ? catalog.items : [];
const benchmarkMap = benchmarkResults.models || {};
const priorityTag = "qwen3.5:35b";
const sampleModels = [...allModels].sort((a, b) => {
  const aTag = String(a?.ollama_tag || "");
  const bTag = String(b?.ollama_tag || "");
  const aPriority = aTag === priorityTag ? 0 : 1;
  const bPriority = bTag === priorityTag ? 0 : 1;
  if (aPriority !== bPriority) {
    return aPriority - bPriority;
  }

  const aMeasured = aTag && benchmarkMap[aTag]?.status === "ok" ? 0 : 1;
  const bMeasured = bTag && benchmarkMap[bTag]?.status === "ok" ? 0 : 1;
  if (aMeasured !== bMeasured) {
    return aMeasured - bMeasured;
  }

  const aUpdated = Date.parse(String(a?.updated_at || "")) || 0;
  const bUpdated = Date.parse(String(b?.updated_at || "")) || 0;
  if (aUpdated !== bUpdated) {
    return bUpdated - aUpdated;
  }

  return String(a?.name || "").localeCompare(String(b?.name || ""));
});
const firstMeasuredModel = sampleModels.find((item) => {
  if (!item.ollama_tag) {
    return false;
  }
  const data = benchmarkMap[item.ollama_tag];
  return data && data.status === "ok" && typeof data.tokens_per_second === "number";
});
const pinnedModelId =
  sampleModels.find((item) => String(item?.ollama_tag || "") === priorityTag && String(item?.quantization || "") === "Q4")
    ?.id || "";
const defaultModelId = pinnedModelId || firstMeasuredModel?.id || sampleModels[0]?.id || "";
const calculatorPath = "/en/tools/vram-calculator/";
const calculatorUrl = `https://localvram.com${calculatorPath}`;
const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "LocalVRAM VRAM Calculator",
  applicationCategory: "DeveloperApplication",
  operatingSystem: "Web",
  url: calculatorUrl,
  inLanguage: "en",
  description: "Estimate minimum and optimal VRAM for local LLM models with local-vs-cloud recommendation."
};
const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: "How to estimate VRAM for an Ollama model",
  description: "Use LocalVRAM calculator to estimate minimum and optimal VRAM before deployment.",
  step: [
    { "@type": "HowToStep", name: "Choose model", text: "Select a model profile from the dropdown." },
    { "@type": "HowToStep", name: "Review VRAM", text: "Check minimum and optimal VRAM requirements." },
    { "@type": "HowToStep", name: "Decide local or cloud", text: "Use hardware upgrade or cloud fallback recommendation." }
  ]
};
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "What does minimum VRAM mean?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Minimum VRAM is the lower bound for loading and running a profile with conservative settings."
      }
    },
    {
      "@type": "Question",
      name: "What does optimal VRAM mean?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Optimal VRAM is the recommended target for stable throughput and lower latency under sustained load."
      }
    },
    {
      "@type": "Question",
      name: "Are calculator values always measured?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "No. Measured values are clearly marked as verified. Unverified profiles use estimated baseline anchors."
      }
    }
  ]
};
---

<BaseLayout
  title="VRAM Calculator | LocalVRAM"
  description="Estimate LLM VRAM requirements and choose local GPU upgrade vs cloud fallback."
  locale="en"
  canonicalPath={calculatorPath}
  structuredData={[softwareSchema, howToSchema, faqSchema]}
>
  <main class="container">
    <h1>VRAM Calculator</h1>
    <p>Pick a model profile to get minimum VRAM, optimal VRAM, and local-vs-cloud recommendation.</p>

    <section class="card">
      <label for="model-select">Model profile</label>
      <select id="model-select" class="input">
        {sampleModels.map((item) => (
          <option value={item.id} selected={item.id === defaultModelId}>{item.name}</option>
        ))}
      </select>
      <div id="calc-result" class="card" style="margin-top: 12px;" />
      <div class="card" style="margin-top: 12px;">
        <div class="card-head">
          <h2>Performance Curve</h2>
          <div class="cta-row card-head-actions">
            <a id="calc-primary" class="btn btn-primary" href="/en/affiliate/hardware-upgrade/">Check local upgrade</a>
            <a id="calc-cloud-runpod" class="btn" href={links.runpod}>RunPod fallback</a>
            <a id="calc-cloud-vast" class="btn" href={links.vast}>Vast.ai fallback</a>
          </div>
        </div>
        <div class="chart-wrap">
          <canvas id="calc-chart" aria-label="Hardware benchmark comparison"></canvas>
        </div>
      </div>
      <p class="affiliate-note">We may earn a commission if you click links on this page.</p>
    </section>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js" defer></script>
  <script define:vars={{ items: sampleModels, benchmarkMap, defaultModelId }}>
    const select = document.getElementById("model-select");
    const result = document.getElementById("calc-result");
    const chartCanvas = document.getElementById("calc-chart");
    const primary = document.getElementById("calc-primary");
    const runpod = document.getElementById("calc-cloud-runpod");
    const vast = document.getElementById("calc-cloud-vast");
    let chart = null;

    const renderChart = (model, realData) => {
      if (!chartCanvas || !window.Chart) {
        return;
      }
      if (chart) {
        chart.destroy();
      }
      const hasMeasured = realData && realData.status === "ok" && typeof realData.tokens_per_second === "number";
      const datasets = [
        {
          label: `${model.name} baseline`,
          data: [model.benchmarks.rtx3090_tok_s, model.benchmarks.rtx4090_tok_s, model.benchmarks.a100_tok_s],
          borderColor: "#3b82f6",
          backgroundColor: "rgba(59,130,246,0.15)",
          borderWidth: 2,
          tension: 0.2
        }
      ];
      if (hasMeasured) {
        datasets.push({
          label: "Measured RTX 3090",
          data: [realData.tokens_per_second, null, null],
          borderColor: "#10b981",
          backgroundColor: "rgba(16,185,129,0.2)",
          borderWidth: 2,
          pointRadius: 5,
          spanGaps: true,
          tension: 0
        });
      }
      chart = new window.Chart(chartCanvas, {
        type: "line",
        data: {
          labels: ["RTX 3090", "RTX 4090", "A100 80GB"],
          datasets
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          scales: {
            y: {
              title: { display: true, text: "tokens/s" },
              beginAtZero: true
            }
          }
        }
      });
    };

    const render = () => {
      const model = items.find((item) => item.id === select.value) || items[0];
      const realData = model.ollama_tag ? benchmarkMap[model.ollama_tag] : null;
      const isMeasured = realData && realData.status === "ok" && typeof realData.tokens_per_second === "number";
      const realPerf = isMeasured ? `${realData.tokens_per_second.toFixed(1)} tok/s` : "N/A";
      const realTestTime = isMeasured ? realData.test_time : "N/A";
      const cloudFirst = model.vram_optimal_gb > 24;
      result.innerHTML = [
        `<h2 class="model-title">${model.name}${isMeasured ? ' <span class="verified-badge" title="Tested on local RTX 3090">Verified</span>' : ""}</h2>`,
        `<p>Minimum VRAM: <strong>${model.vram_min_gb}GB</strong> | Optimal VRAM: <strong>${model.vram_optimal_gb}GB</strong></p>`,
        `<p>Best local: ${model.best_local_gpu} | Cloud fallback: ${model.cloud_fallback}</p>`,
        `<p>Catalog baseline (estimated): 3090 ${model.benchmarks.rtx3090_tok_s} tok/s, 4090 ${model.benchmarks.rtx4090_tok_s} tok/s</p>`,
        `<p>Real performance on RTX 3090: <strong>${realPerf}</strong> (test time: ${realTestTime})</p>`,
        `<p>Data status: <strong>${isMeasured ? "Verified by Real Hardware" : "Estimated"}</strong></p>`
      ].join("");

      primary.textContent = cloudFirst ? "Open cloud options" : "Check local upgrade";
      primary.href = cloudFirst ? "/en/affiliate/cloud-gpu/" : "/en/affiliate/hardware-upgrade/";
      runpod.style.display = cloudFirst ? "inline-block" : "none";
      vast.style.display = cloudFirst ? "inline-block" : "none";
      renderChart(model, realData);
    };

    if (select && defaultModelId && select.value !== defaultModelId) {
      select.value = defaultModelId;
    }

    select.addEventListener("change", render);
    if (document.readyState === "complete") {
      render();
    } else {
      window.addEventListener("load", render, { once: true });
    }
  </script>
</BaseLayout>
