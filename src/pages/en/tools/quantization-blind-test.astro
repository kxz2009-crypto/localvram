---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="Quantization Blind Test | LocalVRAM" locale="en">
  <main class="container">
    <h1>Quantization Blind Test</h1>
    <p>
      Compare outputs between Q4 and Q8 in blind mode. Backend execution queue
      can be connected later through a serverless endpoint.
    </p>
    <ul>
      <li>Daily limit: 5 runs</li>
      <li>Open windows: configurable</li>
      <li>Fallback: offline side-by-side samples</li>
    </ul>
  </main>
</BaseLayout>
