---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import updates from "../../../data/daily-updates.json";
---

<BaseLayout
  title="Daily Updates | LocalVRAM"
  description="Daily update feed generated by LocalVRAM content agent."
  locale="en"
>
  <main class="container">
    <h1>Daily Updates</h1>
    <p>Operational feed for what is updated every day (content + verification + SEO).</p>

    <section class="post-list">
      {updates.items.map((item) => (
        <article class="post-card">
          <h2>{item.date}</h2>
          <p>{item.summary}</p>
          <ul>
            {item.candidates.map((c) => (
              <li>{c.keyword} ({c.score})</li>
            ))}
          </ul>
        </article>
      ))}
    </section>
  </main>
</BaseLayout>
