---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import updates from "../../../data/daily-updates.json";

const pagePath = "/en/updates/";
const pageTitle = "Daily Updates | LocalVRAM";
const pageDescription = "Daily update feed generated by LocalVRAM content agent.";
const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Daily Updates",
  description: pageDescription,
  url: `https://localvram.com${pagePath}`,
  inLanguage: "en",
  dateModified: updates.items[0]?.publish_run_at || updates.items[0]?.date,
  publisher: {
    "@type": "Organization",
    name: "LocalVRAM",
    url: "https://localvram.com/en/",
  },
  mainEntity: {
    "@type": "ItemList",
    numberOfItems: updates.items.length,
    itemListElement: updates.items.slice(0, 30).map((item, index) => ({
      "@type": "ListItem",
      position: index + 1,
      item: {
        "@type": "CreativeWork",
        name: `LocalVRAM update ${item.date}`,
        description: item.summary,
        datePublished: item.publish_run_at || item.date,
      },
    })),
  },
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  locale="en"
  canonicalPath={pagePath}
  structuredData={structuredData}
>
  <main class="container">
    <h1>Daily Updates</h1>
    <p>Operational feed for what is updated every day (content + verification + SEO).</p>

    <section class="post-list">
      {updates.items.map((item) => (
        <article class="post-card">
          <h2>{item.date}</h2>
          <p>{item.summary}</p>
          <ul>
            {item.candidates.map((c) => (
              <li>{c.keyword} ({c.score})</li>
            ))}
          </ul>
        </article>
      ))}
    </section>
  </main>
</BaseLayout>
