---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../../data/root-alternates";

const pagePath = "/fr/tools/vram-calculator/";
const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "VRAM Calculator FR",
  url: "https://localvram.com/fr/tools/vram-calculator/",
  inLanguage: "fr"
};
---

<BaseLayout
  title="LocalVRAM FR | VRAM Calculator"
  description="Point de conversion CTA en francais."
  locale="fr"
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={structuredData}
>
  <main class="container">
    <section class="card">
      <h1>VRAM Calculator (FR)</h1>
      <p>Page de conversion CTA pour le funnel francais.</p>
      <div class="cta-row">
        <a class="btn" href="/fr/guides/local-llm-cost-vs-cloud/">Retour a la page sujet</a>
        <a class="btn" href="/fr/models/qwen35-35b-q4/">Retour a la page modele</a>
      </div>
    </section>
  </main>
</BaseLayout>
