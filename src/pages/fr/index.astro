---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../data/root-alternates";

const pagePath = "/fr/";
const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "LocalVRAM Francais",
  url: "https://localvram.com/fr/",
  inLanguage: "fr",
  description: "Route francaise pour l'expansion SEO multilingue de LocalVRAM."
};
---

<BaseLayout
  title="LocalVRAM | Francais"
  description="Route francaise pour l'expansion SEO multilingue de LocalVRAM."
  locale="fr"
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={structuredData}
>
  <main class="container">
    <header class="simple-header">
      <img src="/branding/logo.svg" alt="LocalVRAM" />
      <a class="btn" href="/en/">English</a>
    </header>
    <section class="hero">
      <img class="verified-pill" src="/branding/ollama-verified-pill.svg" alt="Ollama Verified" />
      <h1>La route francaise est active</h1>
      <p>
        Le SEO et les operations en francais sont geres separement des sites anglais et chinois.
      </p>
      <div class="cta-row">
        <a class="btn btn-primary" href="/fr/tools/vram-calculator/">Ouvrir l'outil principal</a>
        <a class="btn" href="/fr/guides/local-llm-cost-vs-cloud/">Page sujet</a>
        <a class="btn" href="/fr/models/qwen35-35b-q4/">Page modele</a>
        <a class="btn" href="/fr/guides/ollama-vs-vllm-vram/">Guide runtime</a>
        <a class="btn" href="/en/status/data-freshness/">Fraicheur des donnees</a>
        <a class="btn" href="/fr/tools/roi-calculator/">ROI Calculator</a>
        <a class="btn" href="/fr/tools/quantization-blind-test/">Quantization Blind Test</a>
        <a class="btn" href="/fr/benchmarks/changelog/">Benchmark Changelog</a>
        <a class="btn" href="/fr/status/data-freshness/">Data Freshness</a>
        <a class="btn" href="/fr/benchmarks/">Benchmark Hub</a>
        <a class="btn" href="/fr/status/pipeline-status/">Pipeline Status</a>
        <a class="btn" href="/fr/models/">Model Catalog</a>
        <a class="btn" href="/fr/hardware/">Hardware Tiers</a>
        <a class="btn" href="/fr/status/">Status Hub</a>
        <a class="btn" href="/fr/status/conversion-funnel/">Conversion Funnel</a>
        <a class="btn" href="/fr/errors/">Error KB</a>
      </div>
    </section>
  </main>
</BaseLayout>





