---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../data/root-alternates";

const pagePath = "/ru/";
const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "LocalVRAM Русский",
  url: "https://localvram.com/ru/",
  inLanguage: "ru",
  description: "Русский маршрут для многоязычного SEO-расширения LocalVRAM."
};
---

<BaseLayout
  title="LocalVRAM | Русский"
  description="Русский маршрут для многоязычного SEO-расширения LocalVRAM."
  locale="ru"
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={structuredData}
>
  <main class="container">
    <header class="simple-header">
      <img src="/branding/logo.svg" alt="LocalVRAM" />
      <a class="btn" href="/en/">English</a>
    </header>
    <section class="hero">
      <img class="verified-pill" src="/branding/ollama-verified-pill.svg" alt="Ollama Verified" />
      <h1>Русская версия маршрута активирована</h1>
      <p>
        SEO и операционные процессы для русского языка ведутся отдельно от английского и китайского.
      </p>
      <div class="cta-row">
        <a class="btn btn-primary" href="/ru/tools/vram-calculator/">Открыть основной инструмент</a>
        <a class="btn" href="/ru/guides/local-llm-cost-vs-cloud/">Тематическая страница</a>
        <a class="btn" href="/ru/models/qwen35-35b-q4/">Страница модели</a>
        <a class="btn" href="/ru/guides/ollama-vs-vllm-vram/">Гайд по рантаймам</a>
        <a class="btn" href="/en/status/data-freshness/">Актуальность данных</a>
        <a class="btn" href="/ru/tools/roi-calculator/">ROI Calculator</a>
        <a class="btn" href="/ru/tools/quantization-blind-test/">Quantization Blind Test</a>
        <a class="btn" href="/ru/benchmarks/changelog/">Benchmark Changelog</a>
        <a class="btn" href="/ru/status/data-freshness/">Data Freshness</a>
        <a class="btn" href="/ru/benchmarks/">Benchmark Hub</a>
        <a class="btn" href="/ru/status/pipeline-status/">Pipeline Status</a>
        <a class="btn" href="/ru/models/">Model Catalog</a>
        <a class="btn" href="/ru/hardware/">Hardware Tiers</a>
        <a class="btn" href="/ru/status/">Status Hub</a>
        <a class="btn" href="/ru/status/conversion-funnel/">Conversion Funnel</a>
        <a class="btn" href="/ru/errors/">Error KB</a>
      </div>
    </section>
  </main>
</BaseLayout>





