---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../../data/root-alternates";

const pagePath = "/ru/tools/vram-calculator/";
const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "VRAM Calculator RU",
  url: "https://localvram.com/ru/tools/vram-calculator/",
  inLanguage: "ru"
};
---

<BaseLayout
  title="LocalVRAM RU | VRAM Calculator"
  description="Russian CTA conversion entry."
  locale="ru"
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={structuredData}
>
  <main class="container">
    <section class="card">
      <h1>VRAM Calculator (RU)</h1>
      <p>CTA conversion page for Russian funnel routing.</p>
      <div class="cta-row">
        <a class="btn" href="/ru/guides/local-llm-cost-vs-cloud/">Back to topic page</a>
        <a class="btn" href="/ru/models/qwen35-35b-q4/">Back to model page</a>
      </div>
    </section>
  </main>
</BaseLayout>
