---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../../data/root-alternates";

const pagePath = "/hi/tools/vram-calculator/";
const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "VRAM कैलकुलेटर HI",
  url: "https://localvram.com/hi/tools/vram-calculator/",
  inLanguage: "hi"
};
---

<BaseLayout
  title="LocalVRAM HI | VRAM Calculator"
  description="हिंदी CTA कन्वर्ज़न एंट्री।"
  locale="hi"
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={structuredData}
>
  <main class="container">
    <section class="card">
      <h1>VRAM कैलकुलेटर (HI)</h1>
      <p>हिंदी फ़नल के लिए CTA कन्वर्ज़न पेज।</p>
      <div class="cta-row">
        <a class="btn" href="/hi/guides/local-llm-cost-vs-cloud/">टॉपिक पेज पर वापस जाएं</a>
        <a class="btn" href="/hi/models/qwen35-35b-q4/">मॉडल पेज पर वापस जाएं</a>
      </div>
    </section>
  </main>
</BaseLayout>