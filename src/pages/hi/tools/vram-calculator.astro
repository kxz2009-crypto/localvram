---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../../data/root-alternates";

const pagePath = "/hi/tools/vram-calculator/";
const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "VRAM Calculator HI",
  url: "https://localvram.com/hi/tools/vram-calculator/",
  inLanguage: "hi"
};
---

<BaseLayout
  title="LocalVRAM HI | VRAM Calculator"
  description="Hindi CTA conversion entry."
  locale="hi"
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={structuredData}
>
  <main class="container">
    <section class="card">
      <h1>VRAM Calculator (HI)</h1>
      <p>CTA conversion page for Hindi funnel routing.</p>
      <div class="cta-row">
        <a class="btn" href="/hi/guides/local-llm-cost-vs-cloud/">Back to topic page</a>
        <a class="btn" href="/hi/models/qwen35-35b-q4/">Back to model page</a>
      </div>
    </section>
  </main>
</BaseLayout>
