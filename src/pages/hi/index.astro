---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../data/root-alternates";

const pagePath = "/hi/";
const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "LocalVRAM हिंदी",
  url: "https://localvram.com/hi/",
  inLanguage: "hi",
  description: "LocalVRAM के बहुभाषी SEO विस्तार के लिए हिंदी रूट।"
};
---

<BaseLayout
  title="LocalVRAM | हिंदी"
  description="LocalVRAM के बहुभाषी SEO विस्तार के लिए हिंदी रूट।"
  locale="hi"
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={structuredData}
>
  <main class="container">
    <header class="simple-header">
      <img src="/branding/logo.svg" alt="LocalVRAM" />
      <a class="btn" href="/en/">English</a>
    </header>
    <section class="hero">
      <img class="verified-pill" src="/branding/ollama-verified-pill.svg" alt="Ollama Verified" />
      <h1>हिंदी रूट अब सक्रिय है</h1>
      <p>
        हिंदी के लिए SEO और संचालन, अंग्रेजी और चीनी से अलग चलाए जाते हैं।
      </p>
      <div class="cta-row">
        <a class="btn btn-primary" href="/hi/tools/vram-calculator/">मुख्य टूल खोलें</a>
        <a class="btn" href="/hi/guides/local-llm-cost-vs-cloud/">टॉपिक पेज</a>
        <a class="btn" href="/hi/models/qwen35-35b-q4/">मॉडल पेज</a>
        <a class="btn" href="/hi/guides/ollama-vs-vllm-vram/">रनटाइम तुलना गाइड</a>
        <a class="btn" href="/en/status/data-freshness/">डेटा ताजगी</a>
      </div>
    </section>
  </main>
</BaseLayout>
