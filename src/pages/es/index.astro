---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../data/root-alternates";

const pagePath = "/es/";
const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "LocalVRAM Espanol",
  url: "https://localvram.com/es/",
  inLanguage: "es",
  description: "Ruta en espanol para la expansion SEO multilingue de LocalVRAM."
};
---

<BaseLayout
  title="LocalVRAM | Espanol"
  description="Ruta en espanol para la expansion SEO multilingue de LocalVRAM."
  locale="es"
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={structuredData}
>
  <main class="container">
    <header class="simple-header">
      <img src="/branding/logo.svg" alt="LocalVRAM" />
      <a class="btn" href="/en/">English</a>
    </header>
    <section class="hero">
      <img class="verified-pill" src="/branding/ollama-verified-pill.svg" alt="Ollama Verified" />
      <h1>La ruta en espanol ya esta activa</h1>
      <p>
        El SEO y las operaciones en espanol se gestionan de forma independiente del ingles y el chino.
      </p>
      <div class="cta-row">
        <a class="btn btn-primary" href="/es/tools/vram-calculator/">Abrir herramienta principal</a>
        <a class="btn" href="/es/guides/local-llm-cost-vs-cloud/">Pagina tematica</a>
        <a class="btn" href="/es/models/qwen35-35b-q4/">Pagina del modelo</a>
        <a class="btn" href="/en/status/data-freshness/">Actualizacion de datos</a>
      </div>
    </section>
  </main>
</BaseLayout>