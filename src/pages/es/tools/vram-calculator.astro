---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../../data/root-alternates";

const pagePath = "/es/tools/vram-calculator/";
const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "Calculadora de VRAM ES",
  url: "https://localvram.com/es/tools/vram-calculator/",
  inLanguage: "es"
};
---

<BaseLayout
  title="LocalVRAM ES | VRAM Calculator"
  description="Entrada de conversion CTA en espanol."
  locale="es"
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={structuredData}
>
  <main class="container">
    <section class="card">
      <h1>Calculadora de VRAM (ES)</h1>
      <p>Pagina de conversion CTA para el embudo en espanol.</p>
      <div class="cta-row">
        <a class="btn" href="/es/guides/local-llm-cost-vs-cloud/">Volver a la pagina tematica</a>
        <a class="btn" href="/es/models/qwen35-35b-q4/">Volver a la pagina del modelo</a>
      </div>
    </section>
  </main>
</BaseLayout>