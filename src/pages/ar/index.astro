---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../data/root-alternates";

const pagePath = "/ar/";
const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "LocalVRAM العربية",
  url: "https://localvram.com/ar/",
  inLanguage: "ar",
  description: "المسار العربي لتوسعة تحسين محركات البحث متعددة اللغات في LocalVRAM."
};
---

<BaseLayout
  title="LocalVRAM | Arabic GPU VRAM Calculator & Benchmarks"
  description="Find local model compatibility, estimate VRAM by GPU tier, track benchmark freshness, and optimize run-versus-rent decisions for the Arabic route."
  locale="ar"
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={structuredData}
>
  <main class="container">
    <header class="simple-header">
      <img src="/branding/logo.svg" alt="LocalVRAM" />
      <a class="btn" href="/en/">English</a>
    </header>
    <section class="hero">
      <img class="verified-pill" src="/branding/ollama-verified-pill.svg" alt="Ollama Verified" />
      <h1>تم تفعيل المسار العربي</h1>
      <p>
        يتم تشغيل السيو والعمليات للعربية بشكل مستقل عن الإنجليزية والصينية.
      </p>
      <h2>Navigation Hubs</h2>
      <h3>Tools, model pages, hardware tiers, and status monitors</h3>
      <div class="cta-row">
        <a class="btn btn-primary" href="/ar/tools/vram-calculator/">فتح الأداة الأساسية</a>
        <a class="btn" href="/ar/guides/local-llm-cost-vs-cloud/">صفحة الموضوع</a>
        <a class="btn" href="/ar/models/qwen35-35b-q4/">صفحة النموذج</a>
        <a class="btn" href="/ar/guides/ollama-vs-vllm-vram/">دليل مقارنة الرنتايم</a>
        <a class="btn" href="/en/status/data-freshness/">حداثة البيانات</a>
        <a class="btn" href="/ar/tools/roi-calculator/">ROI Calculator</a>
        <a class="btn" href="/ar/tools/quantization-blind-test/">Quantization Blind Test</a>
        <a class="btn" href="/ar/benchmarks/changelog/">Benchmark Changelog</a>
        <a class="btn" href="/ar/status/data-freshness/">Data Freshness</a>
        <a class="btn" href="/ar/benchmarks/">Benchmark Hub</a>
        <a class="btn" href="/ar/status/pipeline-status/">Pipeline Status</a>
        <a class="btn" href="/ar/models/">Model Catalog</a>
        <a class="btn" href="/ar/hardware/">Hardware Tiers</a>
        <a class="btn" href="/ar/status/">Status Hub</a>
        <a class="btn" href="/ar/status/conversion-funnel/">Conversion Funnel</a>
        <a class="btn" href="/ar/errors/">Error KB</a>
      </div>
    </section>
  </main>
</BaseLayout>





