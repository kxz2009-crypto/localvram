---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../../data/root-alternates";

const pagePath = "/ar/tools/vram-calculator/";
const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "حاسبة VRAM AR",
  url: "https://localvram.com/ar/tools/vram-calculator/",
  inLanguage: "ar"
};
---

<BaseLayout
  title="LocalVRAM AR | VRAM Calculator"
  description="نقطة تحويل CTA باللغة العربية."
  locale="ar"
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={structuredData}
>
  <main class="container">
    <section class="card">
      <h1>حاسبة VRAM (AR)</h1>
      <p>صفحة تحويل CTA لمسار العربية.</p>
      <div class="cta-row">
        <a class="btn" href="/ar/guides/local-llm-cost-vs-cloud/">العودة إلى صفحة الموضوع</a>
        <a class="btn" href="/ar/models/qwen35-35b-q4/">العودة إلى صفحة النموذج</a>
      </div>
    </section>
  </main>
</BaseLayout>