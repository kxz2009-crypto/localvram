---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../../data/root-alternates";
import { LOCALE_WAVE2, WAVE2_LOCALES, type Wave2Locale } from "../../../data/locale-wave2-copy";

export function getStaticPaths() {
  return WAVE2_LOCALES.map((locale) => ({
    params: { locale }
  }));
}

const localeParam = String(Astro.params.locale || "");
if (!Object.prototype.hasOwnProperty.call(LOCALE_WAVE2, localeParam)) {
  throw new Error(`Unsupported locale for wave2 guide: ${localeParam}`);
}

const locale = localeParam as Wave2Locale;
const copy = LOCALE_WAVE2[locale];
const pagePath = `/${locale}/guides/ollama-vs-vllm-vram/`;
const zhOrigin = (import.meta.env.PUBLIC_ZH_SITE_ORIGIN || "https://localvram.com").replace(/\/$/, "");
const siteOrigin = locale === "zh" ? zhOrigin : "https://localvram.com";
const pageUrl = `${siteOrigin}${pagePath}`;
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  headline: copy.guideHeading,
  description: copy.guideDescription,
  inLanguage: locale,
  url: pageUrl,
  author: {
    "@type": "Organization",
    name: "LocalVRAM"
  }
};
---

<BaseLayout
  title={copy.guideTitle}
  description={copy.guideDescription}
  locale={locale}
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={articleSchema}
>
  <main class="container">
    <section class="card">
      <h1>{copy.guideHeading}</h1>
      <p>{copy.guideIntro}</p>
      <ul>
        <li>Ollama: local-first workflow, fast setup, and lower ops overhead.</li>
        <li>vLLM: stronger for API-serving and high-concurrency throughput.</li>
        <li>122B-class deployment: default to cloud-first, then optimize by measured demand.</li>
      </ul>
      <div class="cta-row">
        <a class="btn btn-primary" href={`/${locale}/models/qwen35-122b-cloud/`}>{copy.ctaModel122}</a>
        <a class="btn" href={`/${locale}/models/qwen35-35b-q4/`}>{copy.ctaModel35}</a>
        <a class="btn" href={`/${locale}/tools/vram-calculator/`}>{copy.ctaTool}</a>
      </div>
    </section>
  </main>
</BaseLayout>
