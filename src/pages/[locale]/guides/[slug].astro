---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../../data/root-alternates";
import { GUIDE_ROUTE_ITEMS, type RouteManifestItem } from "../../../data/i18n-route-manifest";
import { STANDARD_I18N_LOCALES, type ComLocale } from "../../../config/i18n";
import { withLocale } from "../../../lib/locale-paths";

export function getStaticPaths() {
  return STANDARD_I18N_LOCALES.flatMap((locale) =>
    GUIDE_ROUTE_ITEMS.map((item) => ({
      params: { locale, slug: item.slug },
      props: { locale, item },
    })),
  );
}

const { locale, item } = Astro.props as { locale: ComLocale; item: RouteManifestItem };
const pagePath = withLocale(locale, item.enPath);
---

<BaseLayout
  title={`${item.title} (${locale.toUpperCase()}) | LocalVRAM`}
  description={item.description}
  locale={locale}
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  noindex={true}
>
  <main class="container">
    <section class="hero">
      <h1>{item.title}</h1>
      <p>{item.description}</p>
      <p>
        This localized page is in staged rollout mode. Content quality gates and glossary checks are applied
        before index enablement.
      </p>
      <div class="cta-row">
        <a class="btn btn-primary" href={item.enPath}>Open English Source</a>
        <a class="btn" href={withLocale(locale, "/en/guides/")}>Back to Guides Hub</a>
        <a class="btn" href={withLocale(locale, "/en/status/")}>Open Status Hub</a>
      </div>
    </section>

    <section class="card-grid">
      <article class="card">
        <h2>Current Rollout State</h2>
        <p>Route is active, canonical is locale-scoped, and hreflang is controlled by staged rollout policy.</p>
      </article>
      <article class="card">
        <h2>Next Step</h2>
        <p>Replace fallback copy with fully localized content after glossary and terminology checks pass.</p>
      </article>
    </section>
  </main>
</BaseLayout>

