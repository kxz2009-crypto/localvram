---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../../data/root-alternates";
import { LOCALE_WAVE2, WAVE2_LOCALES, type Wave2Locale } from "../../../data/locale-wave2-copy";

export function getStaticPaths() {
  return WAVE2_LOCALES.map((locale) => ({
    params: { locale }
  }));
}

const localeParam = String(Astro.params.locale || "");
if (!Object.prototype.hasOwnProperty.call(LOCALE_WAVE2, localeParam)) {
  throw new Error(`Unsupported locale for localized hardware-upgrade page: ${localeParam}`);
}

const locale = localeParam as Wave2Locale;
const copy = LOCALE_WAVE2[locale];
const pagePath = `/${locale}/affiliate/hardware-upgrade/`;
const zhOrigin = (import.meta.env.PUBLIC_ZH_SITE_ORIGIN || "https://localvram.com").replace(/\/$/, "");
const siteOrigin = locale === "zh" ? zhOrigin : "https://localvram.com";
const pageUrl = `${siteOrigin}${pagePath}`;
const pageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Hardware upgrade simulator",
  inLanguage: locale,
  url: pageUrl
};
---

<BaseLayout
  title={`LocalVRAM ${locale.toUpperCase()} | Hardware Upgrade`}
  description="Evaluate practical GPU upgrade routes for local model workloads."
  locale={locale}
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={pageSchema}
>
  <main class="container">
    <h1>Hardware Upgrade Simulator</h1>
    <p>Plan upgrade path by current VRAM tier, workload target, and cloud fallback threshold.</p>

    <section class="card-grid">
      <article class="card">
        <h2>Used RTX 3090</h2>
        <p>Best value jump for 24GB class workloads.</p>
      </article>
      <article class="card">
        <h2>RTX 4090</h2>
        <p>Higher throughput and sustained performance headroom.</p>
      </article>
      <article class="card">
        <h2>Local + Cloud Burst</h2>
        <p>Keep daily workloads local and burst to cloud only when needed.</p>
      </article>
    </section>

    <section class="cta-row">
      <a class="btn" href={`/${locale}/affiliate/cloud-gpu/`}>Open Cloud GPU Options</a>
      <a class="btn" href={`/${locale}/hardware/`}>Open Hardware Tiers</a>
      <a class="btn btn-primary" href={`/${locale}/tools/vram-calculator/`}>{copy.ctaTool}</a>
    </section>
  </main>
</BaseLayout>
