---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import providers from "../../../data/cloud-gpu.json";
import { ROOT_ALTERNATES } from "../../../data/root-alternates";
import { LOCALE_WAVE2, WAVE2_LOCALES, type Wave2Locale } from "../../../data/locale-wave2-copy";

export function getStaticPaths() {
  return WAVE2_LOCALES.map((locale) => ({
    params: { locale }
  }));
}

const localeParam = String(Astro.params.locale || "");
if (!Object.prototype.hasOwnProperty.call(LOCALE_WAVE2, localeParam)) {
  throw new Error(`Unsupported locale for localized cloud GPU page: ${localeParam}`);
}

const locale = localeParam as Wave2Locale;
const copy = LOCALE_WAVE2[locale];
const pagePath = `/${locale}/affiliate/cloud-gpu/`;
const zhOrigin = (import.meta.env.PUBLIC_ZH_SITE_ORIGIN || "https://localvram.com").replace(/\/$/, "");
const siteOrigin = locale === "zh" ? zhOrigin : "https://localvram.com";
const pageUrl = `${siteOrigin}${pagePath}`;
const pageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Cloud GPU options",
  inLanguage: locale,
  url: pageUrl
};
---

<BaseLayout
  title={`LocalVRAM ${locale.toUpperCase()} | Cloud GPU Options`}
  description="Compare cloud GPU options when local VRAM is insufficient."
  locale={locale}
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={pageSchema}
>
  <main class="container">
    <h1>Cloud GPU Options</h1>
    <section class="card">
      <table class="table">
        <thead>
          <tr>
            <th>Provider</th>
            <th>Recommended GPU</th>
            <th>Price/hr</th>
            <th>Setup</th>
          </tr>
        </thead>
        <tbody>
          {providers.providers.map((p) => (
            <tr>
              <td>{p.name}</td>
              <td>{p.recommended_gpu}</td>
              <td>${p.hourly_usd}</td>
              <td>{p.setup}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    <section class="cta-row">
      <a class="btn" href={`/${locale}/affiliate/hardware-upgrade/`}>Open Hardware Upgrade</a>
      <a class="btn" href={`/${locale}/models/`}>Open Model Catalog</a>
      <a class="btn btn-primary" href={`/${locale}/tools/vram-calculator/`}>{copy.ctaTool}</a>
    </section>
  </main>
</BaseLayout>
