---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../../data/root-alternates";
import { LOCALE_WAVE2, WAVE2_LOCALES, type Wave2Locale } from "../../../data/locale-wave2-copy";

export function getStaticPaths() {
  return WAVE2_LOCALES.map((locale) => ({
    params: { locale }
  }));
}

const localeParam = String(Astro.params.locale || "");
if (!Object.prototype.hasOwnProperty.call(LOCALE_WAVE2, localeParam)) {
  throw new Error(`Unsupported locale for quantization blind test: ${localeParam}`);
}

const locale = localeParam as Wave2Locale;
const copy = LOCALE_WAVE2[locale];
const pagePath = `/${locale}/tools/quantization-blind-test/`;
const zhOrigin = (import.meta.env.PUBLIC_ZH_SITE_ORIGIN || "https://localvram.com").replace(/\/$/, "");
const siteOrigin = locale === "zh" ? zhOrigin : "https://localvram.com";
const pageUrl = `${siteOrigin}${pagePath}`;
const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "LocalVRAM Quantization Blind Test",
  applicationCategory: "DeveloperApplication",
  operatingSystem: "Web",
  inLanguage: locale,
  url: pageUrl
};
---

<BaseLayout
  title={`LocalVRAM ${locale.toUpperCase()} | Quantization Blind Test`}
  description="Compare Q4/Q5/Q8 quality and latency with a practical blind test workflow."
  locale={locale}
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={softwareSchema}
>
  <main class="container">
    <section class="card">
      <h1>Quantization Blind Test</h1>
      <p>Run side-by-side prompts with hidden quantization labels and track quality drift against VRAM savings.</p>
      <ul>
        <li>Run a fixed prompt set on Q4, Q5, and Q8.</li>
        <li>Score output quality first, reveal quantization later.</li>
        <li>Keep the smallest setting that meets your quality bar.</li>
      </ul>
      <div class="cta-row">
        <a class="btn btn-primary" href={`/${locale}/tools/vram-calculator/`}>{copy.ctaTool}</a>
        <a class="btn" href={`/${locale}/models/qwen35-35b-q4/`}>{copy.ctaModel35}</a>
        <a class="btn" href={`/${locale}/models/qwen35-35b-fp16/`}>Open 35B FP16</a>
      </div>
    </section>
  </main>
</BaseLayout>
