---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../../data/root-alternates";
import { TOOL_ROUTE_ITEMS, type RouteManifestItem } from "../../../data/i18n-route-manifest";
import { STANDARD_I18N_LOCALES, type ComLocale } from "../../../config/i18n";
import { withLocale } from "../../../lib/locale-paths";
import { resolvePageCopy, shouldNoindexByFallback } from "../../../lib/i18n-copy";
import { localizeRouteItem } from "../../../lib/localize-route-item";

export function getStaticPaths() {
  return STANDARD_I18N_LOCALES.flatMap((locale) =>
    TOOL_ROUTE_ITEMS.filter((item) => item.slug !== "vram-calculator").map((item) => ({
      params: { locale, slug: item.slug },
      props: { locale, item },
    })),
  );
}

const { locale, item } = Astro.props as { locale: ComLocale; item: RouteManifestItem };
const pagePath = withLocale(locale, item.enPath);
const home = resolvePageCopy("locale-home", locale, { localeUpper: locale.toUpperCase() }).fields;
const previewCopy = resolvePageCopy("tools-detail", locale, {
  localeUpper: locale.toUpperCase(),
  itemTitle: item.title,
  itemDescription: item.description,
});
const previewText = previewCopy.fields;
const localizedItem = localizeRouteItem(item, home, previewText.rollout_intro);
const copy = resolvePageCopy("tools-detail", locale, {
  localeUpper: locale.toUpperCase(),
  itemTitle: localizedItem.title,
  itemDescription: localizedItem.description,
});
const text = copy.fields;
const shouldNoindex = shouldNoindexByFallback(locale, copy.fallbackRatio);
const pageUrl = `https://localvram.com${pagePath}`;
const roiSoftwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: localizedItem.title,
  applicationCategory: "FinanceApplication",
  operatingSystem: "Web",
  url: pageUrl,
  inLanguage: locale,
  description: localizedItem.description,
};
const roiFaqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  inLanguage: locale,
  mainEntity: [
    {
      "@type": "Question",
      name: "When should I run local instead of cloud?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "If sustained monthly usage is high and the target model fits local VRAM, local deployment is usually cheaper over time.",
      },
    },
    {
      "@type": "Question",
      name: "When should I burst to cloud?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Use cloud when the target model exceeds local VRAM or when short-term high-throughput capacity is needed.",
      },
    },
  ],
};
const quantDatasetSchema = {
  "@context": "https://schema.org",
  "@type": "Dataset",
  name: localizedItem.title,
  description: localizedItem.description,
  url: pageUrl,
  inLanguage: locale,
  creator: {
    "@type": "Organization",
    name: "LocalVRAM",
  },
  license: "https://localvram.com/legal/",
};
const quantFaqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  inLanguage: locale,
  mainEntity: [
    {
      "@type": "Question",
      name: "What does this blind test compare?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "It compares answer quality between lower-VRAM and higher-retention quantization profiles without exposing which output is which.",
      },
    },
    {
      "@type": "Question",
      name: "Does this page run live inference now?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "It supports offline side-by-side samples now and can be connected to an execution queue later.",
      },
    },
  ],
};
const quantHowToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: localizedItem.title,
  description: localizedItem.description,
  inLanguage: locale,
  totalTime: "PT10M",
  step: [
    {
      "@type": "HowToStep",
      name: "Prepare one benchmark prompt set",
      text: "Use the same prompts for both quantization runs so only quantization level changes.",
    },
    {
      "@type": "HowToStep",
      name: "Generate blind outputs",
      text: "Label outputs A/B without showing which profile used lower or higher quantization.",
    },
    {
      "@type": "HowToStep",
      name: "Score before reveal",
      text: "Score factuality, structure, and latency first, then reveal quantization labels.",
    },
  ],
};
const structuredData =
  item.slug === "roi-calculator"
    ? [roiSoftwareSchema, roiFaqSchema]
    : item.slug === "quantization-blind-test"
      ? [quantDatasetSchema, quantFaqSchema, quantHowToSchema]
      : [];
---

<BaseLayout
  title={text.meta_title}
  description={text.meta_description}
  locale={locale}
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  noindex={shouldNoindex}
  structuredData={structuredData}
>
  <main class="container">
    <section class="hero">
      <h1>{localizedItem.title}</h1>
      <p>{localizedItem.description}</p>
      <p>{text.rollout_intro}</p>
      <div class="cta-row">
        <a class="btn" href={withLocale(locale, "/en/tools/")}>{text.cta_back_hub}</a>
        <a class="btn" href={withLocale(locale, "/en/models/")}>{text.cta_open_models}</a>
      </div>
    </section>
  </main>
</BaseLayout>
