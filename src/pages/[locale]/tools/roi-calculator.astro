---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../../data/root-alternates";
import { LOCALE_WAVE2, WAVE2_LOCALES, type Wave2Locale } from "../../../data/locale-wave2-copy";

export function getStaticPaths() {
  return WAVE2_LOCALES.map((locale) => ({
    params: { locale }
  }));
}

const localeParam = String(Astro.params.locale || "");
if (!Object.prototype.hasOwnProperty.call(LOCALE_WAVE2, localeParam)) {
  throw new Error(`Unsupported locale for ROI calculator: ${localeParam}`);
}

const locale = localeParam as Wave2Locale;
const copy = LOCALE_WAVE2[locale];
const pagePath = `/${locale}/tools/roi-calculator/`;
const zhOrigin = (import.meta.env.PUBLIC_ZH_SITE_ORIGIN || "https://localvram.com").replace(/\/$/, "");
const siteOrigin = locale === "zh" ? zhOrigin : "https://localvram.com";
const pageUrl = `${siteOrigin}${pagePath}`;
const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "LocalVRAM ROI Calculator",
  applicationCategory: "FinanceApplication",
  operatingSystem: "Web",
  url: pageUrl,
  inLanguage: locale,
  description: "Estimate local GPU run cost vs cloud hourly pricing for LLM inference."
};
---

<BaseLayout
  title={`LocalVRAM ${locale.toUpperCase()} | ROI Calculator`}
  description="Compare local run cost and cloud rent cost for practical model deployment decisions."
  locale={locale}
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={softwareSchema}
>
  <main class="container">
    <section class="card">
      <h1>ROI Calculator</h1>
      <p>Use this page to decide when local GPU serving is cheaper than cloud hourly rental.</p>
      <ul>
        <li>Input electricity and utilization for your local node.</li>
        <li>Compare with cloud hourly list price for the same throughput target.</li>
        <li>Use hybrid path when burst traffic exceeds local capacity.</li>
      </ul>
      <div class="cta-row">
        <a class="btn btn-primary" href={`/${locale}/tools/vram-calculator/`}>{copy.ctaTool}</a>
        <a class="btn" href={`/${locale}/guides/local-llm-cost-vs-cloud/`}>{copy.ctaCostGuide}</a>
        <a class="btn" href={`/${locale}/models/qwen35-122b-cloud/`}>{copy.ctaModel122}</a>
      </div>
    </section>
  </main>
</BaseLayout>
