---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import catalog from "../../../data/model-catalog.json";
import links from "../../../data/affiliate-links.json";
import benchmarkResults from "../../../data/benchmark-results.json";
import newModelWatchlist from "../../../data/new-model-watchlist.json";
import vramUiCatalog from "../../../data/i18n-vram-calculator-ui.json";
import { ROOT_ALTERNATES } from "../../../data/root-alternates";
import { STANDARD_I18N_LOCALES, type ComLocale } from "../../../config/i18n";
import { withLocale } from "../../../lib/locale-paths";
import { resolvePageCopy, shouldNoindexByFallback } from "../../../lib/i18n-copy";
import { getFeaturedTestModels } from "../../../lib/featured-test-models";

export function getStaticPaths() {
  return STANDARD_I18N_LOCALES.map((locale) => ({
    params: { locale },
    props: { locale },
  }));
}

const { locale } = Astro.props as { locale: ComLocale };
const localeUpper = locale.toUpperCase();
const pagePath = withLocale(locale, "/en/tools/vram-calculator/");
const home = resolvePageCopy("locale-home", locale, { localeUpper }).fields;
const copy = resolvePageCopy("tools-detail", locale, {
  localeUpper,
  itemTitle: home.cta_start_vram || "VRAM Calculator",
  itemDescription: home.hero_intro || "Estimate VRAM before deployment.",
});
const text = copy.fields;
const shouldNoindex = shouldNoindexByFallback(locale, copy.fallbackRatio);
const uiCatalog = vramUiCatalog as Record<string, Record<string, string>>;
const ui = uiCatalog[locale] || uiCatalog.en;
const seoCopyByLocale: Partial<Record<ComLocale, Record<string, string>>> = {
  de: {
    title: "VRAM Rechner und VRAM Test | LocalVRAM",
    description:
      "Teste, wie viel VRAM ein lokales LLM braucht. Vergleiche Mindest-VRAM, optimalen VRAM, RTX 3090 Benchmarks und Cloud-Fallback.",
    intro:
      "Wähle ein Modellprofil, um Mindest-VRAM, optimalen VRAM, reale RTX 3090 Messwerte und die Entscheidung lokal oder Cloud zu prüfen.",
    testTitle: "So funktioniert der VRAM Test",
    testStep1Title: "1. Modellprofil wählen",
    testStep1Body:
      "Der Rechner nutzt den LocalVRAM Modellkatalog und priorisiert aktuelle Ollama-Modelle mit Benchmark-Snapshots.",
    testStep2Title: "2. VRAM Bedarf lesen",
    testStep2Body:
      "Minimaler VRAM zeigt die Untergrenze. Optimaler VRAM ist der Zielwert für stabilere Latenz und sustained throughput.",
    testStep3Title: "3. Lokal oder Cloud entscheiden",
    testStep3Body:
      "Wenn das Profil über 24GB VRAM braucht, zeigt die Seite Cloud-Optionen. Kleinere Profile verweisen zuerst auf lokale Hardware.",
    faqTitle: "VRAM Rechner FAQ",
    faqQ1: "Wie teste ich, ob genug VRAM vorhanden ist?",
    faqA1:
      "Wähle das Modellprofil und vergleiche minimalen VRAM, optimalen VRAM und Datenstatus. Verifizierte Profile enthalten reale RTX 3090 Messwerte.",
    faqQ2: "Was ist der Unterschied zwischen RAM Rechner und VRAM Rechner?",
    faqA2:
      "RAM beschreibt Systemspeicher. VRAM ist der GPU-Speicher, der beim lokalen LLM oft zuerst limitiert.",
    faqQ3: "Sind die Werte gemessen oder geschätzt?",
    faqA3:
      "Verifizierte Profile nutzen Benchmark-Daten. Nicht verifizierte Profile nutzen katalogbasierte Baseline-Schätzungen."
  },
  ko: {
    title: "VRAM 계산기와 로컬 LLM 테스트 | LocalVRAM",
    description:
      "로컬 LLM에 필요한 VRAM을 계산하고 최소 VRAM, 최적 VRAM, RTX 3090 benchmark, cloud fallback을 비교합니다.",
    intro:
      "모델 프로필을 선택해 최소 VRAM, 최적 VRAM, RTX 3090 실측값, local 또는 cloud 결정을 확인합니다.",
    testTitle: "VRAM 테스트 방식",
    testStep1Title: "1. 모델 프로필 선택",
    testStep1Body: "계산기는 LocalVRAM 모델 카탈로그와 benchmark snapshot이 있는 최신 Ollama 모델을 우선합니다.",
    testStep2Title: "2. VRAM 요구량 확인",
    testStep2Body: "최소 VRAM은 실행 하한선이고 최적 VRAM은 안정적인 latency와 sustained throughput을 위한 목표입니다.",
    testStep3Title: "3. Local 또는 cloud 결정",
    testStep3Body: "프로필이 24GB VRAM을 넘으면 cloud 옵션을 우선 표시하고, 작은 프로필은 local hardware를 먼저 안내합니다.",
    faqTitle: "VRAM 계산기 FAQ",
    faqQ1: "VRAM이 충분한지 어떻게 테스트하나요?",
    faqA1: "모델 프로필을 고른 뒤 최소 VRAM, 최적 VRAM, 데이터 상태를 비교합니다. verified 프로필은 RTX 3090 실측값을 포함합니다.",
    faqQ2: "RAM 계산기와 VRAM 계산기는 무엇이 다른가요?",
    faqA2: "RAM은 시스템 메모리이고 VRAM은 GPU 메모리입니다. 로컬 LLM에서는 VRAM이 먼저 병목이 되는 경우가 많습니다.",
    faqQ3: "값은 측정인가요, 추정인가요?",
    faqA3: "verified 프로필은 benchmark 데이터를 사용하고, 나머지는 catalog baseline estimate를 사용합니다."
  }
};
const seoCopy = {
  title: text.meta_title,
  description: text.meta_description,
  intro: text.rollout_intro,
  testTitle: "How the VRAM test works",
  testStep1Title: "1. Choose a model profile",
  testStep1Body: "The calculator uses the LocalVRAM catalog and prioritizes current Ollama models with benchmark snapshots.",
  testStep2Title: "2. Read the VRAM envelope",
  testStep2Body: "Minimum VRAM is the lower bound. Optimal VRAM is the target for steadier latency and sustained throughput.",
  testStep3Title: "3. Decide local or cloud",
  testStep3Body: "Profiles above 24GB VRAM surface cloud options first. Smaller profiles point to local hardware paths.",
  faqTitle: "VRAM Calculator FAQ",
  faqQ1: "How do I test whether I have enough VRAM?",
  faqA1:
    "Choose the model profile and compare minimum VRAM, optimal VRAM, and data status. Verified profiles include real RTX 3090 measurements.",
  faqQ2: "What is the difference between a RAM calculator and a VRAM calculator?",
  faqA2:
    "RAM is system memory. VRAM is GPU memory, and it is often the first limit when running a local LLM.",
  faqQ3: "Are the values measured or estimated?",
  faqA3:
    "Verified profiles use benchmark data. Unverified profiles use catalog baseline estimates.",
  ...(seoCopyByLocale[locale] || {})
};

const allModels = Array.isArray(catalog.items) ? catalog.items : [];
const benchmarkMap = benchmarkResults.models || {};
const featuredModels = getFeaturedTestModels(allModels, benchmarkMap, newModelWatchlist.items);
const featuredIdSet = new Set(featuredModels.map((item) => item.id));
const sampleModels = [...allModels].sort((a, b) => {
  const aFeaturedIndex = featuredModels.findIndex((item) => item.id === a.id);
  const bFeaturedIndex = featuredModels.findIndex((item) => item.id === b.id);
  const aPriority = aFeaturedIndex === -1 ? 999 : aFeaturedIndex;
  const bPriority = bFeaturedIndex === -1 ? 999 : bFeaturedIndex;
  if (aPriority !== bPriority) {
    return aPriority - bPriority;
  }

  const aTag = String(a?.ollama_tag || "");
  const bTag = String(b?.ollama_tag || "");
  const aMeasured = aTag && benchmarkMap[aTag]?.status === "ok" ? 0 : 1;
  const bMeasured = bTag && benchmarkMap[bTag]?.status === "ok" ? 0 : 1;
  if (aMeasured !== bMeasured) {
    return aMeasured - bMeasured;
  }

  const aUpdated = Date.parse(String(a?.updated_at || "")) || 0;
  const bUpdated = Date.parse(String(b?.updated_at || "")) || 0;
  if (aUpdated !== bUpdated) {
    return bUpdated - aUpdated;
  }

  return String(a?.name || "").localeCompare(String(b?.name || ""));
});
const firstMeasuredModel = sampleModels.find((item) => {
  if (!item.ollama_tag) {
    return false;
  }
  const data = benchmarkMap[item.ollama_tag];
  return data && data.status === "ok" && typeof data.tokens_per_second === "number";
});
const pinnedModelId = featuredModels.find((item) => featuredIdSet.has(item.id))?.id || "";
const defaultModelId = pinnedModelId || firstMeasuredModel?.id || sampleModels[0]?.id || "";
const pageUrl = `https://localvram.com${pagePath}`;
const affiliateLocalPath = withLocale(locale, "/en/affiliate/hardware-upgrade/");
const affiliateCloudPath = withLocale(locale, "/en/affiliate/cloud-gpu/");
const faqItems = [
  { question: seoCopy.faqQ1, answer: seoCopy.faqA1 },
  { question: seoCopy.faqQ2, answer: seoCopy.faqA2 },
  { question: seoCopy.faqQ3, answer: seoCopy.faqA3 },
];
const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "LocalVRAM VRAM Calculator",
  applicationCategory: "DeveloperApplication",
  operatingSystem: "Web",
  url: pageUrl,
  inLanguage: locale,
  description: seoCopy.description,
};
const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: seoCopy.testTitle,
  description: seoCopy.intro,
  inLanguage: locale,
  step: [
    {
      "@type": "HowToStep",
      name: seoCopy.testStep1Title,
      text: seoCopy.testStep1Body,
    },
    {
      "@type": "HowToStep",
      name: seoCopy.testStep2Title,
      text: seoCopy.testStep2Body,
    },
    {
      "@type": "HowToStep",
      name: seoCopy.testStep3Title,
      text: seoCopy.testStep3Body,
    },
  ],
};
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  inLanguage: locale,
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};
---

<BaseLayout
  title={seoCopy.title}
  description={seoCopy.description}
  locale={locale}
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  noindex={shouldNoindex}
  structuredData={[softwareSchema, howToSchema, faqSchema]}
>
  <main class="container">
    <h1>{home.cta_start_vram || "VRAM Calculator"}</h1>
    <p>{seoCopy.intro}</p>

    <section class="card">
      <label for="model-select">{ui.model_profile}</label>
      <select id="model-select" class="input">
        {sampleModels.map((item) => (
          <option value={item.id} selected={item.id === defaultModelId}>{item.name}</option>
        ))}
      </select>
      <div id="calc-result" class="card" style="margin-top: 12px;" />
      <div class="card" style="margin-top: 12px;">
        <div class="card-head">
          <h2>{ui.performance_curve}</h2>
          <div class="cta-row card-head-actions">
            <a id="calc-primary" class="btn btn-primary" href={affiliateLocalPath}>{ui.check_local_upgrade}</a>
            <a id="calc-cloud-runpod" class="btn" href={links.runpod}>{ui.runpod_fallback}</a>
            <a id="calc-cloud-vast" class="btn" href={links.vast}>{ui.vast_fallback}</a>
          </div>
        </div>
        <div class="chart-wrap">
          <canvas id="calc-chart" aria-label={ui.hardware_chart_label}></canvas>
        </div>
      </div>
    </section>

    <section class="card-grid" style="margin-top: 16px;">
      <article class="card">
        <h2>{seoCopy.testStep1Title}</h2>
        <p>{seoCopy.testStep1Body}</p>
      </article>
      <article class="card">
        <h2>{seoCopy.testStep2Title}</h2>
        <p>{seoCopy.testStep2Body}</p>
      </article>
      <article class="card">
        <h2>{seoCopy.testStep3Title}</h2>
        <p>{seoCopy.testStep3Body}</p>
      </article>
    </section>

    <section class="card" style="margin-top: 16px;">
      <h2>{seoCopy.faqTitle}</h2>
      <dl class="faq-list">
        {faqItems.map((item) => (
          <>
            <dt>{item.question}</dt>
            <dd>{item.answer}</dd>
          </>
        ))}
      </dl>
    </section>
  </main>

  <script is:inline src="/js/performance-chart.js?v=20260625"></script>
  <script
    define:vars={{ items: sampleModels, benchmarkMap, defaultModelId, affiliateLocalPath, affiliateCloudPath, ui }}
  >
    const select = document.getElementById("model-select");
    const result = document.getElementById("calc-result");
    const chartCanvas = document.getElementById("calc-chart");
    const primary = document.getElementById("calc-primary");
    const runpod = document.getElementById("calc-cloud-runpod");
    const vast = document.getElementById("calc-cloud-vast");
    let destroyChart = null;

    const renderChart = (model, realData) => {
      if (!chartCanvas || !window.LocalVRAMCharts) {
        window.addEventListener("localvram:charts-ready", () => renderChart(model, realData), { once: true });
        return;
      }
      if (destroyChart) {
        destroyChart();
      }
      const hasMeasured = realData && realData.status === "ok" && typeof realData.tokens_per_second === "number";
      const datasets = [
        {
          label: `${model.name} baseline`,
          data: [model.benchmarks.rtx3090_tok_s, model.benchmarks.rtx4090_tok_s, model.benchmarks.a100_tok_s],
          borderColor: "#3b82f6",
          backgroundColor: "rgba(59,130,246,0.15)",
          borderWidth: 2
        }
      ];
      if (hasMeasured) {
        datasets.push({
          label: "Measured RTX 3090",
          data: [realData.tokens_per_second, null, null],
          borderColor: "#10b981",
          backgroundColor: "rgba(16,185,129,0.2)",
          borderWidth: 2,
          pointRadius: 5
        });
      }
      destroyChart = window.LocalVRAMCharts.renderLineChart(chartCanvas, {
        labels: ["RTX 3090", "RTX 4090", "A100 80GB"],
        datasets,
        yAxisLabel: "tokens/s"
      });
    };

    const renderView = () => {
      const model = items.find((item) => item.id === select.value) || items[0];
      const realData = model.ollama_tag ? benchmarkMap[model.ollama_tag] : null;
      const isMeasured = realData && realData.status === "ok" && typeof realData.tokens_per_second === "number";
      const realPerf = isMeasured ? `${realData.tokens_per_second.toFixed(1)} tok/s` : "N/A";
      const realTestTime = isMeasured ? realData.test_time : "N/A";
      const cloudFirst = model.vram_optimal_gb > 24;
      result.innerHTML = [
        `<h2 class="model-title">${model.name}${isMeasured ? ` <span class="verified-badge" title="${ui.verified_real}">${ui.verified_real}</span>` : ""}</h2>`,
        `<p>${ui.minimum_vram}: <strong>${model.vram_min_gb}GB</strong> | ${ui.optimal_vram}: <strong>${model.vram_optimal_gb}GB</strong></p>`,
        `<p>${ui.best_local}: ${model.best_local_gpu} | ${ui.cloud_fallback}: ${model.cloud_fallback}</p>`,
        `<p>${ui.catalog_baseline}: 3090 ${model.benchmarks.rtx3090_tok_s} tok/s, 4090 ${model.benchmarks.rtx4090_tok_s} tok/s</p>`,
        `<p>${ui.real_perf}: <strong>${realPerf}</strong> (${ui.test_time}: ${realTestTime})</p>`,
        `<p>${ui.data_status}: <strong>${isMeasured ? ui.verified_real : ui.estimated}</strong></p>`
      ].join("");

      primary.textContent = cloudFirst ? ui.open_cloud_options : ui.check_local_upgrade;
      primary.href = cloudFirst ? affiliateCloudPath : affiliateLocalPath;
      runpod.style.display = cloudFirst ? "inline-block" : "none";
      vast.style.display = cloudFirst ? "inline-block" : "none";
      renderChart(model, realData);
    };

    if (select && defaultModelId && select.value !== defaultModelId) {
      select.value = defaultModelId;
    }

    select.addEventListener("change", renderView);
    if (document.readyState === "complete") {
      renderView();
    } else {
      window.addEventListener("load", renderView, { once: true });
    }
  </script>
</BaseLayout>
