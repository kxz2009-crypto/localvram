---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../../data/root-alternates";
import { LOCALE_WAVE2, WAVE2_LOCALES, type Wave2Locale } from "../../../data/locale-wave2-copy";

export function getStaticPaths() {
  return WAVE2_LOCALES.map((locale) => ({
    params: { locale }
  }));
}

const localeParam = String(Astro.params.locale || "");
if (!Object.prototype.hasOwnProperty.call(LOCALE_WAVE2, localeParam)) {
  throw new Error(`Unsupported locale for benchmark changelog: ${localeParam}`);
}

const locale = localeParam as Wave2Locale;
const copy = LOCALE_WAVE2[locale];
const pagePath = `/${locale}/benchmarks/changelog/`;
const zhOrigin = (import.meta.env.PUBLIC_ZH_SITE_ORIGIN || "https://localvram.com").replace(/\/$/, "");
const siteOrigin = locale === "zh" ? zhOrigin : "https://localvram.com";
const pageUrl = `${siteOrigin}${pagePath}`;
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  headline: "Benchmark Changelog",
  inLanguage: locale,
  url: pageUrl
};
---

<BaseLayout
  title={`LocalVRAM ${locale.toUpperCase()} | Benchmark Changelog`}
  description="Date-stamped benchmark updates for hardware sync, runtime versions, and verified models."
  locale={locale}
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={articleSchema}
>
  <main class="container">
    <section class="card">
      <h1>Benchmark Changelog</h1>
      <p>Track what changed in verified runs, model routing, and freshness status each cycle.</p>
      <ul>
        <li>Hardware sync timestamp and GPU thermal snapshot.</li>
        <li>Model-level pass/fail and runtime updates.</li>
        <li>Fallback decisions for heavy workloads.</li>
      </ul>
      <div class="cta-row">
        <a class="btn btn-primary" href={`/${locale}/status/data-freshness/`}>Open Data Freshness</a>
        <a class="btn" href={`/${locale}/models/qwen35-35b-q4/`}>{copy.ctaModel35}</a>
        <a class="btn" href={`/${locale}/tools/vram-calculator/`}>{copy.ctaTool}</a>
      </div>
    </section>
  </main>
</BaseLayout>
