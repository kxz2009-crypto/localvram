---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../../data/root-alternates";
import { LOCALE_WAVE2, WAVE2_LOCALES, type Wave2Locale } from "../../../data/locale-wave2-copy";

export function getStaticPaths() {
  return WAVE2_LOCALES.map((locale) => ({
    params: { locale }
  }));
}

const localeParam = String(Astro.params.locale || "");
if (!Object.prototype.hasOwnProperty.call(LOCALE_WAVE2, localeParam)) {
  throw new Error(`Unsupported locale for benchmark hub: ${localeParam}`);
}

const locale = localeParam as Wave2Locale;
const copy = LOCALE_WAVE2[locale];
const pagePath = `/${locale}/benchmarks/`;
const zhOrigin = (import.meta.env.PUBLIC_ZH_SITE_ORIGIN || "https://localvram.com").replace(/\/$/, "");
const siteOrigin = locale === "zh" ? zhOrigin : "https://localvram.com";
const pageUrl = `${siteOrigin}${pagePath}`;
const pageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Benchmark Hub",
  inLanguage: locale,
  url: pageUrl
};
---

<BaseLayout
  title={`LocalVRAM ${locale.toUpperCase()} | Benchmark Hub`}
  description="Benchmark hub for changelog, freshness checks, and run health snapshots."
  locale={locale}
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={pageSchema}
>
  <main class="container">
    <section class="card">
      <h1>Benchmark Hub</h1>
      <p>Use this page to monitor update cadence and keep links to the latest benchmark context.</p>
      <div class="cta-row">
        <a class="btn btn-primary" href={`/${locale}/benchmarks/changelog/`}>Open Benchmark Changelog</a>
        <a class="btn" href={`/${locale}/status/data-freshness/`}>Open Data Freshness</a>
        <a class="btn" href={`/${locale}/status/pipeline-status/`}>Open Pipeline Status</a>
        <a class="btn" href={`/${locale}/models/qwen35-35b-q4/`}>{copy.ctaModel35}</a>
      </div>
    </section>
  </main>
</BaseLayout>
