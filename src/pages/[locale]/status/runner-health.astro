---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../../data/root-alternates";
import { LOCALE_WAVE2, WAVE2_LOCALES, type Wave2Locale } from "../../../data/locale-wave2-copy";

export function getStaticPaths() {
  return WAVE2_LOCALES.map((locale) => ({
    params: { locale }
  }));
}

const localeParam = String(Astro.params.locale || "");
if (!Object.prototype.hasOwnProperty.call(LOCALE_WAVE2, localeParam)) {
  throw new Error(`Unsupported locale for runner health: ${localeParam}`);
}

const locale = localeParam as Wave2Locale;
const copy = LOCALE_WAVE2[locale];
const pagePath = `/${locale}/status/runner-health/`;
const zhOrigin = (import.meta.env.PUBLIC_ZH_SITE_ORIGIN || "https://localvram.com").replace(/\/$/, "");
const siteOrigin = locale === "zh" ? zhOrigin : "https://localvram.com";
const pageUrl = `${siteOrigin}${pagePath}`;
const statusSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Runner Health",
  inLanguage: locale,
  url: pageUrl
};
---

<BaseLayout
  title={`LocalVRAM ${locale.toUpperCase()} | Runner Health`}
  description="Runner health status entry for scheduled jobs and benchmark execution reliability."
  locale={locale}
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={statusSchema}
>
  <main class="container">
    <section class="card">
      <h1>Runner Health</h1>
      <p>Monitor scheduling reliability and execution stability for benchmark and content agents.</p>
      <ul>
        <li>Runner queue latency and timeout trends.</li>
        <li>Retry and failover behavior for daily tasks.</li>
        <li>Escalation links when publish output drops to zero.</li>
      </ul>
      <div class="cta-row">
        <a class="btn btn-primary" href={`/${locale}/status/pipeline-status/`}>Open Pipeline Status</a>
        <a class="btn" href="/en/status/runner-health/">Global Runner Health (EN)</a>
        <a class="btn" href={`/${locale}/status/content-publish/`}>Content Publish Status</a>
        <a class="btn" href={`/${locale}/tools/vram-calculator/`}>{copy.ctaTool}</a>
      </div>
    </section>
  </main>
</BaseLayout>
