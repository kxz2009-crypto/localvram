---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../../data/root-alternates";
import { LOCALE_WAVE2, WAVE2_LOCALES, type Wave2Locale } from "../../../data/locale-wave2-copy";

export function getStaticPaths() {
  return WAVE2_LOCALES.map((locale) => ({
    params: { locale }
  }));
}

const localeParam = String(Astro.params.locale || "");
if (!Object.prototype.hasOwnProperty.call(LOCALE_WAVE2, localeParam)) {
  throw new Error(`Unsupported locale for submission review: ${localeParam}`);
}

const locale = localeParam as Wave2Locale;
const copy = LOCALE_WAVE2[locale];
const pagePath = `/${locale}/status/submission-review/`;
const zhOrigin = (import.meta.env.PUBLIC_ZH_SITE_ORIGIN || "https://localvram.com").replace(/\/$/, "");
const siteOrigin = locale === "zh" ? zhOrigin : "https://localvram.com";
const pageUrl = `${siteOrigin}${pagePath}`;
const statusSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Submission Review",
  inLanguage: locale,
  url: pageUrl
};
---

<BaseLayout
  title={`LocalVRAM ${locale.toUpperCase()} | Submission Review`}
  description="Submission review status entry for benchmark reports and community data quality."
  locale={locale}
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={statusSchema}
>
  <main class="container">
    <section class="card">
      <h1>Submission Review</h1>
      <p>Review the current state of incoming benchmark submissions and moderation pipeline.</p>
      <ul>
        <li>Pending submission volume and SLA status.</li>
        <li>Acceptance and rejection trend by issue type.</li>
        <li>Escalation path for repeated benchmark anomalies.</li>
      </ul>
      <div class="cta-row">
        <a class="btn btn-primary" href={`/${locale}/errors/`}>Open Error KB</a>
        <a class="btn" href={`/${locale}/status/content-publish/`}>Open Content Publish Status</a>
        <a class="btn" href="/en/status/submission-review/">Global Submission Review (EN)</a>
        <a class="btn" href={`/${locale}/tools/vram-calculator/`}>{copy.ctaTool}</a>
      </div>
    </section>
  </main>
</BaseLayout>
