---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../../data/root-alternates";
import { LOCALE_WAVE2, WAVE2_LOCALES, type Wave2Locale } from "../../../data/locale-wave2-copy";

export function getStaticPaths() {
  return WAVE2_LOCALES.map((locale) => ({
    params: { locale }
  }));
}

const localeParam = String(Astro.params.locale || "");
if (!Object.prototype.hasOwnProperty.call(LOCALE_WAVE2, localeParam)) {
  throw new Error(`Unsupported locale for pipeline status: ${localeParam}`);
}

const locale = localeParam as Wave2Locale;
const copy = LOCALE_WAVE2[locale];
const pagePath = `/${locale}/status/pipeline-status/`;
const zhOrigin = (import.meta.env.PUBLIC_ZH_SITE_ORIGIN || "https://localvram.com").replace(/\/$/, "");
const siteOrigin = locale === "zh" ? zhOrigin : "https://localvram.com";
const pageUrl = `${siteOrigin}${pagePath}`;
const statusSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Pipeline Status",
  inLanguage: locale,
  url: pageUrl
};
---

<BaseLayout
  title={`LocalVRAM ${locale.toUpperCase()} | Pipeline Status`}
  description="Pipeline status entry for benchmark, publish, and locale KPI workflows."
  locale={locale}
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={statusSchema}
>
  <main class="container">
    <section class="card">
      <h1>Pipeline Status</h1>
      <p>Track build and publish workflow health with a locale-specific entry point.</p>
      <ul>
        <li>Benchmark and publish workflow completion state.</li>
        <li>Locale KPI refresh cadence and stale-check guardrail.</li>
        <li>Alert path when daily output is zero.</li>
      </ul>
      <div class="cta-row">
        <a class="btn btn-primary" href={`/${locale}/status/data-freshness/`}>Open Data Freshness</a>
        <a class="btn" href={`/${locale}/benchmarks/changelog/`}>Open Benchmark Changelog</a>
        <a class="btn" href="/en/status/pipeline-status/">Global Pipeline Status (EN)</a>
        <a class="btn" href={`/${locale}/tools/vram-calculator/`}>{copy.ctaTool}</a>
      </div>
    </section>
  </main>
</BaseLayout>
