---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { STANDARD_I18N_LOCALES, type ComLocale } from "../../../config/i18n";
import updates from "../../../data/daily-updates.json";
import { ROOT_ALTERNATES } from "../../../data/root-alternates";
import { resolveBlogCopy } from "../../../lib/i18n-blog-copy";
import { resolvePageCopy } from "../../../lib/i18n-copy";
import { withLocale } from "../../../lib/locale-paths";

type UpdateCandidate = {
  keyword?: string;
  score?: number;
  landing?: string;
  source?: string;
  traffic_priority?: string;
};

type PublishedPost = {
  slug: string;
  title: string;
};

type DailyUpdate = {
  date: string;
  summary: string;
  candidates?: UpdateCandidate[];
  published_posts?: PublishedPost[];
  published_count?: number;
  publish_run_at?: string;
};

export function getStaticPaths() {
  return STANDARD_I18N_LOCALES.map((locale) => ({
    params: { locale },
    props: { locale },
  }));
}

const { locale } = Astro.props as { locale: ComLocale };
const home = resolvePageCopy("locale-home", locale, { localeUpper: locale.toUpperCase() }).fields;
const pagePath = withLocale(locale, "/en/updates/");
const allUpdates = updates.items as DailyUpdate[];
const latest = allUpdates[0];

const copyByLocale: Partial<Record<ComLocale, {
  title: string;
  description: string;
  heading: string;
  intro: string;
  latestLabel: string;
  publishedLabel: string;
  candidatesLabel: string;
  noCandidates: string;
  scoreLabel: string;
  openPost: string;
  runLabel: string;
}>> = {
  es: {
    title: "Actualizaciones diarias | LocalVRAM",
    description: "Feed diario de cambios de LocalVRAM para contenido, verificacion y prioridades SEO.",
    heading: "Actualizaciones diarias",
    intro: "Resumen operativo de lo que cambio cada dia: publicaciones, candidatos revisados y senales de frescura.",
    latestLabel: "Ultima ejecucion",
    publishedLabel: "Publicado",
    candidatesLabel: "Candidatos revisados",
    noCandidates: "Sin candidatos adicionales registrados para esta ejecucion.",
    scoreLabel: "puntuacion",
    openPost: "Abrir articulo",
    runLabel: "Ejecucion",
  },
  pt: {
    title: "Atualizacoes diarias | LocalVRAM",
    description: "Feed diario de alteracoes do LocalVRAM para conteudo, verificacao e prioridades de SEO.",
    heading: "Atualizacoes diarias",
    intro: "Resumo operacional do que mudou a cada dia: posts publicados, candidatos revisados e sinais de frescor.",
