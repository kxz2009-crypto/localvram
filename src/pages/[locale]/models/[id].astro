---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../../data/root-alternates";
import modelCatalog from "../../../data/model-catalog.json";
import { STANDARD_I18N_LOCALES, type ComLocale } from "../../../config/i18n";
import { withLocale } from "../../../lib/locale-paths";
import { resolvePageCopy, shouldNoindexByFallback } from "../../../lib/i18n-copy";

export function getStaticPaths() {
  const items = Array.isArray(modelCatalog?.items) ? modelCatalog.items : [];
  return STANDARD_I18N_LOCALES.flatMap((locale) =>
    items.map((item) => ({
      params: { locale, id: String(item?.id || "").trim() },
      props: { locale, item },
    })),
  );
}

const { locale, item } = Astro.props as { locale: ComLocale; item: Record<string, unknown> };
const modelId = String(item?.id || "").trim();
const modelName = String(item?.name || modelId || "Model");
const enPath = `/en/models/${modelId}/`;
const pagePath = withLocale(locale, enPath);
const pageUrl = `https://localvram.com${pagePath}`;
const minVram = Number(item?.vram_min_gb || 0);
const optimalVram = Number(item?.vram_optimal_gb || 0);
const updatedAt = String(item?.updated_at || "");
const ollamaTag = String(item?.ollama_tag || "").trim();
const relatedProfiles = (Array.isArray(modelCatalog?.items) ? modelCatalog.items : [])
  .filter((candidate) => {
    if (!candidate || typeof candidate !== "object") {
      return false;
    }
    return String(candidate?.id || "") !== modelId && String(candidate?.ollama_tag || "").trim() === ollamaTag;
  })
  .sort((a, b) => {
    const priority: Record<string, number> = { Q4: 0, Q5: 1, Q8: 2, FP16: 3, CLOUD: 4 };
    return (
      (priority[String(a?.quantization || "").toUpperCase()] ?? 9) -
      (priority[String(b?.quantization || "").toUpperCase()] ?? 9)
    );
  })
  .slice(0, 4);
const copy = resolvePageCopy("models-detail", locale, {
  localeUpper: locale.toUpperCase(),
  modelName,
  minVram,
  optimalVram,
});
const text = copy.fields;
const shouldNoindex = shouldNoindexByFallback(locale, copy.fallbackRatio);
const modelSchema = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  headline: `${modelName} VRAM Requirement and Benchmark`,
  description: String(text.meta_description || ""),
  dateModified: updatedAt || undefined,
  inLanguage: locale,
  url: pageUrl,
  mainEntityOfPage: pageUrl,
  author: {
    "@type": "Organization",
    name: "LocalVRAM",
  },
  about: {
    "@type": "SoftwareApplication",
    name: modelName,
    applicationCategory: "DeveloperApplication",
  },
};
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: `https://localvram.com/${locale}/`,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Models",
      item: `https://localvram.com${withLocale(locale, "/en/models/")}`,
    },
    {
      "@type": "ListItem",
      position: 3,
      name: modelName,
      item: pageUrl,
    },
  ],
};
const relatedProfilesSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: `${modelName} related LocalVRAM model profiles`,
  itemListElement: relatedProfiles.map((profile, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: String(profile?.name || profile?.id || ""),
    url: `https://localvram.com${withLocale(locale, `/en/models/${String(profile?.id || "").trim()}/`)}`,
  })),
};
const structuredData = relatedProfiles.length
  ? [modelSchema, breadcrumbSchema, relatedProfilesSchema]
  : [modelSchema, breadcrumbSchema];
---

<BaseLayout
  title={text.meta_title}
  description={text.meta_description}
  locale={locale}
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={structuredData}
  noindex={shouldNoindex}
>
  <main class="container">
    <section class="hero">
      <h1>{modelName}</h1>
      <p>{text.hero_intro}</p>
      <div class="kpi-row">
        <article class="kpi">
          <h3>{text.kpi_min_vram}</h3>
          <p>{minVram} GB</p>
        </article>
        <article class="kpi">
          <h3>{text.kpi_optimal_vram}</h3>
          <p>{optimalVram} GB</p>
        </article>
      </div>
      <div class="cta-row">
        <a class="btn" href={withLocale(locale, "/en/models/")}>{text.cta_back_hub}</a>
        <a class="btn" href={withLocale(locale, "/en/tools/vram-calculator/")}>{text.cta_open_vram}</a>
      </div>
    </section>
  </main>
</BaseLayout>
