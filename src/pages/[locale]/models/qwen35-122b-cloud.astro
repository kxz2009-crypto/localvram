---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../../data/root-alternates";
import { LOCALE_WAVE2, WAVE2_LOCALES, type Wave2Locale } from "../../../data/locale-wave2-copy";

export function getStaticPaths() {
  return WAVE2_LOCALES.map((locale) => ({
    params: { locale }
  }));
}

const localeParam = String(Astro.params.locale || "");
if (!Object.prototype.hasOwnProperty.call(LOCALE_WAVE2, localeParam)) {
  throw new Error(`Unsupported locale for wave2 model: ${localeParam}`);
}

const locale = localeParam as Wave2Locale;
const copy = LOCALE_WAVE2[locale];
const pagePath = `/${locale}/models/qwen35-122b-cloud/`;
const zhOrigin = (import.meta.env.PUBLIC_ZH_SITE_ORIGIN || "https://localvram.com").replace(/\/$/, "");
const siteOrigin = locale === "zh" ? zhOrigin : "https://localvram.com";
const pageUrl = `${siteOrigin}${pagePath}`;
const modelSchema = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  headline: copy.modelHeading,
  description: copy.modelDescription,
  inLanguage: locale,
  url: pageUrl,
  about: {
    "@type": "SoftwareApplication",
    name: "Qwen3.5 122B"
  }
};
---

<BaseLayout
  title={copy.modelTitle}
  description={copy.modelDescription}
  locale={locale}
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={modelSchema}
>
  <main class="container">
    <section class="card">
      <h1>{copy.modelHeading}</h1>
      <p>{copy.modelIntro}</p>
      <ul>
        <li>Typical deployment target: cloud GPU, with local fallback for smaller quantized variants.</li>
        <li>Risk control: track latency, throughput, and monthly cloud budget before scaling traffic.</li>
        <li>Conversion path: route evaluation through VRAM planning and cost guide before purchase decisions.</li>
      </ul>
      <div class="cta-row">
        <a class="btn btn-primary" href={`/${locale}/guides/ollama-vs-vllm-vram/`}>{copy.ctaRuntimeGuide}</a>
        <a class="btn" href={`/${locale}/guides/local-llm-cost-vs-cloud/`}>{copy.ctaCostGuide}</a>
        <a class="btn" href={`/${locale}/tools/vram-calculator/`}>{copy.ctaTool}</a>
      </div>
    </section>
  </main>
</BaseLayout>
