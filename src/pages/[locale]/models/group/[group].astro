---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import catalog from "../../../../data/model-catalog.json";
import { ROOT_ALTERNATES } from "../../../../data/root-alternates";
import { LOCALE_WAVE2, WAVE2_LOCALES, type Wave2Locale } from "../../../../data/locale-wave2-copy";

export function getStaticPaths() {
  return WAVE2_LOCALES.flatMap((locale) =>
    catalog.group_definitions.map((group) => ({
      params: { locale, group: group.id },
      props: { group }
    }))
  );
}

const localeParam = String(Astro.params.locale || "");
if (!Object.prototype.hasOwnProperty.call(LOCALE_WAVE2, localeParam)) {
  throw new Error(`Unsupported locale for localized model group: ${localeParam}`);
}

const locale = localeParam as Wave2Locale;
const copy = LOCALE_WAVE2[locale];
const { group } = Astro.props;
if (!group || !group.id) {
  throw new Error("Missing group payload for localized model group page.");
}

const items = catalog.items
  .filter((item) => item.license_scope === group.id || item.size_class === group.id || item.scenario === group.id)
  .sort((a, b) => b.params_b - a.params_b || a.name.localeCompare(b.name));

const pagePath = `/${locale}/models/group/${group.id}/`;
const zhOrigin = (import.meta.env.PUBLIC_ZH_SITE_ORIGIN || "https://localvram.com").replace(/\/$/, "");
const siteOrigin = locale === "zh" ? zhOrigin : "https://localvram.com";
const pageUrl = `${siteOrigin}${pagePath}`;
const pageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: `${group.label} models`,
  inLanguage: locale,
  url: pageUrl
};
---

<BaseLayout
  title={`${group.label} | LocalVRAM ${locale.toUpperCase()}`}
  description={`${group.label}: localized model list with VRAM and fallback path.`}
  locale={locale}
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={pageSchema}
>
  <main class="container">
    <h1>{group.label}</h1>
    <p>{items.length} profiles in this group.</p>

    <section class="card">
      <table class="table">
        <thead>
          <tr>
            <th>Model</th>
            <th>VRAM min</th>
            <th>VRAM optimal</th>
            <th>Cloud fallback</th>
            <th>Detail</th>
          </tr>
        </thead>
        <tbody>
          {items.map((item) => (
            <tr>
              <td>{item.name}</td>
              <td>{item.vram_min_gb}GB</td>
              <td>{item.vram_optimal_gb}GB</td>
              <td>{item.cloud_fallback}</td>
              <td><a class="btn" href={`/${locale}/models/${item.id}/`}>Open</a></td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    <section class="cta-row">
      <a class="btn" href={`/${locale}/models/`}>Back to model catalog</a>
      <a class="btn" href={`/${locale}/tools/vram-calculator/`}>{copy.ctaTool}</a>
      <a class="btn btn-primary" href={`/${locale}/guides/local-llm-cost-vs-cloud/`}>{copy.ctaCostGuide}</a>
    </section>
  </main>
</BaseLayout>
