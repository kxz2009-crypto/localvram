---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../../../data/root-alternates";
import modelCatalog from "../../../../data/model-catalog.json";
import { STANDARD_I18N_LOCALES, type ComLocale } from "../../../../config/i18n";
import { withLocale } from "../../../../lib/locale-paths";
import { resolvePageCopy, shouldNoindexByFallback } from "../../../../lib/i18n-copy";

export function getStaticPaths() {
  const groups = Array.isArray(modelCatalog?.group_definitions) ? modelCatalog.group_definitions : [];
  return STANDARD_I18N_LOCALES.flatMap((locale) =>
    groups.map((group) => ({
      params: { locale, group: String(group?.id || "").trim() },
      props: { locale, group },
    })),
  );
}

const { locale, group } = Astro.props as { locale: ComLocale; group: Record<string, unknown> };
const groupId = String(group?.id || "").trim();
const groupName = String(group?.label || group?.name || groupId || "Model Group");
const enPath = `/en/models/group/${groupId}/`;
const pagePath = withLocale(locale, enPath);
const copy = resolvePageCopy("models-group", locale, {
  localeUpper: locale.toUpperCase(),
  groupName,
});
const text = copy.fields;
const shouldNoindex = shouldNoindexByFallback(locale, copy.fallbackRatio);
const items = (Array.isArray(modelCatalog?.items) ? modelCatalog.items : [])
  .filter((item) => item?.license_scope === groupId || item?.size_class === groupId || item?.scenario === groupId)
  .sort((a, b) => Number(b?.params_b || 0) - Number(a?.params_b || 0) || String(a?.name || "").localeCompare(String(b?.name || "")));
const featuredItems = items.slice(0, 24);
const measuredCount = items.filter((item) => item?.data_status === "measured").length;
const curatedCount = items.filter((item) => Boolean(item?.is_top20_curated)).length;
const pageDescriptionByLocale: Partial<Record<ComLocale, string>> = {
  de: `${groupName}-Modelle nach VRAM-Bedarf, Quantisierung, Lizenz und praktischer Hardware-Passung vergleichen.`,
  ko: `${groupName} 모델을 VRAM 요구량, 양자화, 라이선스, 실제 하드웨어 적합성으로 비교합니다.`,
};
const pageIntroByLocale: Partial<Record<ComLocale, string>> = {
  de: `Vergleichen Sie ${groupName}-Modelle mit VRAM-Schätzungen, Quantisierungs-Hinweisen und direkten Links zu den Detailseiten.`,
  ko: `${groupName} 모델을 VRAM 추정치, 양자화 힌트, 상세 모델 페이지 링크와 함께 비교하세요.`,
};
const labelsByLocale: Partial<Record<ComLocale, Record<string, string>>> = {
  de: {
    curated: "Ausgewählt",
    measured: "Gemessen",
    models: "Modelle",
    noModels: "Für diese Gruppe sind noch keine Modelle im Katalog verfügbar.",
    openModel: "Modelldetails",
    quantization: "Quantisierung",
    scenario: "Szenario",
    tag: "Tag",
    vram: "VRAM",
    dataFreshness: "Datenfrische",
  },
  ko: {
    curated: "추천",
    measured: "측정됨",
    models: "모델",
    noModels: "이 그룹에는 아직 카탈로그 모델이 없습니다.",
    openModel: "모델 상세",
    quantization: "양자화",
    scenario: "시나리오",
    tag: "태그",
    vram: "VRAM",
    dataFreshness: "데이터 최신성",
  },
};
const labels = labelsByLocale[locale] || {
  curated: "Curated",
  measured: "Measured",
  models: "Models",
  noModels: "No catalog models are available for this group yet.",
  openModel: "Model details",
  quantization: "Quantization",
  scenario: "Scenario",
  tag: "Tag",
  vram: "VRAM",
  dataFreshness: "Data freshness",
};
const pageDescription =
  pageDescriptionByLocale[locale] || `Compare ${groupName} models by VRAM requirement, quantization, license, and practical hardware fit.`;
const pageIntro = pageIntroByLocale[locale] || pageDescription;
const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: text.meta_title,
  url: `https://localvram.com${pagePath}`,
  inLanguage: locale,
  description: pageDescription,
  mainEntity: {
    "@type": "ItemList",
    name: groupName,
    numberOfItems: items.length,
    itemListElement: items.slice(0, 30).map((item, index) => {
      const id = String(item?.id || "").trim();
      const modelPath = withLocale(locale, `/en/models/${id}/`);
      return {
        "@type": "ListItem",
        position: index + 1,
        name: String(item?.name || id),
        url: `https://localvram.com${modelPath}`,
      };
    }),
  },
};
---

<BaseLayout
  title={text.meta_title}
  description={pageDescription}
  locale={locale}
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  noindex={shouldNoindex}
  structuredData={structuredData}
>
  <main class="container">
    <section class="hero">
      <h1>{groupName}</h1>
      <p>{pageIntro}</p>
      <div class="cta-row">
        <a class="btn" href={withLocale(locale, "/en/models/")}>{text.cta_back_hub}</a>
        <a class="btn" href={withLocale(locale, "/en/tools/vram-calculator/")}>{text.cta_open_vram}</a>
        <a class="btn btn-secondary" href={withLocale(locale, "/en/status/data-freshness/")}>{labels.dataFreshness}</a>
      </div>
    </section>

    <section class="kpi-row">
      <article class="kpi">
        <h3>{labels.models}</h3>
        <p>{items.length}</p>
      </article>
      <article class="kpi">
        <h3>{labels.measured}</h3>
        <p>{measuredCount}</p>
      </article>
      <article class="kpi">
        <h3>{labels.curated}</h3>
        <p>{curatedCount}</p>
      </article>
    </section>

    <section class="model-grid" aria-label={groupName}>
      {featuredItems.length > 0 ? (
        featuredItems.map((item) => {
            const id = String(item?.id || "").trim();
            const modelPath = withLocale(locale, `/en/models/${id}/`);
            const vram = [item?.vram_min_gb, item?.vram_optimal_gb]
              .filter((value) => value !== undefined && value !== null && String(value).trim() !== "")
              .join(" / ");
            return (
              <article class="model-card">
                <div>
                  <p class="eyebrow">{item?.data_status === "measured" ? labels.measured : labels.curated}</p>
                  <h2>{String(item?.name || id)}</h2>
                </div>
                <dl>
                  <div>
                    <dt>{labels.vram}</dt>
                    <dd>{vram ? `${vram} GB` : "-"}</dd>
                  </div>
                  <div>
                    <dt>{labels.quantization}</dt>
                    <dd>{String(item?.quantization || "-")}</dd>
                  </div>
                  <div>
                    <dt>{labels.scenario}</dt>
                    <dd>{String(item?.scenario || "-")}</dd>
                  </div>
                  <div>
                    <dt>{labels.tag}</dt>
                    <dd>{String(item?.ollama_tag || id)}</dd>
                  </div>
                </dl>
                <a class="text-link" href={modelPath}>{labels.openModel}</a>
              </article>
            );
          })
      ) : (
        <article class="model-card">
          <h2>{groupName}</h2>
          <p>{labels.noModels}</p>
        </article>
      )}
    </section>
  </main>
</BaseLayout>
