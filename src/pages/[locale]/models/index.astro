---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import catalog from "../../../data/model-catalog.json";
import { ROOT_ALTERNATES } from "../../../data/root-alternates";
import { LOCALE_WAVE2, WAVE2_LOCALES, type Wave2Locale } from "../../../data/locale-wave2-copy";

export function getStaticPaths() {
  return WAVE2_LOCALES.map((locale) => ({
    params: { locale }
  }));
}

const localeParam = String(Astro.params.locale || "");
if (!Object.prototype.hasOwnProperty.call(LOCALE_WAVE2, localeParam)) {
  throw new Error(`Unsupported locale for localized models index: ${localeParam}`);
}

const locale = localeParam as Wave2Locale;
const copy = LOCALE_WAVE2[locale];
const pagePath = `/${locale}/models/`;
const zhOrigin = (import.meta.env.PUBLIC_ZH_SITE_ORIGIN || "https://localvram.com").replace(/\/$/, "");
const siteOrigin = locale === "zh" ? zhOrigin : "https://localvram.com";
const pageUrl = `${siteOrigin}${pagePath}`;
const featured = [...catalog.items].sort((a, b) => b.params_b - a.params_b).slice(0, 10);
const pageSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Localized Model Catalog",
  inLanguage: locale,
  url: pageUrl,
  mainEntity: {
    "@type": "ItemList",
    numberOfItems: catalog.count
  }
};
---

<BaseLayout
  title={`LocalVRAM ${locale.toUpperCase()} | Model Catalog`}
  description="Localized model catalog with VRAM requirements, benchmark anchors, and local-cloud recommendations."
  locale={locale}
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={pageSchema}
>
  <main class="container">
    <h1>Model Catalog ({catalog.count})</h1>
    <p>Use this locale hub to navigate model groups and open profile pages with VRAM and cost anchors.</p>

    <section class="card-grid">
      {catalog.group_definitions.map((group) => (
        <article class="card">
          <h2>{group.label}</h2>
          <a class="btn btn-primary" href={`/${locale}/models/group/${group.id}/`}>Open group</a>
        </article>
      ))}
    </section>

    <section class="card">
      <h2>Featured high-demand profiles</h2>
      <table class="table">
        <thead>
          <tr>
            <th>Model</th>
            <th>VRAM min</th>
            <th>VRAM optimal</th>
            <th>Profile</th>
          </tr>
        </thead>
        <tbody>
          {featured.map((item) => (
            <tr>
              <td>{item.name}</td>
              <td>{item.vram_min_gb}GB</td>
              <td>{item.vram_optimal_gb}GB</td>
              <td><a class="btn" href={`/${locale}/models/${item.id}/`}>Open</a></td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    <section class="cta-row">
      <a class="btn btn-primary" href={`/${locale}/tools/vram-calculator/`}>{copy.ctaTool}</a>
      <a class="btn" href={`/${locale}/benchmarks/`}>Open Benchmark Hub</a>
      <a class="btn" href={`/${locale}/status/data-freshness/`}>Open Data Freshness</a>
    </section>
  </main>
</BaseLayout>
