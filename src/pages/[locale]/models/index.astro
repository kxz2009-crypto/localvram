---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../../data/root-alternates";
import modelCatalog from "../../../data/model-catalog.json";
import { STANDARD_I18N_LOCALES, type ComLocale } from "../../../config/i18n";
import { withLocale } from "../../../lib/locale-paths";
import { resolvePageCopy, shouldNoindexByFallback } from "../../../lib/i18n-copy";

export function getStaticPaths() {
  return STANDARD_I18N_LOCALES.map((locale) => ({
    params: { locale },
    props: { locale },
  }));
}

const { locale } = Astro.props as { locale: ComLocale };
const pagePath = `/${locale}/models/`;
const items = Array.isArray(modelCatalog?.items) ? modelCatalog.items : [];
const groupDefs = Array.isArray(modelCatalog?.group_definitions) ? modelCatalog.group_definitions : [];
const copy = resolvePageCopy("models-index", locale, { localeUpper: locale.toUpperCase() });
const home = resolvePageCopy("locale-home", locale, { localeUpper: locale.toUpperCase() }).fields;
const text = copy.fields;
const shouldNoindex = shouldNoindexByFallback(locale, copy.fallbackRatio);
const catalogDescriptionByLocale: Partial<Record<ComLocale, string>> = {
  de: "Durchsuche lokale LLM-Modelle nach VRAM-Bedarf, Workload, Lizenz und praktischer Hardware-Passung.",
  ko: "VRAM 요구량, 워크로드, 라이선스, 실제 하드웨어 적합성별로 로컬 LLM 모델을 탐색합니다.",
};
const pageDescription =
  catalogDescriptionByLocale[locale] ||
  home.card_model_hub_desc ||
  "Browse local LLM model profiles by VRAM requirement, workload, license, and hardware fit.";
const measuredLabelByLocale: Partial<Record<ComLocale, string>> = {
  de: "Gemessene Profile",
  ko: "측정된 프로필",
};
const curatedLabelByLocale: Partial<Record<ComLocale, string>> = {
  de: "Kuratierte Modelle",
  ko: "선별 모델",
};
const modelsLabelByLocale: Partial<Record<ComLocale, string>> = {
  de: "Modelle",
  ko: "모델",
};
const groupsLabelByLocale: Partial<Record<ComLocale, string>> = {
  de: "Gruppen",
  ko: "그룹",
};
const itemColumnLabelByLocale: Partial<Record<ComLocale, string>> = {
  de: "Modell",
  ko: "모델",
};
const detailColumnLabelByLocale: Partial<Record<ComLocale, string>> = {
  de: "Details",
  ko: "상세",
};
const openModelLabelByLocale: Partial<Record<ComLocale, string>> = {
  de: "Profil öffnen",
  ko: "프로필 열기",
};
const measuredLabel = measuredLabelByLocale[locale] || "Measured profiles";
const curatedLabel = curatedLabelByLocale[locale] || "Curated models";
const modelsLabel = modelsLabelByLocale[locale] || text.kpi_models || "Models";
const groupsLabel = groupsLabelByLocale[locale] || text.kpi_groups || "Groups";
const itemColumnLabel = itemColumnLabelByLocale[locale] || text.table_col_item || "Item";
const detailColumnLabel = detailColumnLabelByLocale[locale] || "Details";
const openModelLabel = openModelLabelByLocale[locale] || "Open profile";
const measuredCount = items.filter((item) => item?.data_status === "measured").length;
const groupCount = (groupId: string) =>
  items.filter(
    (item) =>
      item?.license_scope === groupId ||
      item?.size_class === groupId ||
      item?.scenario === groupId,
  ).length;
const featuredGroups = [...groupDefs]
  .map((group) => ({ ...group, modelCount: groupCount(String(group?.id || "")) }))
  .sort((a, b) => Number(b.modelCount || 0) - Number(a.modelCount || 0))
  .slice(0, 12);
const curatedQ4 = items
  .filter((item) => item?.is_top20_curated && item?.quantization === "Q4")
  .sort((a, b) => Number(a?.top20_rank || 999) - Number(b?.top20_rank || 999));
const featuredModels = (curatedQ4.length ? curatedQ4 : items).slice(0, 20);
const actionLinks = [
  {
    href: withLocale(locale, "/en/tools/vram-calculator/"),
    label: home.cta_start_vram || "VRAM Calculator",
  },
  {
    href: withLocale(locale, "/en/matrix/"),
    label: home.cta_compat_matrix || "Compatibility Matrix",
  },
  {
    href: withLocale(locale, "/en/status/data-freshness/"),
    label: home.cta_data_freshness || "Data Freshness",
  },
];
const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: text.meta_title,
  url: `https://localvram.com${pagePath}`,
  inLanguage: locale,
  description: pageDescription,
  mainEntity: {
    "@type": "ItemList",
    numberOfItems: items.length,
    itemListElement: [
      ...featuredGroups.map((group, index) => {
        const id = String(group?.id || "").trim();
        const enPath = `/en/models/group/${id}/`;
        return {
          "@type": "ListItem",
          position: index + 1,
          name: String(group?.label || group?.name || id),
          url: `https://localvram.com${withLocale(locale, enPath)}`,
        };
      }),
      ...featuredModels.map((item, index) => {
        const id = String(item?.id || "").trim();
        const enPath = `/en/models/${id}/`;
        return {
          "@type": "ListItem",
          position: featuredGroups.length + index + 1,
          name: String(item?.name || id),
          url: `https://localvram.com${withLocale(locale, enPath)}`,
        };
      }),
    ],
  },
};
---

<BaseLayout
  title={text.meta_title}
  description={pageDescription}
  locale={locale}
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  noindex={shouldNoindex}
  structuredData={structuredData}
>
  <main class="container">
    <section class="hero">
      <h1>{text.hero_title}</h1>
      <p>{pageDescription}</p>
      <div class="cta-row">
        <a class="btn btn-primary" href={withLocale(locale, "/en/")}>{text.cta_back_home}</a>
        {actionLinks.map((link) => (
          <a class="btn" href={link.href}>{link.label}</a>
        ))}
      </div>
    </section>

    <section class="kpi-row">
      <article class="kpi">
        <h3>{modelsLabel}</h3>
        <p>{items.length}</p>
      </article>
      <article class="kpi">
        <h3>{groupsLabel}</h3>
        <p>{groupDefs.length}</p>
      </article>
      <article class="kpi">
        <h3>{measuredLabel}</h3>
        <p>{measuredCount}</p>
      </article>
      <article class="kpi">
        <h3>{curatedLabel}</h3>
        <p>{featuredModels.length}</p>
      </article>
    </section>

    <section>
      <h2>{groupsLabel}</h2>
      <div class="group-grid">
        {featuredGroups.map((group) => {
          const id = String(group?.id || "").trim();
          const label = String(group?.label || group?.name || id);
          const localizedPath = withLocale(locale, `/en/models/group/${id}/`);
          return (
            <article class="group-card">
              <h3>{label}</h3>
              <p>{group.modelCount} {modelsLabel}</p>
              <a class="btn btn-primary" href={localizedPath}>{label}</a>
            </article>
          );
        })}
      </div>
    </section>

    <section class="table-card">
      <h2>{modelsLabel}</h2>
      <table>
        <thead>
          <tr>
            <th>{itemColumnLabel}</th>
            <th>VRAM</th>
            <th>Tag</th>
            <th>{detailColumnLabel}</th>
          </tr>
        </thead>
        <tbody>
          {featuredModels.map((item) => {
            const id = String(item?.id || "").trim();
            const enPath = `/en/models/${id}/`;
            const localizedPath = withLocale(locale, enPath);
            return (
              <tr>
                <td>{String(item?.name || id)}</td>
                <td>{item?.vram_min_gb}GB / {item?.vram_optimal_gb}GB</td>
                <td><code>{item?.ollama_tag || "-"}</code></td>
                <td><a class="btn" href={localizedPath}>{openModelLabel}</a></td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </section>
  </main>
</BaseLayout>
