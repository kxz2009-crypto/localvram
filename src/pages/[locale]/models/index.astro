---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../../data/root-alternates";
import modelCatalog from "../../../data/model-catalog.json";
import { STANDARD_I18N_LOCALES, type ComLocale } from "../../../config/i18n";
import { withLocale } from "../../../lib/locale-paths";

export function getStaticPaths() {
  return STANDARD_I18N_LOCALES.map((locale) => ({
    params: { locale },
    props: { locale },
  }));
}

const { locale } = Astro.props as { locale: ComLocale };
const pagePath = `/${locale}/models/`;
const items = Array.isArray(modelCatalog?.items) ? modelCatalog.items : [];
const groupDefs = Array.isArray(modelCatalog?.group_definitions) ? modelCatalog.group_definitions : [];
---

<BaseLayout
  title={`LocalVRAM (${locale.toUpperCase()}) Model Catalog`}
  description="Localized model catalog route skeleton with slug parity to English model pages."
  locale={locale}
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  noindex={true}
>
  <main class="container">
    <section class="hero">
      <h1>Model Catalog ({locale.toUpperCase()})</h1>
      <p>
        Model routes and group routes are staged for locale parity. Full translated model metadata is planned in
        later rollout.
      </p>
      <div class="cta-row">
        <a class="btn btn-primary" href={withLocale(locale, "/en/")}>Back to Locale Home</a>
        <a class="btn" href="/en/models/">Open English Model Catalog</a>
      </div>
    </section>

    <section class="kpi-row">
      <article class="kpi">
        <h3>Models</h3>
        <p>{items.length}</p>
      </article>
      <article class="kpi">
        <h3>Groups</h3>
        <p>{groupDefs.length}</p>
      </article>
    </section>

    <section class="table-card">
      <table>
        <thead>
          <tr>
            <th>Resource</th>
            <th>Localized Path</th>
            <th>English Source</th>
          </tr>
        </thead>
        <tbody>
          {groupDefs.slice(0, 12).map((group) => {
            const id = String(group?.id || "").trim();
            const enPath = `/en/models/group/${id}/`;
            const localizedPath = withLocale(locale, enPath);
            return (
              <tr>
                <td>Group: {id}</td>
                <td><a href={localizedPath}>{localizedPath}</a></td>
                <td><a href={enPath}>{enPath}</a></td>
              </tr>
            );
          })}
          {items.slice(0, 20).map((item) => {
            const id = String(item?.id || "").trim();
            const enPath = `/en/models/${id}/`;
            const localizedPath = withLocale(locale, enPath);
            return (
              <tr>
                <td>Model: {id}</td>
                <td><a href={localizedPath}>{localizedPath}</a></td>
                <td><a href={enPath}>{enPath}</a></td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </section>
  </main>
</BaseLayout>

