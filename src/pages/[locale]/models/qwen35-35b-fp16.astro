---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../../data/root-alternates";
import { LOCALE_WAVE2, WAVE2_LOCALES, type Wave2Locale } from "../../../data/locale-wave2-copy";

export function getStaticPaths() {
  return WAVE2_LOCALES.map((locale) => ({
    params: { locale }
  }));
}

const localeParam = String(Astro.params.locale || "");
if (!Object.prototype.hasOwnProperty.call(LOCALE_WAVE2, localeParam)) {
  throw new Error(`Unsupported locale for qwen35-35b-fp16: ${localeParam}`);
}

const locale = localeParam as Wave2Locale;
const copy = LOCALE_WAVE2[locale];
const pagePath = `/${locale}/models/qwen35-35b-fp16/`;
const zhOrigin = (import.meta.env.PUBLIC_ZH_SITE_ORIGIN || "https://localvram.com").replace(/\/$/, "");
const siteOrigin = locale === "zh" ? zhOrigin : "https://localvram.com";
const pageUrl = `${siteOrigin}${pagePath}`;
const modelSchema = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  headline: "Qwen3.5 35B FP16 deployment checklist",
  inLanguage: locale,
  url: pageUrl
};
---

<BaseLayout
  title={`LocalVRAM ${locale.toUpperCase()} | Qwen3.5 35B FP16`}
  description="FP16 path for Qwen3.5 35B with strict VRAM checks and cloud fallback."
  locale={locale}
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={modelSchema}
>
  <main class="container">
    <section class="card">
      <h1>Qwen3.5 35B FP16</h1>
      <p>Use this page when you need higher quality than Q4/Q5 and can tolerate higher VRAM demand.</p>
      <ul>
        <li>Recommend strict VRAM budgeting before loading FP16 weights.</li>
        <li>Use quantization blind test to verify if FP16 gain is meaningful.</li>
        <li>Fallback to cloud path when local memory pressure is unstable.</li>
      </ul>
      <div class="cta-row">
        <a class="btn btn-primary" href={`/${locale}/tools/vram-calculator/`}>{copy.ctaTool}</a>
        <a class="btn" href={`/${locale}/models/qwen35-35b-q4/`}>{copy.ctaModel35}</a>
        <a class="btn" href={`/${locale}/models/qwen35-122b-cloud/`}>{copy.ctaModel122}</a>
      </div>
    </section>
  </main>
</BaseLayout>
