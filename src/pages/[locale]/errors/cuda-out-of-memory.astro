---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../../data/root-alternates";
import { LOCALE_WAVE2, WAVE2_LOCALES, type Wave2Locale } from "../../../data/locale-wave2-copy";

export function getStaticPaths() {
  return WAVE2_LOCALES.map((locale) => ({
    params: { locale }
  }));
}

const localeParam = String(Astro.params.locale || "");
if (!Object.prototype.hasOwnProperty.call(LOCALE_WAVE2, localeParam)) {
  throw new Error(`Unsupported locale for error page: ${localeParam}`);
}

const locale = localeParam as Wave2Locale;
const copy = LOCALE_WAVE2[locale];
const pagePath = `/${locale}/errors/cuda-out-of-memory/`;
const zhOrigin = (import.meta.env.PUBLIC_ZH_SITE_ORIGIN || "https://localvram.com").replace(/\/$/, "");
const siteOrigin = locale === "zh" ? zhOrigin : "https://localvram.com";
const pageUrl = `${siteOrigin}${pagePath}`;
const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: "Fix Ollama CUDA Out of Memory",
  inLanguage: locale,
  url: pageUrl,
  step: [
    {
      "@type": "HowToStep",
      name: "Lower quantization",
      text: "ollama pull <model>:q4_k_m"
    },
    {
      "@type": "HowToStep",
      name: "Reduce context size",
      text: "ollama run <model> --ctx-size 4096"
    },
    {
      "@type": "HowToStep",
      name: "Reduce GPU layers",
      text: "ollama run <model> --gpu-layers 40"
    }
  ]
};
---

<BaseLayout
  title={`LocalVRAM ${locale.toUpperCase()} | CUDA Out of Memory Fix`}
  description="Fast copy-fix workflow for Ollama CUDA out of memory errors."
  locale={locale}
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={howToSchema}
>
  <main class="container">
    <h1>Ollama CUDA Out of Memory</h1>
    <p>Model loading fails or generation stops because VRAM budget is exceeded.</p>

    <section class="card terminal-card">
      <h2>Copy-fix commands</h2>
      <pre><code>{`ollama pull <model>:q4_k_m
ollama run <model> --ctx-size 4096
ollama run <model> --gpu-layers 40`}</code></pre>
    </section>

    <section class="cta-row">
      <a class="btn btn-primary" href={`/${locale}/tools/vram-calculator/`}>{copy.ctaTool}</a>
      <a class="btn" href={`/${locale}/models/qwen35-35b-q4/`}>{copy.ctaModel35}</a>
      <a class="btn" href={`/${locale}/models/qwen35-122b-cloud/`}>{copy.ctaModel122}</a>
    </section>
  </main>
</BaseLayout>
