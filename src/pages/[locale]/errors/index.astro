---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../../data/root-alternates";
import errorData from "../../../data/errors.json";
import { STANDARD_I18N_LOCALES, type ComLocale } from "../../../config/i18n";
import { withLocale } from "../../../lib/locale-paths";
import { resolvePageCopy, shouldNoindexByFallback } from "../../../lib/i18n-copy";

export function getStaticPaths() {
  return STANDARD_I18N_LOCALES.map((locale) => ({
    params: { locale },
    props: { locale },
  }));
}

const { locale } = Astro.props as { locale: ComLocale };
const pagePath = `/${locale}/errors/`;
const errorItems = Array.isArray(errorData?.errors) ? errorData.errors : [];
const copy = resolvePageCopy("errors-index", locale, { localeUpper: locale.toUpperCase() });
const text = copy.fields;
const shouldNoindex = shouldNoindexByFallback(locale, copy.fallbackRatio);
const localizedItems = errorItems.map((item) => {
  const id = String(item?.id || "").trim();
  const enPath = `/en/errors/${id}/`;
  return {
    id,
    title: String(item?.title || id),
    enPath,
    localizedPath: withLocale(locale, enPath),
  };
});
const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: text.meta_title,
  url: `https://localvram.com${pagePath}`,
  inLanguage: locale,
  description: text.meta_description,
  mainEntity: {
    "@type": "ItemList",
    numberOfItems: localizedItems.length,
    itemListElement: localizedItems.map((item, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: item.title,
      url: `https://localvram.com${item.localizedPath}`,
    })),
  },
};
---

<BaseLayout
  title={text.meta_title}
  description={text.meta_description}
  locale={locale}
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  noindex={shouldNoindex}
  structuredData={structuredData}
>
  <main class="container">
    <section class="hero">
      <h1>{text.hero_title}</h1>
      <p>{text.hero_intro}</p>
      <div class="cta-row">
        <a class="btn btn-primary" href={withLocale(locale, "/en/")}>{text.cta_back_home}</a>
      </div>
    </section>

    <section class="table-card">
      <table>
        <thead>
          <tr>
            <th>{text.table_col_item}</th>
            <th>{text.table_col_localized_path}</th>
            <th>{text.table_col_en_source}</th>
          </tr>
        </thead>
        <tbody>
          {localizedItems.map((item) => {
            return (
              <tr>
                <td>{item.title}</td>
                <td><a href={item.localizedPath}>{item.localizedPath}</a></td>
                <td><code>{item.enPath}</code></td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </section>
  </main>
</BaseLayout>
