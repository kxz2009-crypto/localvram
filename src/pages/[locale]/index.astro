---
import BaseLayout from "../../layouts/BaseLayout.astro";
import runnerStatus from "../../data/runner-status.json";
import statusReport from "../../data/status.json";
import { ROOT_ALTERNATES } from "../../data/root-alternates";
import { STANDARD_I18N_LOCALES, type ComLocale } from "../../config/i18n";
import { withLocale } from "../../lib/locale-paths";
import { resolvePageCopy, shouldNoindexByFallback } from "../../lib/i18n-copy";

export function getStaticPaths() {
  return STANDARD_I18N_LOCALES.map((locale) => ({
    params: { locale },
    props: { locale },
  }));
}

const { locale } = Astro.props as { locale: ComLocale };
const pagePath = `/${locale}/`;
const copy = resolvePageCopy("locale-home", locale, { localeUpper: locale.toUpperCase() });
const text = copy.fields;
const shouldNoindex = shouldNoindexByFallback(locale, copy.fallbackRatio);

const ollamaVersion = String(runnerStatus?.api?.version?.version || "unknown");
const rawLastSync = String(statusReport.last_hardware_sync || statusReport.last_verified || "unknown");
const rawGpuTemperature = Number(statusReport.latest_gpu_temperature_c);

function formatGpuTemperature(value: number): string {
  if (!Number.isFinite(value) || value <= 0) {
    return "unknown";
  }
  return `${Math.round(value)}°C`;
}

function formatUtcDisplay(value: string): string {
  const text = String(value || "").trim();
  if (!text || text === "unknown") {
    return "unknown";
  }
  const date = new Date(text);
  if (Number.isNaN(date.getTime())) {
    return text;
  }
  return date.toISOString().replace(".000Z", "Z");
}

function localHref(enPath: string): string {
  return withLocale(locale, enPath);
}

const lastSyncUtc = formatUtcDisplay(rawLastSync);
const gpuTemperature = formatGpuTemperature(rawGpuTemperature);

const homeStructuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "LocalVRAM",
    url: `https://localvram.com/${locale}/`,
    inLanguage: locale,
    description: text.meta_description || "Pick the right model for your hardware in 60 seconds.",
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "LocalVRAM",
    url: `https://localvram.com/${locale}/`,
    logo: "https://localvram.com/branding/logo.svg",
  },
];
---

<BaseLayout
  title={text.meta_title}
  description={text.meta_description}
  locale={locale}
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={homeStructuredData}
  noindex={shouldNoindex}
>
  <header class="top-nav">
    <a class="brand" href={localHref("/en/")}>
      <img src="/branding/logo.svg" alt="LocalVRAM" />
    </a>
    <div class="ticker">
      RTX 3090: Stable @ {gpuTemperature} | DeepSeek-R1: Verified | Ollama: {ollamaVersion} | Last
      Sync: <span id="last-sync-local">local time loading...</span> (UTC {lastSyncUtc})
    </div>
    <a class="mode-btn" href={localHref("/en/status/data-freshness/")}>{text.nav_data_status}</a>
  </header>

  <main class="container">
    <section class="hero">
      <img
        class="verified-pill"
        src="/branding/ollama-verified-pill.svg"
        alt="Ollama Verified"
      />
      <h1>{text.hero_title}</h1>
      <p>{text.hero_intro}</p>
      <h2>{text.nav_hubs_title}</h2>
      <h3>{text.nav_hubs_intro}</h3>
      <div class="cta-row">
        <a class="btn btn-primary" href={localHref("/en/tools/vram-calculator/")}>{text.cta_start_vram}</a>
        <a class="btn" href={localHref("/en/models/")}>{text.cta_model_catalog}</a>
        <a class="btn" href={localHref("/en/tools/quantization-blind-test/")}>{text.cta_quant_test}</a>
        <a class="btn" href={localHref("/en/guides/ollama-vs-vllm-vram/")}>{text.cta_runtime_guide}</a>
        <a class="btn" href={localHref("/en/guides/best-coding-models/")}>{text.cta_best_coding}</a>
        <a class="btn" href={localHref("/en/guides/best-rag-models/")}>{text.cta_best_rag}</a>
        <a class="btn" href={localHref("/en/benchmarks/changelog/")}>{text.cta_benchmark_changelog}</a>
        <a class="btn" href={localHref("/en/status/data-freshness/")}>{text.cta_data_freshness}</a>
        <a class="btn" href={localHref("/en/status/runner-health/")}>{text.cta_runner_health}</a>
        <a class="btn" href={localHref("/en/status/pipeline-status/")}>{text.cta_pipeline_status}</a>
        <a class="btn" href={localHref("/en/status/conversion-funnel/")}>{text.cta_conversion_funnel}</a>
        <a class="btn" href={localHref("/en/status/submission-review/")}>{text.cta_submission_review}</a>
        <a class="btn" href={localHref("/en/status/content-publish/")}>{text.cta_content_publish}</a>
        <a class="btn" href={localHref("/en/matrix/")}>{text.cta_compat_matrix}</a>
        <a class="btn" href={localHref("/en/multimodal/")}>{text.cta_multimodal_hub}</a>
        <a class="btn" href={localHref("/en/errors/")}>{text.cta_error_kb}</a>
        <a class="btn" href={localHref("/en/blog/")}>{text.cta_daily_blog}</a>
        <a class="btn" href={localHref("/en/about/methodology/")}>{text.cta_methodology}</a>
      </div>
    </section>

    <section class="card-grid">
      <article class="card">
        <h2>{text.card_verified_title}</h2>
        <p>{text.card_verified_desc}</p>
        <a class="btn" href="/en/hardware/verified-3090/">{text.card_verified_cta}</a>
      </article>
      <article class="card">
        <h2>{text.card_error_title}</h2>
        <p>{text.card_error_desc}</p>
        <a class="btn" href={localHref("/en/errors/cuda-out-of-memory/")}>{text.card_error_cta}</a>
      </article>
      <article class="card">
        <h2>{text.card_run_rent_title}</h2>
        <p>{text.card_run_rent_desc}</p>
        <a class="btn" href="/en/affiliate/cloud-gpu/">{text.card_run_rent_cta}</a>
      </article>
      <article class="card">
        <h2>{text.card_cluster_title}</h2>
        <p>{text.card_cluster_desc}</p>
        <a class="btn" href={localHref("/en/guides/ollama-local-cluster-network/")}>{text.card_cluster_cta}</a>
      </article>
      <article class="card">
        <h2>{text.card_backend_title}</h2>
        <p>{text.card_backend_desc}</p>
        <a class="btn" href={localHref("/en/guides/ollama-vs-vllm-vram/")}>{text.card_backend_cta}</a>
      </article>
      <article class="card">
        <h2>{text.card_compare_title}</h2>
        <p>{text.card_compare_desc}</p>
        <a class="btn" href="/en/compare/qwen35-35b-q4-vs-llama31-70b-q4/">{text.card_compare_cta}</a>
      </article>
      <article class="card">
        <h2>{text.card_apple_title}</h2>
        <p>{text.card_apple_desc}</p>
        <a class="btn" href="/en/hardware/apple-silicon-llm-guide/">{text.card_apple_cta}</a>
      </article>
      <article class="card">
        <h2>{text.card_updates_title}</h2>
        <p>{text.card_updates_desc}</p>
        <a class="btn" href={localHref("/en/updates/")}>{text.card_updates_cta}</a>
      </article>
      <article class="card">
        <h2>{text.card_model_hub_title}</h2>
        <p>{text.card_model_hub_desc}</p>
        <a class="btn" href={localHref("/en/models/")}>{text.card_model_hub_cta}</a>
      </article>
      <article class="card">
        <h2>{text.card_changelog_title}</h2>
        <p>{text.card_changelog_desc}</p>
        <a class="btn" href={localHref("/en/benchmarks/changelog/")}>{text.card_changelog_cta}</a>
      </article>
    </section>
  </main>
  <script define:vars={{ rawLastSync }}>
    const localSyncNode = document.getElementById("last-sync-local");
    if (localSyncNode) {
      const raw = String(rawLastSync || "").trim();
      if (!raw || raw === "unknown") {
        localSyncNode.textContent = "unknown";
      } else {
        const date = new Date(raw);
        if (Number.isNaN(date.getTime())) {
          localSyncNode.textContent = raw;
        } else {
          const parts = new Intl.DateTimeFormat(undefined, {
            year: "numeric",
            month: "2-digit",
            day: "2-digit",
            hour: "2-digit",
            minute: "2-digit",
            second: "2-digit",
            hour12: false,
            timeZoneName: "short"
          }).formatToParts(date);
          const part = (type) => parts.find((item) => item.type === type)?.value || "";
          localSyncNode.textContent = `${part("year")}-${part("month")}-${part("day")} ${part("hour")}:${part("minute")}:${part("second")} ${part("timeZoneName") || "local"}`;
        }
      }
    }
  </script>
</BaseLayout>
