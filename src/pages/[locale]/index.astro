---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../data/root-alternates";
import { STANDARD_I18N_LOCALES, type ComLocale } from "../../config/i18n";
import { withLocale } from "../../lib/locale-paths";
import { resolvePageCopy, shouldNoindexByFallback } from "../../lib/i18n-copy";

export function getStaticPaths() {
  return STANDARD_I18N_LOCALES.map((locale) => ({
    params: { locale },
    props: { locale },
  }));
}

const { locale } = Astro.props as { locale: ComLocale };
const pagePath = `/${locale}/`;
const copy = resolvePageCopy("locale-home", locale, { localeUpper: locale.toUpperCase() });
const text = copy.fields;
const shouldNoindex = shouldNoindexByFallback(locale, copy.fallbackRatio);

const guideEntries = [
  {
    title: "Best Coding Models",
    href: withLocale(locale, "/en/guides/best-coding-models/"),
  },
  {
    title: "Best RAG Models",
    href: withLocale(locale, "/en/guides/best-rag-models/"),
  },
  {
    title: "Ollama vs vLLM VRAM",
    href: withLocale(locale, "/en/guides/ollama-vs-vllm-vram/"),
  },
];

const statusEntries = [
  {
    title: "Data Freshness",
    href: withLocale(locale, "/en/status/data-freshness/"),
  },
  {
    title: "Pipeline Status",
    href: withLocale(locale, "/en/status/pipeline-status/"),
  },
  {
    title: "Runner Health",
    href: withLocale(locale, "/en/status/runner-health/"),
  },
];
---

<BaseLayout
  title={text.meta_title}
  description={text.meta_description}
  locale={locale}
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  noindex={shouldNoindex}
>
  <main class="container">
    <section class="hero">
      <h1>{text.hero_title}</h1>
      <p>{text.hero_intro}</p>
      <div class="cta-row">
        <a class="btn btn-primary" href={withLocale(locale, "/en/guides/")}>{text.cta_guides}</a>
        <a class="btn" href={withLocale(locale, "/en/status/")}>{text.cta_status}</a>
        <a class="btn" href="/en/">{text.cta_english}</a>
      </div>
    </section>

    <section class="card-grid">
      <article class="card">
        <h2>{text.guides_title}</h2>
        <p>{text.guides_desc}</p>
        <ul class="locale-list">
          {guideEntries.map((item) => (
            <li><a href={item.href}>{item.title}</a></li>
          ))}
        </ul>
      </article>
      <article class="card">
        <h2>{text.status_title}</h2>
        <p>{text.status_desc}</p>
        <ul class="locale-list">
          {statusEntries.map((item) => (
            <li><a href={item.href}>{item.title}</a></li>
          ))}
        </ul>
      </article>
    </section>
  </main>
</BaseLayout>

<style>
  .locale-list {
    margin: 0;
    padding-left: 1.25rem;
    display: grid;
    gap: 0.4rem;
  }
</style>
