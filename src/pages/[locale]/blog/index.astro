---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../../data/root-alternates";
import { LOCALE_WAVE2, WAVE2_LOCALES, type Wave2Locale } from "../../../data/locale-wave2-copy";

export function getStaticPaths() {
  return WAVE2_LOCALES.map((locale) => ({
    params: { locale }
  }));
}

const localeParam = String(Astro.params.locale || "");
if (!Object.prototype.hasOwnProperty.call(LOCALE_WAVE2, localeParam)) {
  throw new Error(`Unsupported locale for blog hub: ${localeParam}`);
}

const locale = localeParam as Wave2Locale;
const copy = LOCALE_WAVE2[locale];
const pagePath = `/${locale}/blog/`;
const zhOrigin = (import.meta.env.PUBLIC_ZH_SITE_ORIGIN || "https://localvram.com").replace(/\/$/, "");
const siteOrigin = locale === "zh" ? zhOrigin : "https://localvram.com";
const pageUrl = `${siteOrigin}${pagePath}`;
const blogSchema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "LocalVRAM Daily Blog",
  inLanguage: locale,
  url: pageUrl
};
---

<BaseLayout
  title={`LocalVRAM ${locale.toUpperCase()} | Blog Hub`}
  description="Locale blog hub with daily benchmark notes, model insights, and troubleshooting topics."
  locale={locale}
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={blogSchema}
>
  <main class="container">
    <section class="card">
      <h1>Blog Hub</h1>
      <p>Use this locale entry to follow daily topics while the full post stream remains centered in EN.</p>
      <ul>
        <li>Weekly benchmark highlights.</li>
        <li>Model fit and VRAM planning posts.</li>
        <li>Error fixes and runtime comparison notes.</li>
      </ul>
      <div class="cta-row">
        <a class="btn btn-primary" href="/en/blog/">Open EN Blog Stream</a>
        <a class="btn" href={`/${locale}/tools/vram-calculator/`}>{copy.ctaTool}</a>
        <a class="btn" href={`/${locale}/guides/ollama-vs-vllm-vram/`}>{copy.ctaRuntimeGuide}</a>
      </div>
    </section>
  </main>
</BaseLayout>
