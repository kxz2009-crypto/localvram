---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { ROOT_ALTERNATES } from "../../../data/root-alternates";
import { STANDARD_I18N_LOCALES, type ComLocale } from "../../../config/i18n";
import { resolvePageCopy, shouldNoindexByFallback } from "../../../lib/i18n-copy";
import { withLocale } from "../../../lib/locale-paths";
import { resolveBlogCopy } from "../../../lib/i18n-blog-copy";

export function getStaticPaths() {
  return STANDARD_I18N_LOCALES.map((locale) => ({
    params: { locale },
    props: { locale },
  }));
}

const { locale } = Astro.props as { locale: ComLocale };
const localeUpper = locale.toUpperCase();
const homeCopy = resolvePageCopy("locale-home", locale, { localeUpper });
const home = homeCopy.fields;
const bridgeCopy = resolvePageCopy("guides-detail", locale, {
  localeUpper,
  itemTitle: home.cta_daily_blog,
  itemDescription: home.card_updates_desc || home.hero_intro,
});
const bridgeText = bridgeCopy.fields;
const posts = (await getCollection("blog", ({ data }) => data.lang === "en"))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const postCards = posts.map((post) => {
  const localized = resolveBlogCopy(post.slug, locale, {
    title: post.data.title,
    description: post.data.description,
    ctaLine: bridgeText.rollout_intro,
  });
  return {
    post,
    localized,
    localizedPath: withLocale(locale, `/en/blog/${post.slug}/`),
  };
});
const listFallbackRatio =
  postCards.length === 0
    ? 0
    : postCards.reduce((sum, card) => sum + card.localized.fallbackRatio, 0) / postCards.length;
const enPath = "/en/blog/";
const pagePath = withLocale(locale, enPath);
const title = home.cta_daily_blog;
const description = home.card_updates_desc || home.hero_intro;
const shouldNoindex = shouldNoindexByFallback(
  locale,
  Math.max(homeCopy.fallbackRatio, bridgeCopy.fallbackRatio, listFallbackRatio),
);
---

<BaseLayout
  title={title}
  description={description}
  locale={locale}
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  noindex={shouldNoindex}
>
  <main class="container">
    <section class="hero">
      <h1>{title}</h1>
      <p>{description}</p>
      <p>{bridgeText.rollout_intro}</p>
      <div class="cta-row">
        <a class="btn btn-primary" href={withLocale(locale, "/en/status/content-publish/")}>{home.cta_content_publish}</a>
        <a class="btn" href={withLocale(locale, "/en/")}>{home.cta_model_catalog}</a>
      </div>
    </section>

    <section class="post-list">
      {postCards.map((card) => {
        return (
          <article class="post-card">
            <h2><a href={card.localizedPath}>{card.localized.title}</a></h2>
            <p>{card.localized.description}</p>
            <div class="meta-row">
              <span>{card.post.data.pubDate.toISOString().slice(0, 10)}</span>
              <span>{card.post.data.intent}</span>
              <span>{card.post.data.tags.join(", ")}</span>
            </div>
          </article>
        );
      })}
    </section>
  </main>
</BaseLayout>
