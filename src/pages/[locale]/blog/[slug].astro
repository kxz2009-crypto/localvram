---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { createMarkdownProcessor } from "@astrojs/markdown-remark";
import { ROOT_ALTERNATES } from "../../../data/root-alternates";
import { STANDARD_I18N_LOCALES, type ComLocale } from "../../../config/i18n";
import { withLocale } from "../../../lib/locale-paths";
import { resolvePageCopy, shouldNoindexByFallback } from "../../../lib/i18n-copy";
import { resolveBlogCopy } from "../../../lib/i18n-blog-copy";
import { resolveBlogBody } from "../../../lib/i18n-blog-body";

const markdownProcessorPromise = createMarkdownProcessor({ syntaxHighlight: false });

const rewriteEnglishLinksToLocale = (html: string, locale: string): string => {
  const localPrefix = `/${locale}/`;
  return html
    .replace(
      /(href|src)=(["'])\/en\/([^"']*)\2/g,
      (_match, attr: string, quote: string, rest: string) => `${attr}=${quote}${localPrefix}${rest}${quote}`,
    )
    .replace(
      /(href|src)=(["'])https:\/\/localvram\.com\/en\/([^"']*)\2/g,
      (_match, attr: string, quote: string, rest: string) => `${attr}=${quote}https://localvram.com${localPrefix}${rest}${quote}`,
    )
    .replace(
      />(\s*)\/en\/([^<]+)</g,
      (_match, leading: string, rest: string) => `>${leading}${localPrefix}${rest}<`,
    )
    .replace(
      />(\s*)https:\/\/localvram\.com\/en\/([^<]+)</g,
      (_match, leading: string, rest: string) => `>${leading}https://localvram.com${localPrefix}${rest}<`,
    );
};

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => data.lang === "en");
  return STANDARD_I18N_LOCALES.flatMap((locale) =>
    posts.map((post) => ({
      params: { locale, slug: post.slug },
      props: { locale, post },
    })),
  );
}

const { locale, post } = Astro.props as { locale: ComLocale; post: any };
const localeUpper = locale.toUpperCase();
const enPath = `/en/blog/${post.slug}/`;
const pagePath = withLocale(locale, enPath);
const bodyResolution = resolveBlogBody(post.slug, locale, post.body || "");
const markdownProcessor = await markdownProcessorPromise;
const rendered = await markdownProcessor.render(bodyResolution.markdown);
const localizedHtml = rewriteEnglishLinksToLocale(rendered.code, locale);
const home = resolvePageCopy("locale-home", locale, { localeUpper }).fields;
const defaultCtaLine = home.hero_intro || "";
const blogCopy = resolveBlogCopy(post.slug, locale, {
  title: post.data.title,
  description: post.data.description,
  ctaLine: defaultCtaLine,
});
const copy = resolvePageCopy("guides-detail", locale, {
  localeUpper,
  itemTitle: blogCopy.title,
  itemDescription: blogCopy.description,
});
const text = copy.fields;
const showExtraCtaLine = Boolean(blogCopy.ctaLine && blogCopy.ctaLine !== text.rollout_intro);
const shouldNoindex = shouldNoindexByFallback(
  locale,
  Math.max(copy.fallbackRatio, blogCopy.fallbackRatio, bodyResolution.isLocalized ? 0 : 1),
);
---

<BaseLayout
  title={text.meta_title}
  description={text.meta_description}
  locale={locale}
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  noindex={shouldNoindex}
>
  <main class="container">
    <section class="hero">
      <h1>{blogCopy.title}</h1>
      <p>{blogCopy.description}</p>
      <p>{text.rollout_intro}</p>
      {showExtraCtaLine && <p>{blogCopy.ctaLine}</p>}
      <div class="cta-row">
        <a class="btn btn-primary" href={withLocale(locale, "/en/blog/")}>{text.cta_back_hub}</a>
        <a class="btn" href={withLocale(locale, "/en/tools/vram-calculator/")}>{home.cta_start_vram}</a>
        <a class="btn" href={withLocale(locale, "/en/errors/")}>{home.cta_error_kb}</a>
      </div>
    </section>

    <section class="prose">
      <div set:html={localizedHtml} />
    </section>

    <section class="card-grid">
      <article class="card">
        <h2>{text.state_title}</h2>
        <p>{text.state_desc}</p>
      </article>
      <article class="card">
        <h2>{text.next_title}</h2>
        <p>{text.next_desc}</p>
      </article>
    </section>
  </main>
</BaseLayout>
