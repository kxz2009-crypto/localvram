const text = copyByLocale[locale] || {
  title: `${home.ticker_gpu_label || "GPU"} VRAM Tiers | LocalVRAM`,
  description: home.card_model_hub_desc || "Pick Ollama models by available VRAM tier.",
  heading: "Hardware VRAM Tiers",
  intro: "Pick Ollama models by available VRAM tier.",
  tierSuffix: "GB VRAM",
  modelLabel: "Recommended models",
  speedLabel: "expected tok/s",
  fitLabel: "fit",
  viewModels: "View recommended models",
  appleTitle: "Apple Silicon",
  appleSummary: "Unified memory planning guide for local LLM inference on M-series devices.",
  appleCta: "Open Apple Silicon guide",
  verifiedTitle: "Verified on RTX 3090",
  verifiedSummary: "Measured model tags and sustained-load benchmark snapshots on 3090.",
  verifiedCta: "Open verification page",
};

const tierSummaryByVram: Partial<Record<ComLocale, Record<number, string>>> = {
  de: {
    8: "Einstiegsstufe fuer leichte Chat- und Coding-Modelle.",
    12: "Ausgewogene Stufe fuer 7B/13B mit praktikablen lokalen Laeufen.",
    16: "Komfortzone fuer 13B/14B und ausgewaehlte 32B-Q4-Setups.",
    24: "Preis-Leistungs-Stufe fuer grosse quantisierte Modelle und Long-Context-Tests.",
  },
  ko: {
    8: "가벼운 채팅과 코딩 모델을 위한 입문 티어입니다.",
    12: "7B/13B 모델을 현실적으로 로컬 실행하기 좋은 균형 티어입니다.",
    16: "13B/14B 및 일부 32B Q4 구성을 다루기 좋은 구간입니다.",
    24: "대형 양자화 모델과 긴 컨텍스트 테스트에 가치가 높은 티어입니다.",
  },
};

const tierSummary = (tier: HardwareTier) => tierSummaryByVram[locale]?.[tier.vram_gb] || tier.summary;

const hardwareItems = [
  ...hardwareTiers.map((tier) => ({
    name: `${tier.vram_gb}${text.tierSuffix}`,
    url: `https://localvram.com${withLocale(locale, `/en/hardware/${tier.vram_gb}gb-vram-models/`)}`,
  })),
  {
    name: text.appleTitle,
    url: `https://localvram.com${withLocale(locale, "/en/hardware/apple-silicon-llm-guide/")}`,
  },
  {
    name: text.verifiedTitle,
    url: `https://localvram.com${withLocale(locale, "/en/hardware/verified-3090/")}`,
  },
];

const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: text.heading,
  description: text.description,
  url: `https://localvram.com${pagePath}`,
  inLanguage: locale,
  mainEntity: {
    "@type": "ItemList",
    numberOfItems: hardwareItems.length,
    itemListElement: hardwareItems.map((item, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: item.name,
      url: item.url,
    })),
  },
};
---

<BaseLayout
  title={text.title}
  description={text.description}
  locale={locale}
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={structuredData}
>
  <main class="container">
    <section class="hero compact-hero">
      <p class="eyebrow">LocalVRAM</p>
      <h1>{text.heading}</h1>
      <p>{text.intro}</p>
    </section>

    <section class="card-grid" aria-label={text.heading}>
      {hardwareTiers.map((tier) => (
        <article class="card">
          <h2>{tier.vram_gb}{text.tierSuffix}</h2>
          <p>{tierSummary(tier)}</p>
          {tier.recommended_models && tier.recommended_models.length > 0 && (
            <>
              <h3>{text.modelLabel}</h3>
              <ul>
                {tier.recommended_models.map((model) => (
                  <li>
                    <strong>{model.name}</strong>
                    <br />
                    <span class="muted">
                      {text.speedLabel}: {model.expected_tok_s} | {text.fitLabel}: {model.fit}
                    </span>
                  </li>
                ))}
              </ul>
            </>
          )}
          <a class="btn btn-primary" href={withLocale(locale, `/en/hardware/${tier.vram_gb}gb-vram-models/`)}>
            {text.viewModels}
          </a>
        </article>
      ))}
      <article class="card">
        <h2>{text.appleTitle}</h2>
        <p>{text.appleSummary}</p>
        <a class="btn btn-primary" href={withLocale(locale, "/en/hardware/apple-silicon-llm-guide/")}>
          {text.appleCta}
        </a>
      </article>
      <article class="card">
        <h2>{text.verifiedTitle}</h2>
        <p>{text.verifiedSummary}</p>
        <a class="btn btn-primary" href={withLocale(locale, "/en/hardware/verified-3090/")}>
          {text.verifiedCta}
        </a>
      </article>
    </section>
  </main>
</BaseLayout>
