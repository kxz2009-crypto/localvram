---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import affiliateLinks from "../../../data/affiliate-links.json";
import tiers from "../../../data/hardware-tiers.json";
import { ROOT_ALTERNATES } from "../../../data/root-alternates";
import { STANDARD_I18N_LOCALES, type ComLocale } from "../../../config/i18n";
import { withLocale } from "../../../lib/locale-paths";

type TierModel = {
  name: string;
  fit: string;
  expected_tok_s: string;
};

type Tier = {
  vram_gb: number;
  title: string;
  summary: string;
  recommended_models: TierModel[];
};

type TierCopy = {
  title: string;
  summary: string;
};

type PageCopy = {
  titleSuffix: string;
  hardwareCrumb: string;
  introPrefix: string;
  recommendedModels: string;
  modelLabel: string;
  fitLabel: string;
  speedLabel: string;
  checkFit: string;
  hardwareUpgrade: string;
  cloudFallback: string;
  fitGood: string;
  fitConditional: string;
  fitEdge: string;
  tierCopy: Record<number, TierCopy>;
};

export function getStaticPaths() {
  const tierItems = Array.isArray(tiers?.tiers) ? (tiers.tiers as Tier[]) : [];
  return STANDARD_I18N_LOCALES.flatMap((locale) =>
    tierItems.map((tier) => ({
      params: { locale, slug: `${tier.vram_gb}gb-vram-models` },
      props: { locale, tier },
    })),
  );
}

const { locale, tier } = Astro.props as { locale: ComLocale; tier: Tier };
const enPath = `/en/hardware/${tier.vram_gb}gb-vram-models/`;
const pagePath = withLocale(locale, enPath);

