const text = copyByLocale[locale] || copyByLocale.de!;
const localizedTier = text.tierCopy[tier.vram_gb] || {
  title: tier.title,
  summary: tier.summary,
};
const title = `${tier.vram_gb}GB VRAM ${text.titleSuffix} | LocalVRAM`;

const fitLabel = (fit: string) => {
  if (fit === "good") return text.fitGood;
  if (fit === "conditional") return text.fitConditional;
  if (fit === "edge") return text.fitEdge;
  return fit;
};

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: localizedTier.title,
    description: localizedTier.summary,
    url: `https://localvram.com${pagePath}`,
    inLanguage: locale,
    mainEntity: {
      "@type": "ItemList",
      numberOfItems: tier.recommended_models.length,
      itemListElement: tier.recommended_models.map((model, index) => ({
        "@type": "ListItem",
        position: index + 1,
        name: model.name,
        description: `${text.fitLabel}: ${fitLabel(model.fit)}, ${text.speedLabel}: ${model.expected_tok_s}`,
      })),
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "LocalVRAM",
        item: `https://localvram.com${withLocale(locale, "/en/")}`,
      },
      {
        "@type": "ListItem",
        position: 2,
        name: text.hardwareCrumb,
        item: `https://localvram.com${withLocale(locale, "/en/hardware/")}`,
      },
      {
        "@type": "ListItem",
        position: 3,
        name: `${tier.vram_gb}GB VRAM`,
        item: `https://localvram.com${pagePath}`,
      },
    ],
  },
];
---

<BaseLayout
  title={title}
  description={localizedTier.summary}
  locale={locale}
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={structuredData}
>
  <main class="container">
    <section class="hero compact-hero">
      <p class="eyebrow">{tier.vram_gb}GB VRAM</p>
      <h1>{localizedTier.title}</h1>
      <p>{localizedTier.summary}</p>
      <p>{text.introPrefix}</p>
    </section>

    <section class="card">
      <h2>{text.recommendedModels}</h2>
      <table class="table">
        <thead>
          <tr>
            <th>{text.modelLabel}</th>
            <th>{text.fitLabel}</th>
            <th>{text.speedLabel}</th>
          </tr>
        </thead>
        <tbody>
          {tier.recommended_models.map((model) => (
            <tr>
              <td>{model.name}</td>
              <td>{fitLabel(model.fit)}</td>
              <td>{model.expected_tok_s}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    <section class="cta-row">
      <a class="btn" href={withLocale(locale, "/en/tools/vram-calculator/")}>{text.checkFit}</a>
      <a class="btn" href={withLocale(locale, "/en/affiliate/hardware-upgrade/")}>{text.hardwareUpgrade}</a>
      <a class="btn btn-primary" href={affiliateLinks.runpod}>{text.cloudFallback}</a>
    </section>
  </main>
</BaseLayout>
