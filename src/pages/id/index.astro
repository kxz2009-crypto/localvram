---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../data/root-alternates";

const pagePath = "/id/";
const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "LocalVRAM Indonesia",
  url: "https://localvram.com/id/",
  inLanguage: "id",
  description: "Rute bahasa Indonesia untuk ekspansi SEO multibahasa LocalVRAM."
};
---

<BaseLayout
  title="LocalVRAM | Indonesia"
  description="Rute bahasa Indonesia untuk ekspansi SEO multibahasa LocalVRAM."
  locale="id"
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={structuredData}
>
  <main class="container">
    <header class="simple-header">
      <img src="/branding/logo.svg" alt="LocalVRAM" />
      <a class="btn" href="/en/">English</a>
    </header>
    <section class="hero">
      <img class="verified-pill" src="/branding/ollama-verified-pill.svg" alt="Ollama Verified" />
      <h1>Rute bahasa Indonesia sudah aktif</h1>
      <p>
        SEO dan operasional bahasa Indonesia berjalan terpisah dari bahasa Inggris dan Mandarin.
      </p>
      <div class="cta-row">
        <a class="btn btn-primary" href="/id/tools/vram-calculator/">Buka alat utama</a>
        <a class="btn" href="/id/guides/local-llm-cost-vs-cloud/">Halaman topik</a>
        <a class="btn" href="/id/models/qwen35-35b-q4/">Halaman model</a>
        <a class="btn" href="/id/guides/ollama-vs-vllm-vram/">Panduan runtime</a>
        <a class="btn" href="/en/status/data-freshness/">Kesegaran data</a>
        <a class="btn" href="/id/tools/roi-calculator/">ROI Calculator</a>
        <a class="btn" href="/id/tools/quantization-blind-test/">Quantization Blind Test</a>
        <a class="btn" href="/id/benchmarks/changelog/">Benchmark Changelog</a>
        <a class="btn" href="/id/status/data-freshness/">Data Freshness</a>
        <a class="btn" href="/id/benchmarks/">Benchmark Hub</a>
        <a class="btn" href="/id/status/pipeline-status/">Pipeline Status</a>
        <a class="btn" href="/id/status/conversion-funnel/">Conversion Funnel</a>
        <a class="btn" href="/id/errors/">Error KB</a>
      </div>
    </section>
  </main>
</BaseLayout>




