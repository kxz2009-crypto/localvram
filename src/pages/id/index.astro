---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../data/root-alternates";

const pagePath = "/id/";
const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "LocalVRAM Indonesian",
  url: "https://localvram.com/id/",
  inLanguage: "id",
  description: "Indonesian route for LocalVRAM multilingual SEO expansion."
};
---

<BaseLayout
  title="LocalVRAM | Indonesian"
  description="Indonesian route for LocalVRAM multilingual SEO expansion."
  locale="id"
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={structuredData}
>
  <main class="container">
    <header class="simple-header">
      <img src="/branding/logo.svg" alt="LocalVRAM" />
      <a class="btn" href="/en/">English</a>
    </header>
    <section class="hero">
      <img class="verified-pill" src="/branding/ollama-verified-pill.svg" alt="Ollama Verified" />
      <h1>Indonesian locale route is now active</h1>
      <p>
        SEO and operations for Indonesian run independently from English and Chinese.
      </p>
      <div class="cta-row">
        <a class="btn btn-primary" href="/id/tools/vram-calculator/">Open core tool</a>
        <a class="btn" href="/id/guides/local-llm-cost-vs-cloud/">Topic page</a>
        <a class="btn" href="/id/models/qwen35-35b-q4/">Model page</a>
        <a class="btn" href="/en/status/data-freshness/">Data freshness</a>
      </div>
    </section>
  </main>
</BaseLayout>
