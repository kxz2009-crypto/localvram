---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../../data/root-alternates";

const pagePath = "/id/tools/vram-calculator/";
const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "Kalkulator VRAM ID",
  url: "https://localvram.com/id/tools/vram-calculator/",
  inLanguage: "id"
};
---

<BaseLayout
  title="LocalVRAM ID | VRAM Calculator"
  description="Halaman masuk konversi CTA bahasa Indonesia."
  locale="id"
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={structuredData}
>
  <main class="container">
    <section class="card">
      <h1>Kalkulator VRAM (ID)</h1>
      <p>Halaman konversi CTA untuk funnel bahasa Indonesia.</p>
      <div class="cta-row">
        <a class="btn" href="/id/guides/local-llm-cost-vs-cloud/">Kembali ke halaman topik</a>
        <a class="btn" href="/id/models/qwen35-35b-q4/">Kembali ke halaman model</a>
      </div>
    </section>
  </main>
</BaseLayout>