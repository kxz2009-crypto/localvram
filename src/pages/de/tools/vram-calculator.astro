---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../../data/root-alternates";

const pagePath = "/de/tools/vram-calculator/";
const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "VRAM Calculator DE",
  url: "https://localvram.com/de/tools/vram-calculator/",
  inLanguage: "de"
};
---

<BaseLayout
  title="LocalVRAM DE | VRAM Calculator"
  description="German CTA conversion entry."
  locale="de"
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={structuredData}
>
  <main class="container">
    <section class="card">
      <h1>VRAM Calculator (DE)</h1>
      <p>CTA conversion page for German funnel routing.</p>
      <div class="cta-row">
        <a class="btn" href="/de/guides/local-llm-cost-vs-cloud/">Back to topic page</a>
        <a class="btn" href="/de/models/qwen35-35b-q4/">Back to model page</a>
      </div>
    </section>
  </main>
</BaseLayout>
