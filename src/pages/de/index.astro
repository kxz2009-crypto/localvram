---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../data/root-alternates";

const pagePath = "/de/";
const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "LocalVRAM Deutsch",
  url: "https://localvram.com/de/",
  inLanguage: "de",
  description: "Deutsche Route fuer die mehrsprachige SEO-Expansion von LocalVRAM."
};
---

<BaseLayout
  title="LocalVRAM | Deutsch"
  description="Deutsche Route fuer die mehrsprachige SEO-Expansion von LocalVRAM."
  locale="de"
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={structuredData}
>
  <main class="container">
    <header class="simple-header">
      <img src="/branding/logo.svg" alt="LocalVRAM" />
      <a class="btn" href="/en/">English</a>
    </header>
    <section class="hero">
      <img class="verified-pill" src="/branding/ollama-verified-pill.svg" alt="Ollama Verified" />
      <h1>Die deutsche Route ist jetzt aktiv</h1>
      <p>
        SEO und Betrieb fuer Deutsch laufen getrennt von Englisch und Chinesisch.
      </p>
      <div class="cta-row">
        <a class="btn btn-primary" href="/de/tools/vram-calculator/">Kern-Tool oeffnen</a>
        <a class="btn" href="/de/guides/local-llm-cost-vs-cloud/">Themenseite</a>
        <a class="btn" href="/de/models/qwen35-35b-q4/">Modellseite</a>
        <a class="btn" href="/en/status/data-freshness/">Datenaktualitaet</a>
      </div>
    </section>
  </main>
</BaseLayout>
