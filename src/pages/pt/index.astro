---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../data/root-alternates";

const pagePath = "/pt/";
const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "LocalVRAM Portugues",
  url: "https://localvram.com/pt/",
  inLanguage: "pt",
  description: "Rota em portugues para a expansao SEO multilingue da LocalVRAM."
};
---

<BaseLayout
  title="LocalVRAM | Portugues"
  description="Rota em portugues para a expansao SEO multilingue da LocalVRAM."
  locale="pt"
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={structuredData}
>
  <main class="container">
    <header class="simple-header">
      <img src="/branding/logo.svg" alt="LocalVRAM" />
      <a class="btn" href="/en/">English</a>
    </header>
    <section class="hero">
      <img class="verified-pill" src="/branding/ollama-verified-pill.svg" alt="Ollama Verified" />
      <h1>A rota em portugues esta ativa</h1>
      <p>
        SEO e operacoes em portugues rodam de forma independente de ingles e chines.
      </p>
      <div class="cta-row">
        <a class="btn btn-primary" href="/pt/tools/vram-calculator/">Abrir ferramenta principal</a>
        <a class="btn" href="/pt/guides/local-llm-cost-vs-cloud/">Pagina de topico</a>
        <a class="btn" href="/pt/models/qwen35-35b-q4/">Pagina do modelo</a>
        <a class="btn" href="/pt/guides/ollama-vs-vllm-vram/">Guia de runtimes</a>
        <a class="btn" href="/en/status/data-freshness/">Atualizacao de dados</a>
        <a class="btn" href="/pt/tools/roi-calculator/">ROI Calculator</a>
        <a class="btn" href="/pt/tools/quantization-blind-test/">Quantization Blind Test</a>
        <a class="btn" href="/pt/benchmarks/changelog/">Benchmark Changelog</a>
        <a class="btn" href="/pt/status/data-freshness/">Data Freshness</a>
        <a class="btn" href="/pt/benchmarks/">Benchmark Hub</a>
        <a class="btn" href="/pt/status/pipeline-status/">Pipeline Status</a>
        <a class="btn" href="/pt/models/">Model Catalog</a>
        <a class="btn" href="/pt/hardware/">Hardware Tiers</a>
        <a class="btn" href="/pt/status/">Status Hub</a>
        <a class="btn" href="/pt/status/conversion-funnel/">Conversion Funnel</a>
        <a class="btn" href="/pt/errors/">Error KB</a>
      </div>
    </section>
  </main>
</BaseLayout>





