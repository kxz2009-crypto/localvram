---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../../data/root-alternates";

const pagePath = "/pt/tools/vram-calculator/";
const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "Calculadora de VRAM PT",
  url: "https://localvram.com/pt/tools/vram-calculator/",
  inLanguage: "pt"
};
---

<BaseLayout
  title="LocalVRAM PT | VRAM Calculator"
  description="Entrada de conversao CTA em portugues."
  locale="pt"
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={structuredData}
>
  <main class="container">
    <section class="card">
      <h1>Calculadora de VRAM (PT)</h1>
      <p>Pagina de conversao CTA para o funil em portugues.</p>
      <div class="cta-row">
        <a class="btn" href="/pt/guides/local-llm-cost-vs-cloud/">Voltar para a pagina de topico</a>
        <a class="btn" href="/pt/models/qwen35-35b-q4/">Voltar para a pagina do modelo</a>
      </div>
    </section>
  </main>
</BaseLayout>