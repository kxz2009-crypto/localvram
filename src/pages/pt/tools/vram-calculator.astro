---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../../data/root-alternates";

const pagePath = "/pt/tools/vram-calculator/";
const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "VRAM Calculator PT",
  url: "https://localvram.com/pt/tools/vram-calculator/",
  inLanguage: "pt"
};
---

<BaseLayout
  title="LocalVRAM PT | VRAM Calculator"
  description="Portuguese CTA conversion entry."
  locale="pt"
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={structuredData}
>
  <main class="container">
    <section class="card">
      <h1>VRAM Calculator (PT)</h1>
      <p>CTA conversion page for Portuguese funnel routing.</p>
      <div class="cta-row">
        <a class="btn" href="/pt/guides/local-llm-cost-vs-cloud/">Back to topic page</a>
        <a class="btn" href="/pt/models/qwen35-35b-q4/">Back to model page</a>
      </div>
    </section>
  </main>
</BaseLayout>
