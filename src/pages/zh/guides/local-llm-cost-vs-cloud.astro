---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../../data/root-alternates";

const pagePath = "/zh/guides/local-llm-cost-vs-cloud/";
const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "本地 LLM 成本 vs 云端成本",
  url: "https://localvram.com/zh/guides/local-llm-cost-vs-cloud/",
  inLanguage: "zh",
  description: "中文专题入口页，用于成本评估与部署决策。"
};
---

<BaseLayout
  title="LocalVRAM 中文 | 本地成本 vs 云端成本"
  description="中文专题入口页，用于成本评估与部署决策。"
  locale="zh"
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={structuredData}
>
  <main class="container">
    <section class="hero">
      <h1>本地 LLM 成本 vs 云端成本</h1>
      <p>该页面作为中文 SEO 漏斗入口，帮助你先判断预算，再决定部署方案。</p>
      <div class="cta-row">
        <a class="btn btn-primary" href="/zh/models/qwen35-35b-q4/">查看模型页</a>
        <a class="btn" href="/zh/tools/vram-calculator/">打开 VRAM 工具</a>
      </div>
    </section>
  </main>
</BaseLayout>
