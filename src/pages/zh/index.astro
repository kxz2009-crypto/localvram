---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="LocalVRAM | Compatibility Route"
  description="Local Ollama model compatibility and benchmark data hub."
  locale="zh"
>
  <main class="container">
    <header class="simple-header">
      <img src="/branding/logo.svg" alt="LocalVRAM" />
      <a class="btn" href="/en/">English</a>
    </header>
    <section class="hero">
      <img
        class="verified-pill"
        src="/branding/ollama-verified-pill.svg"
        alt="Ollama Verified"
      />
      <h1>Choose local models faster with verified benchmark data</h1>
      <p>This route is kept for compatibility. Use the English tools below.</p>
      <div class="cta-row">
        <a class="btn btn-primary" href="/en/tools/vram-calculator/">VRAM Calculator</a>
        <a class="btn" href="/en/status/data-freshness/">Data Freshness</a>
        <a class="btn" href="/en/status/runner-health/">Runner Health</a>
      </div>
    </section>
  </main>
</BaseLayout>
