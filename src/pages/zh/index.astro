---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../data/root-alternates";

const zhHomeStructuredData = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "LocalVRAM",
  url: "https://localvram.com/zh/",
  inLanguage: "zh",
  description: "Local Ollama model compatibility and benchmark data hub."
};
---

<BaseLayout
  title="LocalVRAM | Compatibility Route"
  description="Local Ollama model compatibility and benchmark data hub."
  locale="zh"
  canonicalPath="/zh/"
  alternates={ROOT_ALTERNATES}
  structuredData={zhHomeStructuredData}
>
  <main class="container">
    <header class="simple-header">
      <img src="/branding/logo.svg" alt="LocalVRAM" />
      <a class="btn" href="/en/">English</a>
    </header>
    <section class="hero">
      <img
        class="verified-pill"
        src="/branding/ollama-verified-pill.svg"
        alt="Ollama Verified"
      />
      <h1>Choose local models faster with verified benchmark data</h1>
      <p>This route is kept for compatibility. Use the English tools below.</p>
      <div class="cta-row">
        <a class="btn btn-primary" href="/zh/tools/vram-calculator/">VRAM Calculator</a>
        <a class="btn" href="/zh/guides/local-llm-cost-vs-cloud/">Cost Guide</a>
        <a class="btn" href="/zh/models/qwen35-35b-q4/">Model Page</a>
        <a class="btn" href="/zh/guides/ollama-vs-vllm-vram/">运行时对比指南</a>
        <a class="btn" href="/en/status/data-freshness/">Data Freshness</a>
        <a class="btn" href="/en/status/runner-health/">Runner Health</a>
        <a class="btn" href="/en/status/pipeline-status/">Pipeline Status</a>
      </div>
    </section>
  </main>
</BaseLayout>
