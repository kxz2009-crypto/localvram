---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../../data/root-alternates";

const pagePath = "/ja/tools/vram-calculator/";
const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "VRAM 計算機 JA",
  url: "https://localvram.com/ja/tools/vram-calculator/",
  inLanguage: "ja"
};
---

<BaseLayout
  title="LocalVRAM JA | VRAM Calculator"
  description="日本語のCTAコンバージョン入口。"
  locale="ja"
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={structuredData}
>
  <main class="container">
    <section class="card">
      <h1>VRAM 計算機 (JA)</h1>
      <p>日本語ファネル向けのCTAコンバージョンページ。</p>
      <div class="cta-row">
        <a class="btn" href="/ja/guides/local-llm-cost-vs-cloud/">トピックページに戻る</a>
        <a class="btn" href="/ja/models/qwen35-35b-q4/">モデルページに戻る</a>
      </div>
    </section>
  </main>
</BaseLayout>