---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../../data/root-alternates";

const pagePath = "/ja/tools/vram-calculator/";
const structuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "VRAM Calculator JA",
  url: "https://localvram.com/ja/tools/vram-calculator/",
  inLanguage: "ja"
};
---

<BaseLayout
  title="LocalVRAM JA | VRAM Calculator"
  description="Japanese CTA conversion entry."
  locale="ja"
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={structuredData}
>
  <main class="container">
    <section class="card">
      <h1>VRAM Calculator (JA)</h1>
      <p>CTA conversion page for Japanese funnel routing.</p>
      <div class="cta-row">
        <a class="btn" href="/ja/guides/local-llm-cost-vs-cloud/">Back to topic page</a>
        <a class="btn" href="/ja/models/qwen35-35b-q4/">Back to model page</a>
      </div>
    </section>
  </main>
</BaseLayout>
