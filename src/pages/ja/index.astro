---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { ROOT_ALTERNATES } from "../../data/root-alternates";

const pagePath = "/ja/";
const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "LocalVRAM 日本語",
  url: "https://localvram.com/ja/",
  inLanguage: "ja",
  description: "LocalVRAM 多言語SEO展開のための日本語ルート。"
};
---

<BaseLayout
  title="LocalVRAM | 日本語"
  description="LocalVRAM 多言語SEO展開のための日本語ルート。"
  locale="ja"
  canonicalPath={pagePath}
  alternates={ROOT_ALTERNATES}
  structuredData={structuredData}
>
  <main class="container">
    <header class="simple-header">
      <img src="/branding/logo.svg" alt="LocalVRAM" />
      <a class="btn" href="/en/">English</a>
    </header>
    <section class="hero">
      <img class="verified-pill" src="/branding/ollama-verified-pill.svg" alt="Ollama Verified" />
      <h1>日本語ルートを有効化しました</h1>
      <p>
        日本語向けのSEOと運用は、英語版と中国語版から分離して運用します。
      </p>
      <div class="cta-row">
        <a class="btn btn-primary" href="/ja/tools/vram-calculator/">主要ツールを開く</a>
        <a class="btn" href="/ja/guides/local-llm-cost-vs-cloud/">トピックページ</a>
        <a class="btn" href="/ja/models/qwen35-35b-q4/">モデルページ</a>
        <a class="btn" href="/ja/guides/ollama-vs-vllm-vram/">ランタイム比較ガイド</a>
        <a class="btn" href="/en/status/data-freshness/">データ鮮度</a>
        <a class="btn" href="/ja/tools/roi-calculator/">ROI Calculator</a>
        <a class="btn" href="/ja/tools/quantization-blind-test/">Quantization Blind Test</a>
        <a class="btn" href="/ja/benchmarks/changelog/">Benchmark Changelog</a>
        <a class="btn" href="/ja/status/data-freshness/">Data Freshness</a>
        <a class="btn" href="/ja/benchmarks/">Benchmark Hub</a>
        <a class="btn" href="/ja/status/pipeline-status/">Pipeline Status</a>
        <a class="btn" href="/ja/models/">Model Catalog</a>
        <a class="btn" href="/ja/hardware/">Hardware Tiers</a>
        <a class="btn" href="/ja/status/">Status Hub</a>
        <a class="btn" href="/ja/status/conversion-funnel/">Conversion Funnel</a>
        <a class="btn" href="/ja/errors/">Error KB</a>
      </div>
    </section>
  </main>
</BaseLayout>





