---
import "../styles/global.css";

type AlternateLink = {
  hrefLang: string;
  href: string;
};

interface Props {
  title?: string;
  description?: string;
  locale?: "en" | "es" | "pt" | "fr" | "de" | "ru" | "ja" | "ko" | "ar" | "hi" | "id" | "zh";
  canonicalPath?: string;
  canonicalOrigin?: string;
  alternates?: AlternateLink[];
  noindex?: boolean;
  ogImage?: string;
  ogType?: "website" | "article";
  publishedTime?: string;
  modifiedTime?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = "LocalVRAM",
  description = "Ollama compatibility and benchmark hub.",
  locale = "en",
  canonicalPath,
  canonicalOrigin,
  alternates = [],
  noindex = false,
  ogImage = "/og/default-og.svg",
  ogType = "website",
  publishedTime,
  modifiedTime,
  structuredData
} = Astro.props as Props;

const EN_SITE_URL = "https://localvram.com";
const ZH_SITE_URL = (import.meta.env.PUBLIC_ZH_SITE_ORIGIN || "https://localvram.com").replace(/\/$/, "");
const siteUrl = (canonicalOrigin || (locale === "zh" ? ZH_SITE_URL : EN_SITE_URL)).replace(/\/$/, "");
const path = canonicalPath || Astro.url.pathname || "/";
const canonicalUrl = new URL(path, siteUrl).toString();
const ogImageUrl = new URL(ogImage, siteUrl).toString();
const robotsContent = noindex ? "noindex, nofollow" : "index, follow";
const ogLocaleByLang: Record<string, string> = {
  en: "en_US",
  es: "es_ES",
  pt: "pt_BR",
  fr: "fr_FR",
  de: "de_DE",
  ru: "ru_RU",
  ja: "ja_JP",
  ko: "ko_KR",
  ar: "ar_SA",
  hi: "hi_IN",
  id: "id_ID",
  zh: "zh_CN"
};
const ogLocale = ogLocaleByLang[locale] || "en_US";
const jsonLdList = Array.isArray(structuredData)
  ? structuredData
  : structuredData
    ? [structuredData]
    : [];
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={canonicalUrl} />
    {alternates.map((item) => (
      <link rel="alternate" hrefLang={item.hrefLang} href={item.href} />
    ))}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="LocalVRAM" />
    <meta property="og:locale" content={ogLocale} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    {jsonLdList.map((item) => (
      <script type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
  </head>
  <body>
    <slot />
    <footer class="legal-footer">
      <a class="legal-mini-link" href="/legal/">Affiliate Disclosure &amp; Privacy Policy</a>
      <a class="legal-mini-link" href="/en/about/methodology/">Methodology</a>
      <p class="legal-copyright">© 2026 localVRAM.com | All Rights Reserved.</p>
    </footer>
  </body>
</html>
