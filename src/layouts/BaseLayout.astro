---
import "../styles/global.css";
import { ROOT_ALTERNATES, buildCnAlternates, buildLocaleAlternates } from "../data/root-alternates";
import {
  COM_LOCALES,
  DEFAULT_LOCALE,
  OG_LOCALE_BY_LANG,
  buildLocalePath,
  isLocalizedComPath,
  stripLocalePrefix,
} from "../config/i18n";
import type { ComLocale } from "../config/i18n";

type AlternateLink = {
  hrefLang: string;
  href: string;
};

interface Props {
  title?: string;
  description?: string;
  locale?: ComLocale | "zh";
  canonicalPath?: string;
  canonicalOrigin?: string;
  alternates?: AlternateLink[];
  noindex?: boolean;
  ogImage?: string;
  ogType?: "website" | "article";
  publishedTime?: string;
  modifiedTime?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = "LocalVRAM",
  description = "Ollama compatibility and benchmark hub.",
  locale = DEFAULT_LOCALE,
  canonicalPath,
  canonicalOrigin,
  alternates,
  noindex = false,
  ogImage = "/og/default-og.svg",
  ogType = "website",
  publishedTime,
  modifiedTime,
  structuredData
} = Astro.props as Props;

const EN_SITE_URL = "https://localvram.com";
const ZH_SITE_URL = "https://localvram.cn";
const buildTarget = String(process.env.BUILD_TARGET || "").trim().toLowerCase();
const isCnBuild = buildTarget === "cn";
const defaultSiteUrl = String(process.env.SITE_URL || (isCnBuild ? ZH_SITE_URL : EN_SITE_URL)).trim().replace(/\/$/, "");
const siteUrl = (canonicalOrigin || defaultSiteUrl || EN_SITE_URL).replace(/\/$/, "");
const rawPath = canonicalPath || Astro.url.pathname || "/";
function toCnCanonicalPath(inputPath: string): string {
  const cleaned = String(inputPath || "/").trim() || "/";
  if (cleaned === "/en" || cleaned === "/en/") {
    return "/";
  }
  if (cleaned.startsWith("/en/")) {
    return cleaned.slice(3);
  }
  return cleaned;
}
const path = isCnBuild ? toCnCanonicalPath(rawPath) : rawPath;
const canonicalUrl = new URL(path, siteUrl).toString();
const normalizedAlternates =
  alternates === ROOT_ALTERNATES
    ? (isCnBuild ? buildCnAlternates(path) : buildLocaleAlternates(path))
    : alternates;
const shouldAutoAlternates = normalizedAlternates === undefined && !noindex && (isCnBuild || isLocalizedComPath(path));
const resolvedAlternates = shouldAutoAlternates
  ? (isCnBuild ? buildCnAlternates(path) : buildLocaleAlternates(path))
  : (normalizedAlternates || []);
const ogImageUrl = new URL(ogImage, siteUrl).toString();
const robotsContent = noindex ? "noindex, nofollow" : "index, follow";
const ogLocale =
  locale === "zh"
    ? "zh_CN"
    : OG_LOCALE_BY_LANG[locale as keyof typeof OG_LOCALE_BY_LANG] || OG_LOCALE_BY_LANG[DEFAULT_LOCALE];
const htmlDir = locale === "ar" ? "rtl" : "ltr";
const localeTail = stripLocalePrefix(path);
const shouldShowLocaleSwitcher = isLocalizedComPath(path);
const localeLabelByCode: Record<string, string> = {
  en: "EN",
  es: "ES",
  pt: "PT",
  fr: "FR",
  de: "DE",
  ru: "RU",
  ja: "JA",
  ko: "KO",
  ar: "AR",
  hi: "HI",
  id: "ID",
};
const localeSwitchLinks = shouldShowLocaleSwitcher
  ? COM_LOCALES.map((code) => ({
      code,
      label: localeLabelByCode[code] || code.toUpperCase(),
      href: new URL(buildLocalePath(code, path), EN_SITE_URL).toString(),
    }))
  : [];
const zhSwitchPath = localeTail === "/" ? "/" : localeTail;
const zhSwitchHref = new URL(zhSwitchPath, ZH_SITE_URL).toString();
const cnIcpNumber = String(process.env.CN_ICP_NUMBER || "京ICP备2026009936号").trim();
const cnIcpUrl = String(process.env.CN_ICP_URL || "https://beian.miit.gov.cn/").trim();
const shouldShowCnIcp = isCnBuild && cnIcpNumber.length > 0;
const cnPublicSecurityStatus = String(process.env.CN_PUBLIC_SECURITY_STATUS || "pending").trim().toLowerCase();
const cnPublicSecurityRecordRaw = String(process.env.CN_PUBLIC_SECURITY_RECORD || "").trim();
const cnPublicSecurityRecord =
  cnPublicSecurityRecordRaw ||
  (cnPublicSecurityStatus === "active" ? "公安备案号待配置" : "公安备案办理中");
const cnPublicSecurityUrl = String(process.env.CN_PUBLIC_SECURITY_URL || "").trim();
const shouldShowCnPublicSecurity = isCnBuild && cnPublicSecurityRecord.length > 0;
const copyrightHost = isCnBuild ? "localvram.cn" : "localvram.com";
const jsonLdList = Array.isArray(structuredData)
  ? structuredData
  : structuredData
    ? [structuredData]
    : [];
function normalizeCnSchemaUrl(input: string): string {
  const value = String(input || "").trim();
  if (!value.startsWith(EN_SITE_URL)) {
    return input;
  }
  const rewritten = `${ZH_SITE_URL}${value.slice(EN_SITE_URL.length)}`;
  if (rewritten === `${ZH_SITE_URL}/en` || rewritten === `${ZH_SITE_URL}/en/`) {
    return `${ZH_SITE_URL}/`;
  }
  if (rewritten.startsWith(`${ZH_SITE_URL}/en/`)) {
    return `${ZH_SITE_URL}${rewritten.slice(`${ZH_SITE_URL}/en`.length)}`;
  }
  return rewritten;
}
function normalizeCnStructuredData<T>(input: T): T {
  if (Array.isArray(input)) {
    return input.map((item) => normalizeCnStructuredData(item)) as T;
  }
  if (input && typeof input === "object") {
    const source = input as Record<string, unknown>;
    const entries = Object.entries(source).map(([key, value]) => [key, normalizeCnStructuredData(value)]);
    return Object.fromEntries(entries) as T;
  }
  if (typeof input === "string") {
    return normalizeCnSchemaUrl(input) as T;
  }
  return input;
}
const resolvedJsonLdList = isCnBuild ? jsonLdList.map((item) => normalizeCnStructuredData(item)) : jsonLdList;
const footerCopyByLocale: Record<string, { legalText: string; rightsText: string }> = {
  en: {
    legalText: "Affiliate Disclosure & Privacy Policy",
    rightsText: "All Rights Reserved."
  },
  es: {
    legalText: "Divulgación de afiliados y política de privacidad",
    rightsText: "Todos los derechos reservados."
  },
  pt: {
    legalText: "Divulgação de afiliados e política de privacidade",
    rightsText: "Todos os direitos reservados."
  },
  fr: {
    legalText: "Divulgation d'affiliation et politique de confidentialité",
    rightsText: "Tous droits réservés."
  },
  de: {
    legalText: "Affiliate-Hinweis und Datenschutzrichtlinie",
    rightsText: "Alle Rechte vorbehalten."
  },
  ru: {
    legalText: "Раскрытие партнерских ссылок и политика конфиденциальности",
    rightsText: "Все права защищены."
  },
  ja: {
    legalText: "アフィリエイト開示とプライバシーポリシー",
    rightsText: "全著作権所有。"
  },
  ko: {
    legalText: "제휴 고지 및 개인정보처리방침",
    rightsText: "모든 권리 보유."
  },
  ar: {
    legalText: "إفصاح الشراكات وسياسة الخصوصية",
    rightsText: "جميع الحقوق محفوظة."
  },
  hi: {
    legalText: "एफिलिएट प्रकटीकरण और गोपनीयता नीति",
    rightsText: "सर्वाधिकार सुरक्षित।"
  },
  id: {
    legalText: "Pengungkapan afiliasi & kebijakan privasi",
    rightsText: "Hak cipta dilindungi."
  },
  zh: {
    legalText: "联盟披露与隐私政策",
    rightsText: "保留所有权利。"
  }
};
const footerCopy = footerCopyByLocale[locale] || footerCopyByLocale.en;
---

<!doctype html>
<html lang={locale} dir={htmlDir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    <meta http-equiv="X-Robots-Tag" content={robotsContent} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={canonicalUrl} />
    {resolvedAlternates.map((item) => (
      <link rel="alternate" hrefLang={item.hrefLang} href={item.href} />
    ))}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="LocalVRAM" />
    <meta property="og:locale" content={ogLocale} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    {resolvedJsonLdList.map((item) => (
      <script type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
  </head>
  <body>
    <slot />
    <footer class="legal-footer">
      {shouldShowLocaleSwitcher && (
        <nav class="locale-switcher" aria-label="Language switcher">
          {localeSwitchLinks.map((item) => (
            <a class:list={["locale-link", item.code === locale && "active"]} href={item.href}>
              {item.label}
            </a>
          ))}
          <a class="locale-link" href={zhSwitchHref}>ZH-CN</a>
        </nav>
      )}
      <a class="legal-mini-link" href="/legal/">{footerCopy.legalText}</a>
      {shouldShowCnIcp && (
        <a class="legal-mini-link" href={cnIcpUrl} target="_blank" rel="noopener noreferrer">
          {cnIcpNumber}
        </a>
      )}
      {shouldShowCnPublicSecurity &&
        (cnPublicSecurityUrl ? (
          <a class="legal-mini-link" href={cnPublicSecurityUrl} target="_blank" rel="noopener noreferrer">
            {cnPublicSecurityRecord}
          </a>
        ) : (
          <span class="legal-mini-link">{cnPublicSecurityRecord}</span>
        ))}
      <p class="legal-copyright">© 2026 {copyrightHost} | {footerCopy.rightsText}</p>
    </footer>
  </body>
</html>
