---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  locale?: "en" | "zh";
}

const {
  title = "LocalVRAM",
  description = "Ollama compatibility and benchmark hub.",
  locale = "en"
} = Astro.props as Props;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={`https://localvram.com${Astro.url.pathname}`} />
    <link rel="alternate" hrefLang="en" href={`https://localvram.com/en${Astro.url.pathname.replace(/^\/(en|zh)/, "")}`} />
    <link rel="alternate" hrefLang="zh" href={`https://localvram.com/zh${Astro.url.pathname.replace(/^\/(en|zh)/, "")}`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://localvram.com${Astro.url.pathname}`} />
    <meta property="og:image" content="https://localvram.com/og/default-og.svg" />
  </head>
  <body>
    <slot />
    <footer class="legal-footer">
      <p>
        <strong>Affiliate Disclosure:</strong><br />
        localVRAM.com is a participant in the Amazon Services LLC Associates Program,
        RunPod Affiliate Program, and Vast.ai Referral Program. We may earn a
        commission from qualifying purchases or sign-ups made through our links at no
        additional cost to you. This helps support our server costs and 3090 hardware
        maintenance.
      </p>
      <p>
        <strong>Disclaimer:</strong><br />
        All content provided on localVRAM.com, including GPU benchmarks,
        configuration scripts, and hardware advice, is for informational purposes
        only. We are not responsible for any hardware damage, data loss, or
        financial loss resulting from the use of information on this site. Handle
        your hardware at your own risk.
      </p>
      <p>
        <strong>Privacy Policy:</strong><br />
        We do not directly collect personal user data. However, we use third-party
        tools (like Cloudflare and Affiliate Tags) that may use cookies to analyze
        web traffic and track referral conversions. By using this site, you agree to
        our use of cookies.
      </p>
      <p class="copyright">© 2026 localVRAM.com | All Rights Reserved.</p>
    </footer>
  </body>
</html>
