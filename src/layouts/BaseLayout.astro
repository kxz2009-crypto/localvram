---
import "../styles/global.css";
import { ROOT_ALTERNATES, buildLocaleAlternates } from "../data/root-alternates";
import { DEFAULT_LOCALE, OG_LOCALE_BY_LANG, isLocalizedComPath, isRtlLocale } from "../config/i18n";

type AlternateLink = {
  hrefLang: string;
  href: string;
};

interface Props {
  title?: string;
  description?: string;
  locale?: keyof typeof OG_LOCALE_BY_LANG;
  canonicalPath?: string;
  canonicalOrigin?: string;
  alternates?: AlternateLink[];
  noindex?: boolean;
  ogImage?: string;
  ogType?: "website" | "article";
  publishedTime?: string;
  modifiedTime?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = "LocalVRAM",
  description = "Ollama compatibility and benchmark hub.",
  locale = DEFAULT_LOCALE,
  canonicalPath,
  canonicalOrigin,
  alternates,
  noindex = false,
  ogImage = "/og/default-og.svg",
  ogType = "website",
  publishedTime,
  modifiedTime,
  structuredData
} = Astro.props as Props;

const EN_SITE_URL = "https://localvram.com";
const siteUrl = (canonicalOrigin || EN_SITE_URL).replace(/\/$/, "");
const path = canonicalPath || Astro.url.pathname || "/";
const canonicalUrl = new URL(path, siteUrl).toString();
const normalizedAlternates = alternates === ROOT_ALTERNATES ? buildLocaleAlternates(path) : alternates;
const shouldAutoAlternates = normalizedAlternates === undefined && !noindex && isLocalizedComPath(path);
const resolvedAlternates = shouldAutoAlternates ? buildLocaleAlternates(path) : (normalizedAlternates || []);
const ogImageUrl = new URL(ogImage, siteUrl).toString();
const robotsContent = noindex ? "noindex, nofollow" : "index, follow";
const ogLocale = OG_LOCALE_BY_LANG[locale] || OG_LOCALE_BY_LANG[DEFAULT_LOCALE];
const htmlDir = isRtlLocale(locale) ? "rtl" : "ltr";
const jsonLdList = Array.isArray(structuredData)
  ? structuredData
  : structuredData
    ? [structuredData]
    : [];
const footerCopy = {
  legalText: "Affiliate Disclosure & Privacy Policy",
  rightsText: "All Rights Reserved."
};
---

<!doctype html>
<html lang={locale} dir={htmlDir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    <meta http-equiv="X-Robots-Tag" content={robotsContent} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={canonicalUrl} />
    {resolvedAlternates.map((item) => (
      <link rel="alternate" hrefLang={item.hrefLang} href={item.href} />
    ))}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="LocalVRAM" />
    <meta property="og:locale" content={ogLocale} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    {jsonLdList.map((item) => (
      <script type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}
  </head>
  <body>
    <slot />
    <footer class="legal-footer">
      <a class="legal-mini-link" href="/legal/">{footerCopy.legalText}</a>
      <p class="legal-copyright">© 2026 localVRAM.com | {footerCopy.rightsText}</p>
    </footer>
  </body>
</html>
