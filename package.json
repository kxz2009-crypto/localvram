{
  "name": "localvram",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "python scripts/build-sitemap.py --target com --out-dir public && astro build",
    "build:cn": "python scripts/build-cn-site.py",
    "preview": "astro preview",
    "sitemap:build": "python scripts/build-sitemap.py",
    "i18n:readiness": "python scripts/i18n-readiness.py",
    "i18n:template": "python scripts/export-i18n-translation-template.py",
    "i18n:template:all": "python scripts/export-i18n-translation-template.py --all",
    "i18n:auto-fill-pack": "python scripts/auto-fill-i18n-pack.py",
    "i18n:apply-pack": "python scripts/apply-i18n-translation-pack.py",
    "i18n:apply-wave": "python scripts/apply-i18n-wave.py",
    "i18n:pack-status": "python scripts/i18n-pack-status.py",
    "i18n:blog-copy:sync": "python scripts/sync-i18n-blog-copy.py",
    "i18n:blog-body:auto-fill": "python scripts/auto-fill-i18n-blog-body.py",
    "i18n:blog-body:auto-fill:zh": "python scripts/auto-fill-i18n-blog-body.py --locales zh --overwrite",
    "i18n:blog-body:auto-fill:zh:stub": "python scripts/auto-fill-i18n-blog-body.py --locales zh --overwrite --fallback-mode stub",
    "i18n:blog-body:auto-fill:zh:resolve-stub": "python scripts/auto-fill-i18n-blog-body.py --locales zh --overwrite --overwrite-stub-only",
    "i18n:blog-body:status": "python scripts/i18n-blog-body-status.py",
    "i18n:validate-packs": "python scripts/validate-i18n-packs.py",
    "i18n:qa-copy": "python scripts/audit-i18n-translation-quality.py",
    "i18n:sitemap-report": "python scripts/i18n-sitemap-section-report.py",
    "i18n:section-parity-summary": "python scripts/export-i18n-section-parity-summary.py",
    "i18n:check-section-parity": "python scripts/check-i18n-section-parity.py",
    "i18n:section-parity-diff": "python scripts/diff-i18n-section-parity.py --current dist/seo-audit/i18n-section-parity-summary.json --out dist/seo-audit/i18n-section-parity-diff.json",
    "i18n:check-rtl-signoff": "python scripts/check-rtl-visual-signoff.py",
    "i18n:export-review-csv": "python scripts/export-i18n-manual-review-checklist.py",
    "verify:prod:i18n": "powershell -ExecutionPolicy Bypass -File scripts/verify-production-i18n.ps1",
    "verify:prod:cn": "powershell -ExecutionPolicy Bypass -File scripts/verify-cn-domain.ps1",
    "verify:prod:baidu": "python scripts/verify-baidu-readiness.py",
    "baidu:push:cn:dry-run": "python scripts/push-baidu-urls.py --site https://localvram.cn --sitemap-url https://localvram.cn/sitemap-cn.xml --dry-run",
    "baidu:push:cn": "python scripts/push-baidu-urls.py --site https://localvram.cn --sitemap-url https://localvram.cn/sitemap-cn.xml",
    "baidu:plan:cn:2day": "python scripts/push-baidu-urls-2day.py --site https://localvram.cn --sitemap-url https://localvram.cn/sitemap-cn.xml --day 1 --dry-run --out-file dist/seo-audit/baidu/day1-urls.txt && python scripts/push-baidu-urls-2day.py --site https://localvram.cn --sitemap-url https://localvram.cn/sitemap-cn.xml --day 2 --dry-run --out-file dist/seo-audit/baidu/day2-urls.txt",
    "baidu:push:cn:tomorrow": "python scripts/push-baidu-urls-2day.py --site https://localvram.cn --sitemap-url https://localvram.cn/sitemap-cn.xml --day 1 --out-file dist/seo-audit/baidu/day1-urls.txt",
    "baidu:push:cn:day-after": "python scripts/push-baidu-urls-2day.py --site https://localvram.cn --sitemap-url https://localvram.cn/sitemap-cn.xml --day 2 --out-file dist/seo-audit/baidu/day2-urls.txt",
    "check:cn-blog-sync": "python scripts/check-cn-blog-sync.py",
    "check:locale-links": "python scripts/check-locale-links.py",
    "check:quality": "python scripts/quality-gate.py",
    "report:freshness": "python scripts/report-data-freshness.py",
    "test:unit": "python -m unittest discover -s tests -p \"test_*.py\"",
    "test:smoke": "python scripts/smoke-tests.py",
    "test": "npm run check:quality && npm run test:unit && npm run test:smoke"
  },
  "dependencies": {
    "astro": "^5.18.0"
  }
}
